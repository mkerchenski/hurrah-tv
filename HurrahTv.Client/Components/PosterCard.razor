@inject ApiClient Api

<div class="poster-card relative rounded-lg overflow-hidden bg-surface-50 cursor-pointer group"
     @onclick="NavigateToDetails">
    @if (!string.IsNullOrEmpty(Result.PosterUrl()))
    {
        <img src="@Result.PosterUrl()" alt="@Result.Title"
             class="w-full aspect-[2/3] object-cover" loading="lazy" />
    }
    else
    {
        <div class="w-full aspect-[2/3] bg-surface-100 flex items-center justify-center">
            <span class="text-gray-500 text-sm text-center px-2">@Result.Title</span>
        </div>
    }

    <!-- hover overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent
                opacity-0 group-hover:opacity-100 transition-opacity duration-200
                flex flex-col justify-end p-3">
        <div class="text-white font-semibold text-sm leading-tight mb-1">@Result.Title</div>
        @if (!string.IsNullOrEmpty(Result.Year))
        {
            <div class="text-gray-300 text-xs mb-2">@Result.Year &middot; @Result.MediaType.ToUpper()</div>
        }
        @if (Result.VoteAverage > 0)
        {
            <div class="flex items-center gap-1 text-xs mb-2">
                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span class="text-gray-300">@Result.VoteAverage.ToString("F1")</span>
            </div>
        }

        <!-- service badges -->
        @if (Result.AvailableOn.Count > 0)
        {
            <div class="flex gap-1 flex-wrap">
                @foreach (AvailableService svc in Result.AvailableOn.Take(4))
                {
                    @if (!string.IsNullOrEmpty(svc.LogoUrl()))
                    {
                        <img src="@svc.LogoUrl("w45")" alt="@svc.ProviderName" title="@svc.ProviderName"
                             class="w-6 h-6 rounded service-badge" />
                    }
                }
            </div>
        }
    </div>

    <!-- queue button -->
    <button class="absolute top-2 right-2 bg-black/60 hover:bg-accent text-white rounded-full w-8 h-8
                   flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all"
            @onclick="AddToQueue" @onclick:stopPropagation="true"
            title="Add to queue">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
    </button>

    @if (_addedToQueue)
    {
        <div class="absolute top-2 right-2 bg-green-600 text-white rounded-full w-8 h-8
                    flex items-center justify-center transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public SearchResult Result { get; set; } = null!;
    [Inject] NavigationManager Nav { get; set; } = null!;

    private bool _addedToQueue;

    private void NavigateToDetails()
    {
        Nav.NavigateTo($"/details/{Result.MediaType}/{Result.TmdbId}");
    }

    private async Task AddToQueue()
    {
        string serviceIds = System.Text.Json.JsonSerializer.Serialize(
            Result.AvailableOn.Select(s => s.ProviderId).ToList());

        QueueItem item = new()
        {
            TmdbId = Result.TmdbId,
            MediaType = Result.MediaType,
            Title = Result.Title,
            PosterPath = Result.PosterPath,
            AvailableOnJson = serviceIds,
        };

        QueueItem? added = await Api.AddToQueueAsync(item);
        if (added != null)
        {
            _addedToQueue = true;
            StateHasChanged();
            await Task.Delay(1500);
            _addedToQueue = false;
            StateHasChanged();
        }
    }
}
