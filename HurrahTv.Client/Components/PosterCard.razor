@implements IAsyncDisposable
@inject ApiClient Api
@inject IJSRuntime JS

<div @ref="_cardRef" class="poster-card relative rounded-lg overflow-hidden bg-surface-50 cursor-pointer group"
     @onclick="NavigateToDetails">
    @if (!string.IsNullOrEmpty(Result.PosterUrl()))
    {
        <img src="@Result.PosterUrl()" alt="@Result.Title"
             class="w-full aspect-[2/3] object-cover" loading="lazy" />
    }
    else
    {
        <div class="w-full aspect-[2/3] bg-gradient-to-b from-surface-200 to-surface-100 flex flex-col items-center justify-center p-3">
            <span class="icon-[heroicons--film] w-8 h-8 text-gray-600 mb-2"></span>
            <span class="text-gray-400 text-xs text-center font-medium leading-tight">@Result.Title</span>
            @if (!string.IsNullOrEmpty(Result.Year))
            {
                <span class="text-gray-600 text-[10px] mt-0.5">@Result.Year</span>
            }
        </div>
    }

    <!-- media type badge — shown in All mode so TV and movies are distinguishable -->
    @if (ShowMediaTypeBadge)
    {
        <div class="absolute top-1.5 left-1.5 bg-black/60 text-gray-200 text-[10px] px-1.5 py-0.5 rounded backdrop-blur-sm pointer-events-none">
            @(Result.MediaType == "tv" ? "TV" : "Movie")
        </div>
    }

    <!-- new episode indicator -->
    @if (HasNewEpisode)
    {
        <div class="absolute top-1.5 right-1.5 bg-black/60 backdrop-blur-sm rounded-full w-6 h-6 flex items-center justify-center"
             title="New episode available">
            <span class="icon-[heroicons--sparkles] w-3.5 h-3.5 text-amber-300"></span>
        </div>
    }

    <!-- network badges — always visible at bottom of poster -->
    @if (Result.AvailableOn.Count > 0)
    {
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 to-transparent p-2 pt-6">
            <div class="flex gap-1 flex-wrap">
                @foreach (AvailableService svc in Result.AvailableOn.Take(4))
                {
                    @if (!string.IsNullOrEmpty(svc.LogoUrl()))
                    {
                        <img src="@svc.LogoUrl("w45")" alt="@svc.ProviderName" title="@svc.ProviderName"
                             class="w-5 h-5 md:w-6 md:h-6 rounded service-badge" />
                    }
                }
            </div>
        </div>
    }
    else if (Result.NotOnYourServices)
    {
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 to-transparent p-2 pt-6">
            <span class="text-[10px] text-yellow-500/80 font-medium bg-black/40 px-1.5 py-0.5 rounded">Not on your services</span>
        </div>
    }
    else if (Result.NoStreamingInfo)
    {
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 to-transparent p-2 pt-6">
            <span class="text-[10px] text-gray-500 font-medium bg-black/40 px-1.5 py-0.5 rounded">Not streaming</span>
        </div>
    }

    <!-- hover overlay (desktop only) -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent
                opacity-0 group-hover:opacity-100 transition-opacity duration-200
                hidden md:flex flex-col justify-end p-3">
        <div class="text-white font-semibold text-sm leading-tight mb-1">@Result.Title</div>
        @if (!string.IsNullOrEmpty(Result.Year))
        {
            <div class="text-gray-300 text-xs mb-2">@Result.Year &middot; @Result.MediaType.ToUpper()</div>
        }
        @if (Result.VoteAverage > 0)
        {
            <div class="flex items-center gap-1 text-xs mb-2">
                <span class="icon-[heroicons--star-20-solid] w-3.5 h-3.5 text-yellow-400"></span>
                <span class="text-gray-300">@Result.VoteAverage.ToString("F1")</span>
            </div>
        }

        <!-- service badges in hover too for context -->
        @if (Result.AvailableOn.Count > 0)
        {
            <div class="flex gap-1 flex-wrap">
                @foreach (AvailableService svc in Result.AvailableOn.Take(4))
                {
                    @if (!string.IsNullOrEmpty(svc.LogoUrl()))
                    {
                        <img src="@svc.LogoUrl("w45")" alt="@svc.ProviderName" title="@svc.ProviderName"
                             class="w-6 h-6 rounded service-badge" />
                    }
                }
            </div>
        }
    </div>

    <!-- action buttons (desktop hover) -->
    @if (_actionState == ActionState.None)
    {
        <div class="absolute top-2 right-2 flex gap-1.5 opacity-0 group-hover:opacity-100 transition-all hidden md:flex">
            <button class="bg-black/60 hover:bg-accent text-white rounded-full w-8 h-8
                           flex items-center justify-center transition-colors"
                    @onclick="AddToQueue" @onclick:stopPropagation="true"
                    title="Want to watch">
                <span class="icon-[heroicons--plus] w-4 h-4"></span>
            </button>
            <button class="bg-black/60 hover:bg-green-600 text-white rounded-full w-8 h-8
                           flex items-center justify-center transition-colors"
                    @onclick="MarkThumbsUp" @onclick:stopPropagation="true"
                    title="Thumbs up">
                <span class="icon-[heroicons--hand-thumb-up] w-4 h-4"></span>
            </button>
            <button class="bg-black/60 hover:bg-blue-600 text-white rounded-full w-8 h-8
                           flex items-center justify-center transition-colors"
                    @onclick="MarkSeen" @onclick:stopPropagation="true"
                    title="I've seen this">
                <span class="icon-[heroicons--eye] w-4 h-4"></span>
            </button>
        </div>
    }
    else if (_actionState == ActionState.Added)
    {
        <div class="absolute top-2 right-2 bg-green-600 text-white rounded-full w-6 h-6
                    flex items-center justify-center transition-all">
            <span class="icon-[heroicons--check] w-3.5 h-3.5"></span>
        </div>
    }
    else if (_actionState == ActionState.Seen)
    {
        <div class="absolute top-2 right-2 bg-blue-600 text-white rounded-full w-6 h-6
                    flex items-center justify-center transition-all">
            <span class="icon-[heroicons--eye] w-3.5 h-3.5"></span>
        </div>
    }
    else if (_actionState == ActionState.ThumbsUp)
    {
        <div class="absolute top-2 right-2 bg-green-600 text-white rounded-full w-6 h-6
                    flex items-center justify-center transition-all">
            <span class="icon-[heroicons--hand-thumb-up] w-3.5 h-3.5"></span>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public SearchResult Result { get; set; } = null!;
    [Parameter] public bool HasNewEpisode { get; set; }
    [Parameter] public bool ShowMediaTypeBadge { get; set; }
    [Inject] NavigationManager Nav { get; set; } = null!;
    [Inject] QuickActionService QuickActionSvc { get; set; } = null!;

    private ActionState _actionState = ActionState.None;
    private bool _disposed;
    private ElementReference _cardRef;
    private DotNetObjectReference<PosterCard>? _dotNetRef;
    private IJSObjectReference? _longPressHandle;

    private enum ActionState { None, Added, Seen, ThumbsUp }

    private void NavigateToDetails()
    {
        Nav.NavigateTo($"/details/{Result.MediaType}/{Result.TmdbId}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_longPressHandle != null) return;
        _dotNetRef ??= DotNetObjectReference.Create(this);
        try
        {
            _longPressHandle = await JS.InvokeAsync<IJSObjectReference>(
                "hurrahLongPress", _cardRef, _dotNetRef, nameof(OnLongPress), 0);
        }
        catch (JSException) { }
    }

    [JSInvokable]
    public void OnLongPress(int _)
    {
        QuickActionSvc.ShowForSearchResult(Result);
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_longPressHandle != null)
        {
            try { await JS.InvokeVoidAsync("hurrahLongPressCleanup", _longPressHandle); }
            catch { }
        }
        _dotNetRef?.Dispose();
    }

    private async Task AddToQueue()
    {
        QueueItem? added = await Api.AddToQueueAsync(Result.ToQueueItem());
        if (added != null)
            await ShowTemporaryState(ActionState.Added);
    }

    private async Task MarkThumbsUp()
    {
        // use MarkAsSeen (upserts) so it works for both new and existing queue items
        QueueItem? item = await Api.MarkAsSeenAsync(Result);
        if (item != null)
        {
            await Api.UpdateSentimentAsync(item.Id, SentimentLevel.Up);
            await ShowTemporaryState(ActionState.ThumbsUp);
        }
    }

    private async Task MarkSeen()
    {
        QueueItem? item = await Api.MarkAsSeenAsync(Result);
        if (item != null)
            await ShowTemporaryState(ActionState.Seen);
    }

    private async Task ShowTemporaryState(ActionState state)
    {
        _actionState = state;
        if (!_disposed) StateHasChanged();
        await Task.Delay(1500);
        _actionState = ActionState.None;
        if (!_disposed) StateHasChanged();
    }
}
