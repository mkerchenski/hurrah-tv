<ChipPicker Items="_items" @bind-SelectedIds="SelectedIds" @bind-SelectedIds:after="NotifyChanged"
            SizeClass="px-4 py-2" GapClass="gap-3" />

@code {
    [Parameter] public List<int> SelectedIds { get; set; } = [];
    [Parameter] public EventCallback<List<int>> SelectedIdsChanged { get; set; }

    private static readonly List<ChipPicker.ChipItem> _items =
        StreamingService.All.Select(s => new ChipPicker.ChipItem(s.TmdbProviderId, s.Name)).ToList();

    private async Task NotifyChanged() => await SelectedIdsChanged.InvokeAsync(SelectedIds);
}
