<section class="bg-surface-50 rounded-xl overflow-hidden">
    <h2 class="text-sm uppercase tracking-wide text-gray-400 px-4 pt-4 mb-3">@Title</h2>
    @if (Buckets is null || Buckets.Count == 0)
    {
        <div class="px-4 pb-4 text-gray-500 text-sm">No data.</div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-surface-100 text-gray-400 text-xs uppercase">
                    <tr>
                        <th class="px-3 py-2 text-left">When</th>
                        <th class="px-3 py-2 text-right">Calls</th>
                        <th class="px-3 py-2 text-right">Users</th>
                        <th class="px-3 py-2 text-right">In</th>
                        <th class="px-3 py-2 text-right">Out</th>
                        <th class="px-3 py-2 text-right">Cost</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (AdminAiUsageBucket row in Buckets)
                    {
                        <tr class="border-t border-surface-200">
                            <td class="px-3 py-2">@row.BucketStart.ToLocalTime().ToString(Format)</td>
                            <td class="px-3 py-2 text-right">@row.RequestCount</td>
                            <td class="px-3 py-2 text-right">@row.DistinctUsers</td>
                            <td class="px-3 py-2 text-right text-gray-400">@row.InputTokens.ToString("N0")</td>
                            <td class="px-3 py-2 text-right text-gray-400">@row.OutputTokens.ToString("N0")</td>
                            <td class="px-3 py-2 text-right">@($"${row.CostUsd:F4}")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public List<AdminAiUsageBucket>? Buckets { get; set; }
    [Parameter] public string Format { get; set; } = "yyyy-MM-dd";
}
