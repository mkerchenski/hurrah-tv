@implements IDisposable
@inject ApiClient Api
@inject QuickActionService QuickActionSvc

@if (_visible)
{
    <div class="fixed inset-0 bg-black/80 z-[60] flex items-end justify-center isolate" @onclick="Close">
        <div class="bg-surface-50 rounded-t-2xl w-full max-w-sm p-5 pb-24 md:pb-8 animate-slide-up"
             @onclick:stopPropagation="true">

            <!-- header with poster + title -->
            <div class="flex items-center gap-3 mb-4">
                @if (!string.IsNullOrEmpty(_posterUrl))
                {
                    <img src="@_posterUrl" alt="" class="w-10 h-14 object-cover rounded" />
                }
                <div class="flex-1 min-w-0">
                    <div class="text-white font-semibold text-sm truncate">@_title</div>
                    <div class="text-gray-500 text-xs">@_mediaType.ToUpper()</div>
                </div>
            </div>

            <!-- episode watched — Continue Watching only -->
            @if (_showEpisodeWatched)
            {
                <button class="w-full py-2.5 rounded-lg text-sm font-medium mb-4 transition-colors flex items-center justify-center gap-1.5
                               @(_episodeWatched ? "bg-green-600/30 text-green-400 ring-1 ring-green-500/50" : "bg-surface-200 text-gray-300 hover:text-white")"
                        @onclick="ToggleEpisodeWatched" @onclick:stopPropagation="true">
                    <span class="@(_episodeWatched ? "icon-[heroicons--check-circle-20-solid]" : "icon-[heroicons--check-circle]") w-4 h-4"></span>
                    @(_episodeWatched ? "Episode Marked Watched" : "Episode Watched")
                </button>
            }

            <!-- list status -->
            @if (_queueId > 0)
            {
                <div class="text-gray-500 text-[10px] font-medium uppercase tracking-wider mb-2">List Status</div>
                <div class="grid grid-cols-4 gap-2 mb-4">
                    @foreach (QueueStatus status in BadgeHelpers.AllStatuses)
                    {
                        bool active = _currentStatus == status;
                        bool isNfm = status == QueueStatus.NotForMe;
                        string activeCss = isNfm ? "bg-gray-600/80 text-white" : BadgeHelpers.StatusBg(status) + " text-white";
                        string inactiveCss = isNfm ? "bg-surface-200 text-gray-600 hover:text-gray-400" : "bg-surface-200 text-gray-400 hover:text-white";
                        <button class="py-2 rounded-lg text-xs font-medium transition-colors flex items-center justify-center gap-1
                                       @(active ? activeCss : inactiveCss)"
                                @onclick="() => SetStatus(status)" @onclick:stopPropagation="true">
                            <span class="@BadgeHelpers.StatusIcon(status) w-3.5 h-3.5"></span>
                            <span>@BadgeHelpers.StatusShortLabel(status)</span>
                        </button>
                    }
                </div>

                <div class="text-gray-500 text-[10px] font-medium uppercase tracking-wider mb-2">Sentiment</div>
                <div class="flex gap-2 mb-4">
                    @foreach ((int level, string activeCss, string inactiveCss, string icon, string label) in _sentimentOptions)
                    {
                        bool active = _currentSentiment == level;
                        <button class="flex-1 py-2 rounded-lg text-xs font-medium transition-colors flex items-center justify-center gap-1
                                       @(active ? activeCss : inactiveCss)"
                                @onclick="() => SetSentiment(level)" @onclick:stopPropagation="true">
                            <span class="@icon w-3.5 h-3.5"></span>
                            @label
                        </button>
                    }
                </div>
            }
            else
            {
                <!-- browse card: not yet in queue -->
                <div class="flex flex-col gap-2 mb-4">
                    <button class="w-full py-2.5 rounded-lg text-sm font-medium bg-gray-700/80 text-white transition-colors flex items-center justify-center gap-1.5"
                            @onclick="AddToQueue" @onclick:stopPropagation="true">
                        <span class="icon-[heroicons--plus] w-4 h-4"></span>
                        Want to Watch
                    </button>
                    <button class="w-full py-2.5 rounded-lg text-sm font-medium bg-green-600/80 text-white transition-colors flex items-center justify-center gap-1.5"
                            @onclick="MarkThumbsUp" @onclick:stopPropagation="true">
                        <span class="icon-[heroicons--hand-thumb-up] w-4 h-4"></span>
                        Thumbs Up
                    </button>
                    <button class="w-full py-2.5 rounded-lg text-sm font-medium bg-blue-600/80 text-white transition-colors flex items-center justify-center gap-1.5"
                            @onclick="MarkSeen" @onclick:stopPropagation="true">
                        <span class="icon-[heroicons--eye] w-4 h-4"></span>
                        I've Seen This
                    </button>
                </div>
            }

            <button class="w-full py-2 text-gray-500 text-sm" @onclick="Close" @onclick:stopPropagation="true">Cancel</button>
        </div>
    </div>
}

@code {
    private bool _visible;
    private bool _busy;
    private bool _disposed;
    private string _title = "";
    private string _posterUrl = "";
    private string _mediaType = "";
    private int _queueId;
    private QueueStatus _currentStatus;
    private int? _currentSentiment;
    private SearchResult? _searchResult;

    private static readonly (int Level, string ActiveCss, string InactiveCss, string Icon, string Label)[] _sentimentOptions =
    [
        (SentimentLevel.Down, "bg-red-600/30 text-red-400 ring-1 ring-red-500/50", "bg-surface-200 text-gray-400 hover:text-red-400", "icon-[heroicons--hand-thumb-down-20-solid]", "Nah"),
        (SentimentLevel.Up, "bg-green-600/30 text-green-400 ring-1 ring-green-500/50", "bg-surface-200 text-gray-400 hover:text-green-400", "icon-[heroicons--hand-thumb-up-20-solid]", "Good"),
        (SentimentLevel.Favorite, "bg-pink-600/30 text-pink-400 ring-1 ring-pink-500/50", "bg-surface-200 text-gray-400 hover:text-pink-400", "icon-[heroicons--heart-20-solid]", "Love"),
    ];

    private bool _showEpisodeWatched;
    private int _episodeTmdbId;
    private int _episodeSeason;
    private int _episodeNumber;
    private bool _episodeWatched;

    protected override void OnInitialized()
    {
        QuickActionSvc.OnShowForQueueItem += ShowForQueueItem;
        QuickActionSvc.OnShowForSearchResult += ShowForSearchResult;
    }

    private void ShowForQueueItem(QueueItem item, bool showEpisodeWatched)
    {
        _queueId = item.Id;
        _title = item.Title;
        _posterUrl = item.PosterUrl();
        _mediaType = item.MediaType;
        _currentStatus = item.Status;
        _currentSentiment = item.Sentiment;
        _searchResult = null;
        _showEpisodeWatched = showEpisodeWatched;
        _episodeTmdbId = item.TmdbId;
        _episodeSeason = item.LatestEpisodeSeason ?? 0;
        _episodeNumber = item.LatestEpisodeNumber ?? 0;
        _episodeWatched = item.IsLatestEpisodeWatched;
        _busy = false;
        _visible = true;
        StateHasChanged();
    }

    private void ShowForSearchResult(SearchResult result)
    {
        _queueId = 0;
        _title = result.Title;
        _posterUrl = result.PosterUrl();
        _mediaType = result.MediaType;
        _currentStatus = default;
        _currentSentiment = null;
        _searchResult = result;
        _busy = false;
        _visible = true;
        StateHasChanged();
    }

    private async Task ToggleEpisodeWatched()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (_episodeSeason == 0 || _episodeNumber == 0)
            {
                // episode data not yet refreshed — close and trigger reload; next open will have real data
                Close();
                QuickActionSvc.NotifyChanged();
                return;
            }
            if (_episodeWatched)
                await Api.UnmarkEpisodeWatchedAsync(_episodeTmdbId, _episodeSeason, _episodeNumber);
            else
                await Api.MarkEpisodeWatchedAsync(_episodeTmdbId, _episodeSeason, _episodeNumber);
            _episodeWatched = !_episodeWatched;
            Close();
            QuickActionSvc.NotifyChanged();
        }
        catch { Close(); }
        finally { _busy = false; }
    }

    private async Task SetStatus(QueueStatus status)
    {
        if (_busy || status == _currentStatus) return;
        _busy = true;
        try
        {
            await Api.UpdateStatusAsync(_queueId, status);
            _currentStatus = status;
            Close();
            QuickActionSvc.NotifyChanged();
        }
        catch { Close(); }
        finally { _busy = false; }
    }

    private async Task SetSentiment(int sentiment)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            int? newValue = _currentSentiment == sentiment ? null : sentiment;
            await Api.UpdateSentimentAsync(_queueId, newValue);
            _currentSentiment = newValue;
            Close();
            QuickActionSvc.NotifyChanged();
        }
        catch { Close(); }
        finally { _busy = false; }
    }

    private async Task AddToQueue()
    {
        if (_busy || _searchResult == null) return;
        _busy = true;
        try
        {
            QueueItem? added = await Api.AddToQueueAsync(_searchResult.ToQueueItem());
            if (added != null)
            {
                Close();
                QuickActionSvc.NotifyChanged();
            }
        }
        catch { Close(); }
        finally { _busy = false; }
    }

    private async Task MarkThumbsUp()
    {
        if (_busy || _searchResult == null) return;
        _busy = true;
        try
        {
            QueueItem? item = await Api.MarkAsSeenAsync(_searchResult);
            if (item != null)
                await Api.UpdateSentimentAsync(item.Id, SentimentLevel.Up);
            Close();
            QuickActionSvc.NotifyChanged();
        }
        catch { Close(); }
        finally { _busy = false; }
    }

    private async Task MarkSeen()
    {
        if (_busy || _searchResult == null) return;
        _busy = true;
        try
        {
            await Api.MarkAsSeenAsync(_searchResult);
            Close();
            QuickActionSvc.NotifyChanged();
        }
        catch { Close(); }
        finally { _busy = false; }
    }

    private void Close()
    {
        _visible = false;
        if (!_disposed) StateHasChanged();
    }

    public void Dispose()
    {
        _disposed = true;
        QuickActionSvc.OnShowForQueueItem -= ShowForQueueItem;
        QuickActionSvc.OnShowForSearchResult -= ShowForSearchResult;
    }
}
