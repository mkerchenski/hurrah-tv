@implements IDisposable
@inject ApiClient Api
@inject QuickActionService QuickActionSvc

@if (_visible)
{
    <div class="fixed inset-0 bg-black/80 z-[60] flex items-end justify-center isolate" @onclick="Close">
        <div class="bg-surface-50 rounded-t-2xl w-full max-w-sm p-5 pb-24 md:pb-8 animate-slide-up"
             @onclick:stopPropagation="true">

            <!-- header with poster + title -->
            <div class="flex items-center gap-3 mb-4">
                @if (!string.IsNullOrEmpty(_posterUrl))
                {
                    <img src="@_posterUrl" alt="" draggable="false" class="w-10 h-14 object-cover rounded no-callout" />
                }
                <div class="flex-1 min-w-0">
                    <div class="text-white font-semibold text-sm truncate">@_title</div>
                    <div class="text-gray-500 text-xs">@_mediaType.ToUpper()</div>
                </div>
            </div>

            <!-- episode watched — for TV shows you're Watching whose latest aired episode
                 isn't marked watched yet. Self-gated, no recency window (#168). Once marked,
                 the gate hides it on reopen (the modal closes optimistically on tap). -->
            @if (ShouldShowEpisodeWatched())
            {
                <button class="w-full py-2.5 rounded-lg text-sm font-medium mb-4 transition-colors flex items-center justify-center gap-1.5 disabled:opacity-50 bg-surface-200 text-gray-300 hover:text-white"
                        disabled="@(_busy && _pendingAction != "episode")"
                        @onclick="MarkEpisodeWatched" @onclick:stopPropagation="true">
                    @if (_pendingAction == "episode")
                    {
                        <span class="w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"></span>
                    }
                    else
                    {
                        <span class="icon-[heroicons--check-circle] w-4 h-4"></span>
                    }
                    Episode Watched
                </button>
            }
            else if (ShouldShowEpisodePending())
            {
                <!-- latest-episode metadata not refreshed from TMDb yet — explain the gap
                     rather than silently hiding the action (#168). -->
                <button disabled
                        class="w-full py-2.5 rounded-lg text-sm font-medium mb-4 flex items-center justify-center gap-1.5 bg-surface-200/50 text-gray-500 cursor-default"
                        @onclick:stopPropagation="true">
                    <span class="icon-[heroicons--arrow-path] w-4 h-4"></span>
                    Episode info updating…
                </button>
            }

            <!-- list status -->
            <div class="text-gray-500 text-[10px] font-medium uppercase tracking-wider mb-2">List Status</div>
            <div class="grid grid-cols-4 gap-2 mb-4">
                @foreach (QueueStatus status in QueueStatusOrdering.DisplayOrder)
                {
                    bool active = _queueId > 0 && _currentStatus == status;
                    bool isNfm = status == QueueStatus.NotForMe;
                    string activeCss = isNfm ? "bg-gray-600/80 text-white" : BadgeHelpers.StatusBg(status) + " text-white";
                    string inactiveCss = isNfm ? "bg-surface-200 text-gray-600 hover:text-gray-400" : "bg-surface-200 text-gray-400 hover:text-white";
                    string actionKey = $"status:{(int)status}";
                    bool isPending = _pendingAction == actionKey;
                    <button class="py-2 rounded-lg text-xs font-medium transition-colors flex items-center justify-center gap-1 disabled:opacity-50
                                   @(active ? activeCss : inactiveCss)"
                            disabled="@(_busy && !isPending)"
                            @onclick="() => SetStatus(status)" @onclick:stopPropagation="true">
                        @if (isPending)
                        {
                            <span class="w-3.5 h-3.5 border-2 border-current border-t-transparent rounded-full animate-spin"></span>
                        }
                        else
                        {
                            <span class="@BadgeHelpers.StatusIcon(status) w-3.5 h-3.5"></span>
                        }
                        <span>@BadgeHelpers.StatusShortLabel(status)</span>
                    </button>
                }
            </div>

            <div class="text-gray-500 text-[10px] font-medium uppercase tracking-wider mb-2">Sentiment</div>
            <div class="flex gap-2 mb-4">
                @foreach ((int level, string activeCss, string inactiveCss, string icon, string label) in _sentimentOptions)
                {
                    bool active = _queueId > 0 && _currentSentiment == level;
                    string actionKey = $"sentiment:{level}";
                    bool isPending = _pendingAction == actionKey;
                    <button class="flex-1 py-2 rounded-lg text-xs font-medium transition-colors flex items-center justify-center gap-1 disabled:opacity-50
                                   @(active ? activeCss : inactiveCss)"
                            disabled="@(_busy && !isPending)"
                            @onclick="() => SetSentiment(level)" @onclick:stopPropagation="true">
                        @if (isPending)
                        {
                            <span class="w-3.5 h-3.5 border-2 border-current border-t-transparent rounded-full animate-spin"></span>
                        }
                        else
                        {
                            <span class="@icon w-3.5 h-3.5"></span>
                        }
                        @label
                    </button>
                }
            </div>

            <button class="w-full py-2 text-gray-500 text-sm" @onclick="Close" @onclick:stopPropagation="true">Cancel</button>
        </div>
    </div>
}

@code {
    private bool _visible;
    private bool _busy;
    private string? _pendingAction;
    private bool _disposed;
    private string _title = "";
    private string _posterUrl = "";
    private string _mediaType = "";
    private int _queueId;
    private QueueStatus _currentStatus;
    private int? _currentSentiment;
    private SearchResult? _searchResult;
    private QueueItem? _item; // backing item for queue-surface gates; null on the browse surface

    private static readonly (int Level, string ActiveCss, string InactiveCss, string Icon, string Label)[] _sentimentOptions =
    [
        (SentimentLevel.Down, "bg-red-600/30 text-red-400 ring-1 ring-red-500/50", "bg-surface-200 text-gray-400 hover:text-red-400", "icon-[heroicons--hand-thumb-down-20-solid]", "Nah"),
        (SentimentLevel.Up, "bg-green-600/30 text-green-400 ring-1 ring-green-500/50", "bg-surface-200 text-gray-400 hover:text-green-400", "icon-[heroicons--hand-thumb-up-20-solid]", "Good"),
        (SentimentLevel.Favorite, "bg-pink-600/30 text-pink-400 ring-1 ring-pink-500/50", "bg-surface-200 text-gray-400 hover:text-pink-400", "icon-[heroicons--heart-20-solid]", "Love"),
    ];

    private bool _hasEpisodeData; // false when LatestEpisodeSeason/Number not yet populated
    private int _episodeTmdbId;
    private int _episodeSeason;
    private int _episodeNumber;
    private bool _episodeWatched;

    // gate lives on QueueItem (CanMarkLatestEpisodeWatched) so it's unit-tested in Shared.
    private bool ShouldShowEpisodeWatched() =>
        _item is { } item && item.CanMarkLatestEpisodeWatched(DateTime.UtcNow);

    // a Watching TV item whose episode metadata hasn't been refreshed from TMDb yet — show a
    // disabled "updating" hint instead of silently hiding the action (#168). Distinct from the
    // already-watched case, which intentionally shows nothing.
    private bool ShouldShowEpisodePending() =>
        _item is { } item
        && item.MediaType == MediaTypes.Tv
        && item.Status == QueueStatus.Watching
        && !_hasEpisodeData;

    private void RunAction(string actionKey, Func<Task> action)
    {
        if (_busy) return;
        _busy = true;
        _pendingAction = actionKey;
        Close(); // close immediately — the click feels instant, API runs in the background
        _ = ExecuteActionAsync(action);
    }

    private async Task ExecuteActionAsync(Func<Task> action)
    {
        bool failed = false;
        try
        {
            await action();
        }
        catch
        {
            failed = true;
        }
        finally
        {
            _busy = false;
            _pendingAction = null;
            // success path dispatches targeted events from inside the action body (NotifyItemUpdated /
            // NotifyEpisodeWatchedChanged) so Home can splice in place without a refetch.
            // failure path falls back to NotifyChanged so Home reloads from server and reverts any
            // optimistic local state.
            if (failed) QuickActionSvc.NotifyChanged();
        }
    }

    protected override void OnInitialized()
    {
        // idempotent registration — unsubscribe first so a re-mount (hot reload, double render)
        // doesn't stack multiple listeners on the singleton event bus
        QuickActionSvc.OnShowForQueueItem -= ShowForQueueItem;
        QuickActionSvc.OnShowForQueueItem += ShowForQueueItem;
        QuickActionSvc.OnShowForSearchResult -= ShowForSearchResult;
        QuickActionSvc.OnShowForSearchResult += ShowForSearchResult;
    }

    private void ShowForQueueItem(QueueItem item)
    {
        _queueId = item.Id;
        _title = item.Title;
        _posterUrl = item.PosterUrl();
        _mediaType = item.MediaType;
        _currentStatus = item.Status;
        _currentSentiment = item.Sentiment;
        _searchResult = null;
        _item = item;
        _hasEpisodeData = item.LatestEpisodeSeason.HasValue && item.LatestEpisodeNumber.HasValue;
        _episodeTmdbId = item.TmdbId;
        _episodeSeason = item.LatestEpisodeSeason ?? 0; // 0 only when HasValue==false; Season 0 (specials) is HasValue==true
        _episodeNumber = item.LatestEpisodeNumber ?? 0;
        _episodeWatched = item.IsLatestEpisodeWatched;
        _visible = true;
        StateHasChanged();
    }

    private void ShowForSearchResult(SearchResult result)
    {
        _queueId = 0;
        _title = result.Title;
        _posterUrl = result.PosterUrl();
        _mediaType = result.MediaType;
        _currentStatus = default;
        _currentSentiment = null;
        _searchResult = result;
        _item = null;
        _hasEpisodeData = false;
        _episodeTmdbId = 0;
        _episodeSeason = 0;
        _episodeNumber = 0;
        _episodeWatched = false;
        _visible = true;
        StateHasChanged();
    }

    private void MarkEpisodeWatched()
    {
        // gate already excludes watched + unpopulated items, but guard the action path too
        if (!_hasEpisodeData || _episodeWatched) return;

        int tmdbId = _episodeTmdbId;
        int season = _episodeSeason;
        int episode = _episodeNumber;
        _episodeWatched = true;

        RunAction("episode", async () =>
        {
            try
            {
                await Api.MarkEpisodeWatchedAsync(tmdbId, season, episode);
                // targeted update — Home updates its watched-set in place, no refetch needed
                QuickActionSvc.NotifyEpisodeWatchedChanged(tmdbId, season, episode, true);
            }
            catch
            {
                // revert local state so the modal shows the truth on reopen; the broad
                // NotifyChanged from ExecuteActionAsync's failure path also fires
                _episodeWatched = false;
                throw;
            }
        });
    }

    private void SetStatus(QueueStatus status)
    {
        // tapping the already-active status removes the item from the queue (#195) — mirrors the
        // Details page so the toggle-off gesture is consistent everywhere. RunAction closes the
        // sheet immediately; the broad failure-path NotifyChanged reloads if the delete fails.
        if (_queueId > 0 && status == _currentStatus)
        {
            int removeId = _queueId;
            RunAction($"status:{(int)status}", async () =>
            {
                await Api.RemoveFromQueueAsync(removeId);
                QuickActionSvc.NotifyItemRemoved(removeId);
            });
            return;
        }

        // queue surface: optimistic flip + single API call
        if (_queueId > 0)
        {
            int targetId = _queueId;
            _currentStatus = status;
            RunAction($"status:{(int)status}", async () =>
            {
                QueueItem? updated = await Api.UpdateStatusAsync(targetId, status);
                if (updated is not null) QuickActionSvc.NotifyItemUpdated(updated);
            });
            return;
        }

        // browse surface: needs to ensure the queue item exists first, so we can't be fully optimistic
        if (_searchResult is null) return;
        SearchResult result = _searchResult;
        RunAction($"status:{(int)status}", async () =>
        {
            QueueItem? ensured = await Api.EnsureQueueItemAsync(result);
            if (ensured == null) return;
            if (ensured.Status == status)
            {
                QuickActionSvc.NotifyItemUpdated(ensured);
                return;
            }
            QueueItem? updated = await Api.UpdateStatusAsync(ensured.Id, status);
            if (updated is not null) QuickActionSvc.NotifyItemUpdated(updated);
        });
    }

    private void SetSentiment(int sentiment)
    {
        // queue surface: optimistic flip + single API call
        if (_queueId > 0)
        {
            int targetId = _queueId;
            int? newValue = _currentSentiment == sentiment ? null : sentiment; // toggle off when re-tapping
            _currentSentiment = newValue;
            RunAction($"sentiment:{sentiment}", async () =>
            {
                QueueItem? updated = await Api.UpdateSentimentAsync(targetId, newValue);
                if (updated is not null) QuickActionSvc.NotifyItemUpdated(updated);
            });
            return;
        }

        // browse surface: ensure first
        if (_searchResult is null) return;
        SearchResult result = _searchResult;
        RunAction($"sentiment:{sentiment}", async () =>
        {
            QueueItem? ensured = await Api.EnsureQueueItemAsync(result);
            if (ensured == null) return;
            int? newValue = ensured.Sentiment == sentiment ? null : sentiment;
            QueueItem? updated = await Api.UpdateSentimentAsync(ensured.Id, newValue);
            if (updated is not null) QuickActionSvc.NotifyItemUpdated(updated);
        });
    }

    private void Close()
    {
        _visible = false;
        if (!_disposed) StateHasChanged();
    }

    public void Dispose()
    {
        _disposed = true;
        QuickActionSvc.OnShowForQueueItem -= ShowForQueueItem;
        QuickActionSvc.OnShowForSearchResult -= ShowForSearchResult;
    }
}
