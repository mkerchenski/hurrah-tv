@if (Loading)
{
    <div class="grid grid-cols-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-2 md:gap-4">
        @for (int i = 0; i < 12; i++)
        {
            <div class="loading-shimmer rounded-lg aspect-[2/3]"></div>
        }
    </div>
}
else if (Results.Count == 0)
{
    <div class="text-center py-12 text-gray-500">
        <span class="icon-[heroicons--film] w-12 h-12 mx-auto mb-3 text-gray-600"></span>
        <p>@EmptyMessage</p>
    </div>
}
else
{
    <div class="grid grid-cols-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-2 md:gap-4 fade-in">
        @foreach (SearchResult result in Results)
        {
            <PosterCard Result="result" />
        }
    </div>
}

@code {
    [Parameter] public List<SearchResult> Results { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string EmptyMessage { get; set; } = "Nothing found";
}
