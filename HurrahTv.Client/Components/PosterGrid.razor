@if (Loading)
{
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
        @for (int i = 0; i < 12; i++)
        {
            <div class="loading-shimmer rounded-lg aspect-[2/3]"></div>
        }
    </div>
}
else if (Results.Count == 0)
{
    <div class="text-center py-12 text-gray-500">
        <svg class="w-12 h-12 mx-auto mb-3 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/>
        </svg>
        <p>@EmptyMessage</p>
    </div>
}
else
{
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 fade-in">
        @foreach (SearchResult result in Results)
        {
            <PosterCard Result="result" />
        }
    </div>
}

@code {
    [Parameter] public List<SearchResult> Results { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string EmptyMessage { get; set; } = "Nothing found";
}
