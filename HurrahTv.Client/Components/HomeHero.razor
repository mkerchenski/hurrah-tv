@inject NavigationManager Nav
@inject ApiClient Api
@inject QuickActionService QuickActionSvc
@inject ToastService Toast

@if (Item is not null)
{
    <section class="relative -mx-4 md:-mx-6 mb-6 md:mb-10 overflow-hidden rounded-b-xl md:rounded-xl">
        <!-- backdrop image — full bleed on mobile (escapes the page padding via -mx) -->
        <div class="aspect-[3/4] sm:aspect-[16/9] md:aspect-[21/9] relative bg-surface-100">
            @if (!string.IsNullOrEmpty(Item.BackdropUrl))
            {
                <img src="@Item.BackdropUrl" alt="" draggable="false"
                     class="absolute inset-0 w-full h-full object-cover no-callout" />
            }

            <!-- gradient: dark and tall at the bottom for text legibility, fading to transparent -->
            <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/80 to-transparent"></div>
            <!-- subtle side fade so the eyebrow doesn't disappear into a busy left edge -->
            <div class="absolute inset-y-0 left-0 w-2/3 bg-gradient-to-r from-bg/60 to-transparent hidden md:block"></div>

            <!-- content -->
            <div class="absolute inset-x-0 bottom-0 p-4 md:p-8">
                <div class="text-[10px] md:text-xs uppercase tracking-widest text-accent-light font-bold mb-1.5 md:mb-2 text-shadow-hero">
                    @Item.Eyebrow
                </div>
                <h1 class="text-2xl sm:text-3xl md:text-5xl font-bold text-white leading-tight max-w-2xl text-shadow-hero">
                    @Item.Title
                </h1>
                @if (!string.IsNullOrEmpty(Item.Overview))
                {
                    <p class="text-xs md:text-base text-gray-100 mt-2 md:mt-3 max-w-xl line-clamp-3 md:line-clamp-3 italic text-shadow-hero">
                        &ldquo;@Item.Overview&rdquo;
                    </p>
                }

                <div class="flex items-center gap-2 mt-3 md:mt-5">
                    <button @onclick="OnPrimary" disabled="@(_adding || _added)"
                            class="bg-white text-black hover:bg-gray-200 disabled:hover:bg-white font-semibold px-5 md:px-7 py-2 md:py-2.5 rounded-lg text-sm md:text-base flex items-center gap-2 transition-colors">
                        @if (_adding)
                        {
                            <span class="w-4 h-4 md:w-5 md:h-5 border-2 border-black/30 border-t-black rounded-full animate-spin"></span>
                            <span>Adding…</span>
                        }
                        else if (_added)
                        {
                            <span class="icon-[heroicons--check-20-solid] w-4 h-4 md:w-5 md:h-5"></span>
                            <span>Added to list</span>
                        }
                        else
                        {
                            <span class="@PrimaryIcon w-4 h-4 md:w-5 md:h-5"></span>
                            <span>@Item.PrimaryLabel</span>
                        }
                    </button>
                    @* "More info" only when it adds a distinct destination. For a Resume hero the
                       primary already navigates to the details page, so a second button to the
                       same URL is redundant — that was #138. *@
                    @if (Item.PrimaryAction != HeroAction.Resume)
                    {
                        @* self-stretch matches the primary button's height even when "More info"
                           text is hidden below the sm: breakpoint (icon-only is ~1-2px shorter
                           than text-bearing buttons, leaving this one visibly short on mobile). *@
                        <button @onclick="OnSecondary" title="More info" aria-label="More info"
                                class="bg-surface-100/70 backdrop-blur text-white hover:bg-surface-200/70 font-semibold self-stretch px-3 sm:px-4 md:px-6 py-2 md:py-2.5 rounded-lg text-sm md:text-base flex items-center gap-2 transition-colors">
                            @* icon size is driven by font-size (icons.css renders the glyph at 1em),
                               NOT by w-/h- utilities — those are overridden. text-xl/text-lg keeps this
                               in lockstep with the shuffle glyph below; bump both together. *@
                            <span class="icon-[heroicons--information-circle] text-xl sm:text-lg"></span>
                            <span class="hidden sm:inline">More info</span>
                        </button>
                    }
                    @if (OnShuffle.HasDelegate)
                    {
                        <button @onclick="OnShuffleClick" disabled="@_shuffling" title="Show another pick" aria-label="Show another pick"
                                class="bg-surface-100/70 backdrop-blur text-white hover:bg-surface-200/70 disabled:opacity-60 flex items-center justify-center self-stretch px-3 md:px-3.5 py-2 md:py-2.5 rounded-lg transition-colors">
                            @* same font-size as the "More info" glyph above so the two siblings match *@
                            <span class="icon-[heroicons--arrow-path] text-xl sm:text-lg @(_shuffling ? "animate-spin" : "")"></span>
                        </button>
                    }
                </div>
            </div>
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public HeroItem? Item { get; set; }

    // when set, renders a shuffle button that asks the parent for a different pick (the
    // manual force-refresh escape hatch for the rotating AI hero). #135
    [Parameter] public EventCallback OnShuffle { get; set; }

    private bool _shuffling;
    private bool _adding;
    private bool _added;
    private int _lastHeroId;

    protected override void OnParametersSet()
    {
        // reset the per-hero button state whenever the hero changes (e.g. after a shuffle)
        if (Item is not null && Item.TmdbId != _lastHeroId)
        {
            _lastHeroId = Item.TmdbId;
            _added = false;
            _adding = false;
            _shuffling = false;
        }
    }

    private string PrimaryIcon => Item?.PrimaryAction switch
    {
        HeroAction.Resume => "icon-[heroicons--play-20-solid]",
        HeroAction.Add => "icon-[heroicons--plus]",
        _ => "icon-[heroicons--play-20-solid]"
    };

    private async Task OnPrimary()
    {
        if (Item is null) return;
        switch (Item.PrimaryAction)
        {
            case HeroAction.Resume:
                Nav.NavigateTo($"/details/{Item.MediaType}/{Item.TmdbId}");
                break;
            case HeroAction.Add:
                await AddAndNotifyAsync();
                break;
        }
    }

    private void OnSecondary()
    {
        if (Item is null) return;
        Nav.NavigateTo($"/details/{Item.MediaType}/{Item.TmdbId}");
    }

    private async Task OnShuffleClick()
    {
        if (_shuffling || !OnShuffle.HasDelegate) return;
        // spin the icon for the whole round-trip — refresh can take a beat (it may regenerate
        // the AI reservoir), and without feedback it looked like nothing happened.
        _shuffling = true;
        StateHasChanged();
        try
        {
            await OnShuffle.InvokeAsync();
        }
        finally
        {
            _shuffling = false;
            StateHasChanged();
        }
    }

    private async Task AddAndNotifyAsync()
    {
        if (Item is null || _adding || _added) return;

        // snapshot the hero before the await — a background AI load / shuffle can swap Item
        // mid-request, which would otherwise add the right title but show the wrong one in the toast.
        HeroItem hero = Item;
        QueueItem stub = new()
        {
            TmdbId = hero.TmdbId,
            MediaType = hero.MediaType,
            Title = hero.Title,
            PosterPath = hero.PosterPath,
            BackdropPath = hero.BackdropPathRaw
        };

        _adding = true;
        StateHasChanged();
        try
        {
            // AddToQueueAsync doesn't swallow exceptions — a network failure throws, so the
            // finally is what guarantees the button doesn't get stuck spinning.
            QueueItem? added = await Api.AddToQueueAsync(stub);
            if (added is not null)
            {
                _added = true;
                QuickActionSvc.NotifyItemUpdated(added);
                await Toast.ShowAsync($"Added “{hero.Title}” to your list");
            }
            else
            {
                await Toast.ShowAsync("Couldn't add to your list — try again");
            }
        }
        catch
        {
            await Toast.ShowAsync("Couldn't add to your list — try again");
        }
        finally
        {
            _adding = false;
            StateHasChanged();
        }
    }

    public enum HeroAction { Resume, Add }

    public record HeroItem(
        string Eyebrow,
        string Title,
        string BackdropUrl,
        string BackdropPathRaw,
        string PosterPath,
        string? Overview,
        int TmdbId,
        string MediaType,
        string PrimaryLabel,
        HeroAction PrimaryAction
    );
}
