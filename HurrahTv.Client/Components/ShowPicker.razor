@inject ApiClient Api

<div class="space-y-4">
    <!-- search bar -->
    <div class="relative">
        <span class="icon-[heroicons--magnifying-glass] w-5 h-5 text-gray-500 absolute left-3 top-1/2 -translate-y-1/2"></span>
        <input type="text" placeholder="Search for a show or movie..."
               class="w-full bg-surface-50 border border-surface-200 rounded-lg pl-10 pr-4 py-2.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-accent"
               @bind="_searchQuery" @bind:event="oninput" @bind:after="OnSearchInput" />
    </div>

    <!-- selection counter -->
    <div class="flex items-center justify-between">
        <span class="text-sm text-gray-400">
            @if (_selections.Count < MinimumShows)
            {
                <span>Pick at least <strong class="text-white">@MinimumShows</strong> — @_selections.Count selected</span>
            }
            else
            {
                <span class="text-green-400">@_selections.Count selected</span>
            }
        </span>
        @if (_searching)
        {
            <div class="w-4 h-4 border-2 border-accent border-t-transparent rounded-full animate-spin"></div>
        }
    </div>

    <!-- results grid -->
    @if (_displayResults.Count == 0 && !_loading && !_searching)
    {
        <p class="text-gray-600 text-sm py-4 text-center">No results found. Try searching for something else.</p>
    }
    else
    {
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-3">
            @if (_loading)
            {
                @for (int i = 0; i < 12; i++)
                {
                    <div class="aspect-[2/3] bg-surface-100 rounded-lg animate-pulse"></div>
                }
            }
            else
            {
                @foreach (SearchResult result in _displayResults)
                {
                    bool isSelected = _selections.ContainsKey(result.TmdbId);
                    QueueStatus? selectedStatus = isSelected ? _selections[result.TmdbId].Status : null;

                    <div class="relative cursor-pointer group" @onclick="() => ToggleSelection(result)">
                        @if (!string.IsNullOrEmpty(result.PosterUrl()))
                        {
                            <img src="@result.PosterUrl()" alt="@result.Title"
                                 class="w-full aspect-[2/3] object-cover rounded-lg transition-all @(isSelected ? "ring-2 " + StatusRingColor(selectedStatus!.Value) : "hover:ring-1 ring-gray-600")"
                                 loading="lazy" />
                        }
                        else
                        {
                            <div class="w-full aspect-[2/3] bg-surface-100 rounded-lg flex items-center justify-center @(isSelected ? "ring-2 " + StatusRingColor(selectedStatus!.Value) : "")">
                                <span class="text-gray-500 text-xs text-center px-2">@result.Title</span>
                            </div>
                        }

                        @if (isSelected)
                        {
                            <!-- status pill -->
                            <div class="absolute top-1.5 right-1.5 @StatusBgColor(selectedStatus!.Value) text-white text-[10px] px-1.5 py-0.5 rounded backdrop-blur-sm">
                                @SentimentHelpers.StatusLabel(selectedStatus!.Value)
                            </div>
                            <!-- checkmark -->
                            <div class="absolute top-1.5 left-1.5 bg-black/60 rounded-full w-5 h-5 flex items-center justify-center">
                                <span class="icon-[heroicons--check-20-solid] w-3.5 h-3.5 text-green-400"></span>
                            </div>
                        }

                        <!-- title overlay -->
                        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-2 pt-6 rounded-b-lg">
                            <div class="text-white text-xs font-medium leading-tight truncate">@result.Title</div>
                            <div class="text-gray-400 text-[10px]">@result.Year</div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

<!-- status picker modal -->
@if (_pendingResult != null)
{
    <div class="fixed inset-0 bg-black/70 z-50 flex items-end sm:items-center justify-center p-4" @onclick="CancelPick">
        <div class="bg-surface-50 rounded-xl p-5 w-full max-w-sm space-y-3" @onclick:stopPropagation>
            <div class="flex items-center gap-3 mb-1">
                @if (!string.IsNullOrEmpty(_pendingResult.PosterUrl()))
                {
                    <img src="@_pendingResult.PosterUrl("w92")" class="w-12 h-18 object-cover rounded" />
                }
                <div>
                    <div class="text-white font-semibold text-sm">@_pendingResult.Title</div>
                    <div class="text-gray-500 text-xs">@_pendingResult.Year</div>
                </div>
            </div>
            @if (_pendingStatus == null)
            {
                <!-- step 1: pick list status -->
                <button class="w-full py-2.5 rounded-lg text-sm font-medium transition-colors bg-green-600/20 border border-green-600/40 text-green-400 hover:bg-green-600/30"
                        @onclick="() => PickStatus(QueueStatus.Watching)">
                    Watching
                </button>
                <button class="w-full py-2.5 rounded-lg text-sm font-medium transition-colors bg-blue-600/20 border border-blue-600/40 text-blue-400 hover:bg-blue-600/30"
                        @onclick="() => PickStatus(QueueStatus.Finished)">
                    Watched
                </button>
                <button class="w-full py-2.5 rounded-lg text-sm font-medium transition-colors bg-accent/20 border border-accent/40 text-accent-light hover:bg-accent/30"
                        @onclick="() => PickStatus(QueueStatus.WantToWatch)">
                    Want to Watch
                </button>
            }
            else
            {
                <!-- step 2: optional sentiment -->
                <div class="text-xs text-gray-500 text-center mb-1">How do you feel about it?</div>
                <div class="flex gap-2 justify-center">
                    <button class="w-12 h-12 rounded-lg flex items-center justify-center border border-red-500/40 text-gray-500 hover:bg-red-600/20 hover:text-red-400 transition-colors"
                            @onclick="() => ConfirmPick(SentimentLevel.Down)" title="Thumbs down">
                        <span class="icon-[heroicons--hand-thumb-down] w-6 h-6"></span>
                    </button>
                    <button class="w-12 h-12 rounded-lg flex items-center justify-center border border-green-500/40 text-gray-500 hover:bg-green-600/20 hover:text-green-400 transition-colors"
                            @onclick="() => ConfirmPick(SentimentLevel.Up)" title="Thumbs up">
                        <span class="icon-[heroicons--hand-thumb-up] w-6 h-6"></span>
                    </button>
                    <button class="w-12 h-12 rounded-lg flex items-center justify-center border border-pink-500/40 text-gray-500 hover:bg-pink-600/20 hover:text-pink-400 transition-colors"
                            @onclick="() => ConfirmPick(SentimentLevel.Favorite)" title="Favorite">
                        <span class="icon-[heroicons--heart] w-6 h-6"></span>
                    </button>
                </div>
                <button class="w-full py-1.5 text-gray-500 text-xs hover:text-gray-300 transition-colors"
                        @onclick="() => ConfirmPick(null)">
                    Skip
                </button>
            }
            <button class="w-full py-2 text-gray-500 text-xs hover:text-gray-300 transition-colors"
                    @onclick="CancelPick">
                Cancel
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public int MinimumShows { get; set; } = 3;
    [Parameter] public EventCallback<Dictionary<int, (SearchResult Result, QueueStatus Status, int? Sentiment)>> SelectionsChanged { get; set; }

    private string _searchQuery = "";
    private QueueStatus? _pendingStatus;
    private bool _loading = true;
    private bool _searching;
    private System.Timers.Timer? _debounceTimer;
    private List<SearchResult> _popularResults = [];
    private List<SearchResult> _searchResults = [];
    private List<SearchResult> _displayResults => _searchResults.Count > 0 || !string.IsNullOrWhiteSpace(_searchQuery)
        ? _searchResults : _popularResults;
    private Dictionary<int, (SearchResult Result, QueueStatus Status, int? Sentiment)> _selections = [];
    private SearchResult? _pendingResult;

    protected override async Task OnInitializedAsync()
    {
        // load popular shows from user's selected services + genres
        Task<List<SearchResult>> tvTask = Api.ForYouAsync("tv");
        Task<List<SearchResult>> movieTask = Api.ForYouAsync("movie");
        await Task.WhenAll(tvTask, movieTask);
        List<SearchResult> tv = tvTask.Result;
        List<SearchResult> movies = movieTask.Result;

        // interleave TV and movies, TV-heavy
        _popularResults = [];
        int ti = 0, mi = 0;
        while (ti < tv.Count || mi < movies.Count)
        {
            if (ti < tv.Count) _popularResults.Add(tv[ti++]);
            if (ti < tv.Count) _popularResults.Add(tv[ti++]);
            if (mi < movies.Count) _popularResults.Add(movies[mi++]);
        }

        _loading = false;
    }

    private void OnSearchInput()
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _searchResults = [];
            _searching = false;
            StateHasChanged();
            return;
        }

        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) =>
        {
            _debounceTimer?.Stop();
            await InvokeAsync(async () =>
            {
                _searching = true;
                StateHasChanged();

                SearchResponse response = await Api.SearchAsync(_searchQuery);
                _searchResults = response.Results;
                _searching = false;
                StateHasChanged();
            });
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private void ToggleSelection(SearchResult result)
    {
        if (_selections.ContainsKey(result.TmdbId))
        {
            // deselect
            _selections.Remove(result.TmdbId);
            SelectionsChanged.InvokeAsync(_selections);
        }
        else
        {
            // show status picker
            _pendingResult = result;
        }
    }

    private void PickStatus(QueueStatus status)
    {
        _pendingStatus = status;
    }

    private async Task ConfirmPick(int? sentiment)
    {
        if (_pendingResult == null || _pendingStatus == null) return;
        _selections[_pendingResult.TmdbId] = (_pendingResult, _pendingStatus.Value, sentiment);
        _pendingResult = null;
        _pendingStatus = null;
        await SelectionsChanged.InvokeAsync(_selections);
    }

    private void CancelPick()
    {
        _pendingResult = null;
        _pendingStatus = null;
    }

    private static string StatusRingColor(QueueStatus status) => status switch
    {
        QueueStatus.Watching => "ring-green-500",
        QueueStatus.Finished => "ring-blue-500",
        QueueStatus.WantToWatch => "ring-accent",
        _ => "ring-gray-500"
    };

    private static string StatusBgColor(QueueStatus status) => status switch
    {
        QueueStatus.Watching => "bg-green-600/80",
        QueueStatus.Finished => "bg-blue-600/80",
        QueueStatus.WantToWatch => "bg-accent/80",
        _ => "bg-gray-600/80"
    };
}
