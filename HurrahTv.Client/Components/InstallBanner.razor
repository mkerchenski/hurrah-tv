@inject IJSRuntime JS

@if (_show)
{
    <div class="bg-surface-100 border border-surface-200 rounded-xl px-4 py-3 mb-4 flex items-start gap-3">
        <span class="icon-[heroicons--arrow-up-on-square] w-5 h-5 text-accent mt-0.5 shrink-0"></span>
        <div class="flex-1 text-sm text-gray-300">
            <span class="text-white font-medium">Add Hurrah.tv to your Home Screen</span><br />
            Tap <span class="icon-[heroicons--arrow-up-on-square] w-4 h-4 inline-block align-text-bottom text-blue-400"></span>
            then <span class="font-medium text-white">"Add to Home Screen"</span>
        </div>
        <button @onclick="Dismiss" class="text-gray-500 hover:text-white p-1 shrink-0" title="Dismiss">
            <span class="icon-[heroicons--x-mark] w-5 h-5"></span>
        </button>
    </div>
}

@code {
    private bool _show;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            bool shouldShow = await JS.InvokeAsync<bool>("hurrahShouldShowInstallBanner");
            if (shouldShow)
            {
                _show = true;
                StateHasChanged();
            }
        }
        catch (JSException) { }
    }

    private async Task Dismiss()
    {
        _show = false;
        try { await JS.InvokeVoidAsync("hurrahDismissInstallBanner"); }
        catch (JSException) { }
    }
}
