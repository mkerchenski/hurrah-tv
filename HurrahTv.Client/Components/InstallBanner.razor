@inject InstallBannerService InstallSvc

@if (_variant == Variant.Ios)
{
    <div class="bg-surface-100 border border-surface-200 rounded-xl px-4 py-3 mb-4 flex items-start gap-3">
        <span class="icon-[heroicons--arrow-up-on-square] w-5 h-5 text-accent mt-0.5 shrink-0"></span>
        <div class="flex-1 text-sm text-gray-300">
            <span class="text-white font-medium">Add Hurrah.tv to your Home Screen</span><br />
            Tap <span class="icon-[heroicons--arrow-up-on-square] w-4 h-4 inline-block align-text-bottom text-blue-400"></span>
            then <span class="font-medium text-white">"Add to Home Screen"</span>
        </div>
        <button @onclick="Dismiss" class="text-gray-500 hover:text-white p-1 shrink-0" title="Dismiss">
            <span class="icon-[heroicons--x-mark] w-5 h-5"></span>
        </button>
    </div>
}
else if (_variant == Variant.Install)
{
    <div class="bg-surface-100 border border-surface-200 rounded-xl px-4 py-3 mb-4 flex items-center gap-3">
        <span class="icon-[heroicons--arrow-down-tray] w-5 h-5 text-accent shrink-0"></span>
        <div class="flex-1 text-sm text-gray-300">
            <span class="text-white font-medium">Install Hurrah.tv</span><br />
            Add it to your device for a full-screen, app-like experience.
        </div>
        <button @onclick="Install" disabled="@_installing"
                class="bg-accent hover:bg-accent-light text-white font-semibold px-4 py-2 rounded-lg transition-colors disabled:opacity-40 shrink-0">
            Install
        </button>
        <button @onclick="Dismiss" class="text-gray-500 hover:text-white p-1 shrink-0" title="Dismiss">
            <span class="icon-[heroicons--x-mark] w-5 h-5"></span>
        </button>
    </div>
}

@code {
    private enum Variant { None, Ios, Install }

    private Variant _variant = Variant.None;
    private bool _installing;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            // iOS Safari has no programmatic install — show the manual instructions.
            // Everything else (Android / desktop Chrome) gets a real Install button
            // when the browser has offered a beforeinstallprompt.
            if (await InstallSvc.ShouldShowAsync())
            {
                _variant = Variant.Ios;
                StateHasChanged();
            }
            else if (await InstallSvc.CanPromptInstallAsync())
            {
                _variant = Variant.Install;
                StateHasChanged();
            }
        }
        catch (JSException) { }
    }

    private async Task Install()
    {
        if (_installing) return;
        _installing = true;
        try { await InstallSvc.PromptInstallAsync(); }
        catch (JSException) { }

        // the native prompt is single-use — hide the banner regardless of outcome.
        // if the user declined, the banner returns only on the next page load (detection
        // runs once, on firstRender) — see #15 follow-up for live re-evaluation.
        _variant = Variant.None;
        _installing = false;
        StateHasChanged();
    }

    private async Task Dismiss()
    {
        _variant = Variant.None;
        try { await InstallSvc.DismissAsync(); }
        catch (JSException) { }
    }
}
