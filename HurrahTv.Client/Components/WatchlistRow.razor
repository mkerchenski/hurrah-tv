@implements IAsyncDisposable
@inject NavigationManager Nav
@inject IJSRuntime JS

<section class="mb-6 md:mb-8">
    <div class="flex items-center justify-between mb-3">
        <div class="flex items-baseline gap-2">
            <h3 class="text-sm md:text-base font-semibold text-white">@Title</h3>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <span class="text-xs text-gray-500">@Subtitle</span>
            }
        </div>
    </div>

    @if (Items.Count == 0)
    {
        <p class="text-gray-600 text-sm py-4">@EmptyMessage</p>
    }
    else
    {
        <div class="relative group/row">
            <!-- left arrow -->
            <button class="absolute left-0 top-1/2 -translate-y-1/2 z-10 bg-black/70 hover:bg-black/90 text-white
                           rounded-full w-9 h-9 items-center justify-center transition-all
                           hidden md:flex opacity-0 group-hover/row:opacity-100 -ml-1"
                    @onclick="() => Scroll(-1)">
                <span class="icon-[heroicons--chevron-left] w-5 h-5"></span>
            </button>

            <div @ref="_scrollContainer"
                 class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide snap-x snap-mandatory scroll-smooth">
                @foreach (QueueItem item in Items)
                {
                    <div @key="item.Id" @ref="_cardRefs[item.Id]"
                         class="flex-shrink-0 w-32 sm:w-32 md:w-36 snap-start cursor-pointer relative group"
                         @onclick="() => GoToDetails(item)">
                        @if (!string.IsNullOrEmpty(item.PosterUrl()))
                        {
                            <img src="@item.PosterUrl()" alt="@item.Title" draggable="false"
                                 class="w-full aspect-[2/3] object-cover rounded-lg no-callout" loading="lazy" />
                        }
                        else
                        {
                            <div class="w-full aspect-[2/3] bg-surface-100 rounded-lg flex items-center justify-center">
                                <span class="text-gray-500 text-xs text-center px-2">@item.Title</span>
                            </div>
                        }

                        @{ string badge = ShowAirDates ? FormatAirBadge(item) : ""; }
                        @if (!string.IsNullOrEmpty(badge))
                        {
                            <div class="absolute top-1.5 left-1.5 bg-black/60 text-gray-200 text-[10px] px-1.5 py-0.5 rounded backdrop-blur-sm">
                                @badge
                            </div>
                        }

                        @if (ShowStatusBadge && item.Status != QueueStatus.Watching)
                        {
                            string icon = BadgeHelpers.StatusIcon(item.Status);
                            string label = BadgeHelpers.StatusShortLabel(item.Status);
                            <div class="absolute top-1.5 right-1.5 bg-black/60 text-white backdrop-blur-sm flex items-center justify-center rounded-full w-5 h-5"
                                 title="@label">
                                <span class="@icon w-3 h-3"></span>
                            </div>
                        }

                        <!-- title overlay at bottom -->
                        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-2 pt-6 rounded-b-lg">
                            <div class="flex items-center gap-1">
                                <span class="text-white text-xs font-medium leading-tight truncate flex-1">@item.Title</span>
                                @if (item.Sentiment.HasValue)
                                {
                                    <span class="@SentimentHelpers.Icon(item.Sentiment.Value) @SentimentHelpers.Color(item.Sentiment.Value) w-3 h-3 shrink-0"></span>
                                }
                            </div>
                            @if (item.MediaType == "tv" && item.LastSeasonWatched.HasValue && item.LastEpisodeWatched.HasValue)
                            {
                                <div class="text-gray-400 text-[10px]">S@(item.LastSeasonWatched)E@(item.LastEpisodeWatched)</div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- right arrow -->
            <button class="absolute right-0 top-1/2 -translate-y-1/2 z-10 bg-black/70 hover:bg-black/90 text-white
                           rounded-full w-9 h-9 items-center justify-center transition-all
                           hidden md:flex opacity-0 group-hover/row:opacity-100 -mr-1"
                    @onclick="() => Scroll(1)">
                <span class="icon-[heroicons--chevron-right] w-5 h-5"></span>
            </button>
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string EmptyMessage { get; set; } = "Nothing here yet";
    [Parameter, EditorRequired] public List<QueueItem> Items { get; set; } = [];
    [Parameter] public bool ShowAirDates { get; set; }
    [Parameter] public string RowMode { get; set; } = "watching"; // "watching" or "upcoming"
    [Parameter] public bool ShowStatusBadge { get; set; } = true;

    [Inject] QuickActionService QuickActionSvc { get; set; } = null!;

    private ElementReference _scrollContainer;
    private Dictionary<int, ElementReference> _cardRefs = new();
    private DotNetObjectReference<WatchlistRow>? _dotNetRef;
    private Dictionary<int, IJSObjectReference> _longPressHandles = new();

    protected override void OnParametersSet()
    {
        _cardRefs = new();
        foreach (QueueItem item in Items)
            _cardRefs[item.Id] = default;
    }

    private void GoToDetails(QueueItem item) => Nav.NavigateTo($"/details/{item.MediaType}/{item.TmdbId}");

    private async Task Scroll(int direction)
    {
        await JS.InvokeVoidAsync("hurrahScrollRow", _scrollContainer, direction * 480);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _dotNetRef ??= DotNetObjectReference.Create(this);

        // clean up handles for items no longer in the list
        List<int> staleIds = [.. _longPressHandles.Keys.Where(id => !_cardRefs.ContainsKey(id))];
        foreach (int id in staleIds)
        {
            try { await JS.InvokeVoidAsync("hurrahLongPressCleanup", _longPressHandles[id]); }
            catch { }
            _longPressHandles.Remove(id);
        }

        // register new items
        foreach (KeyValuePair<int, ElementReference> kvp in _cardRefs)
        {
            if (_longPressHandles.ContainsKey(kvp.Key)) continue;
            try
            {
                IJSObjectReference handle = await JS.InvokeAsync<IJSObjectReference>(
                    "hurrahLongPress", kvp.Value, _dotNetRef, nameof(OnLongPress), kvp.Key);
                _longPressHandles[kvp.Key] = handle;
            }
            catch (JSException) { }
        }
    }

    [JSInvokable]
    public void OnLongPress(int itemId)
    {
        QueueItem? item = Items.FirstOrDefault(i => i.Id == itemId);
        if (item != null)
            QuickActionSvc.ShowForQueueItem(item);
    }

    public async ValueTask DisposeAsync()
    {
        foreach (IJSObjectReference handle in _longPressHandles.Values)
        {
            try { await JS.InvokeVoidAsync("hurrahLongPressCleanup", handle); }
            catch { }
        }
        _longPressHandles.Clear();
        _dotNetRef?.Dispose();
    }

    private string FormatAirBadge(QueueItem item)
    {
        // episode dates come from Postgres TIMESTAMPTZ (Kind=Utc); compare in UTC calendar days
        // for Kind-consistency. See Learnings/wasm-datetime-source-matters.md
        DateTime todayUtc = DateTime.UtcNow.Date;

        if (RowMode == "upcoming")
        {
            if (!item.NextEpisodeDate.HasValue) return "";
            int daysUntil = (int)(item.NextEpisodeDate.Value.Date - todayUtc).TotalDays;
            // Home.razor's Upcoming filter guarantees daysUntil >= 1 — defensive clamp only.
            if (daysUntil < 1) return "";
            return daysUntil == 1 ? "1d" : $"{daysUntil}d";
        }

        // watching mode: show how long ago the latest episode aired
        if (!item.LatestEpisodeDate.HasValue) return "";
        int daysAgo = (int)(todayUtc - item.LatestEpisodeDate.Value.Date).TotalDays;
        if (daysAgo < 0 || daysAgo > 30) return "";
        return daysAgo switch
        {
            0 => "today",
            1 => "1d ago",
            _ => $"{daysAgo}d ago"
        };
    }
}
