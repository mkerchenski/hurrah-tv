@inject NavigationManager Nav
@inject IJSRuntime JS

<section class="mb-6 md:mb-8">
    <div class="flex items-baseline justify-between mb-3">
        <h3 class="text-sm md:text-base font-semibold text-white">@Title</h3>
        <a href="/queue" class="text-accent text-xs hover:text-accent-light whitespace-nowrap ml-4">See all &rarr;</a>
    </div>

    @if (Items.Count == 0)
    {
        <p class="text-gray-600 text-sm py-4">@EmptyMessage</p>
    }
    else
    {
        <div class="relative group/row">
            <!-- left arrow -->
            <button class="absolute left-0 top-1/2 -translate-y-1/2 z-10 bg-black/70 hover:bg-black/90 text-white
                           rounded-full w-9 h-9 items-center justify-center transition-all
                           hidden md:flex opacity-0 group-hover/row:opacity-100 -ml-1"
                    @onclick="() => Scroll(-1)">
                <span class="icon-[heroicons--chevron-left] w-5 h-5"></span>
            </button>

            <div @ref="_scrollContainer"
                 class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide snap-x snap-mandatory scroll-smooth">
                @foreach (QueueItem item in Items)
                {
                    <div class="flex-shrink-0 w-24 sm:w-28 md:w-36 snap-start cursor-pointer relative group"
                         @onclick="() => GoToDetails(item)">
                        @if (!string.IsNullOrEmpty(item.PosterUrl()))
                        {
                            <img src="@item.PosterUrl()" alt="@item.Title"
                                 class="w-full aspect-[2/3] object-cover rounded-lg" loading="lazy" />
                        }
                        else
                        {
                            <div class="w-full aspect-[2/3] bg-surface-100 rounded-lg flex items-center justify-center">
                                <span class="text-gray-500 text-xs text-center px-2">@item.Title</span>
                            </div>
                        }


                        <!-- title overlay at bottom -->
                        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-2 pt-6 rounded-b-lg">
                            <div class="text-white text-xs font-medium leading-tight truncate">@item.Title</div>
                            @if (item.MediaType == "tv" && item.LastSeasonWatched.HasValue && item.LastEpisodeWatched.HasValue)
                            {
                                <div class="text-gray-400 text-[10px]">S@(item.LastSeasonWatched)E@(item.LastEpisodeWatched)</div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- right arrow -->
            <button class="absolute right-0 top-1/2 -translate-y-1/2 z-10 bg-black/70 hover:bg-black/90 text-white
                           rounded-full w-9 h-9 items-center justify-center transition-all
                           hidden md:flex opacity-0 group-hover/row:opacity-100 -mr-1"
                    @onclick="() => Scroll(1)">
                <span class="icon-[heroicons--chevron-right] w-5 h-5"></span>
            </button>
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string EmptyMessage { get; set; } = "Nothing here yet";
    [Parameter, EditorRequired] public List<QueueItem> Items { get; set; } = [];

    private ElementReference _scrollContainer;

    private void GoToDetails(QueueItem item) => Nav.NavigateTo($"/details/{item.MediaType}/{item.TmdbId}");

    private async Task Scroll(int direction)
    {
        await JS.InvokeVoidAsync("hurrahScrollRow", _scrollContainer, direction * 480);
    }
}
