@inject ApiClient Api

<div class="mt-6 md:mt-8">
    <h3 class="text-lg font-semibold mb-3">Seasons & Episodes</h3>
    <div class="space-y-2">
        @foreach (SeasonInfo season in Seasons.Where(s => s.SeasonNumber > 0 && s.EpisodeCount > 0).OrderByDescending(s => s.SeasonNumber))
        {
            int sn = season.SeasonNumber;
            bool expanded = _expandedSeason == sn;
            SeasonSentiment? seasonSent = _seasonSentiments.GetValueOrDefault(sn);
            Dictionary<int, EpisodeSentiment> epSents = _episodeSentiments.GetValueOrDefault(sn) ?? [];

            <div class="bg-surface-50 rounded-lg overflow-hidden">
                <!-- season header -->
                <button class="w-full flex items-center justify-between px-4 py-3 hover:bg-surface-100 transition-colors"
                        @onclick="() => ToggleSeason(sn)">
                    <div class="flex items-center gap-3">
                        <span class="@(expanded ? "icon-[heroicons--chevron-down]" : "icon-[heroicons--chevron-right]") w-4 h-4 text-gray-500"></span>
                        <div class="text-left">
                            <span class="text-sm font-medium text-white">@season.Name</span>
                            <span class="text-xs text-gray-500 ml-2">@season.EpisodeCount episodes</span>
                            @if (!string.IsNullOrEmpty(season.AirDate) && season.AirDate.Length >= 4)
                            {
                                <span class="text-xs text-gray-600 ml-1">(@season.AirDate[..4])</span>
                            }
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <!-- episode sentiment summary -->
                        @if (epSents.Count > 0)
                        {
                            <div class="flex items-center gap-1.5 text-[10px]">
                                @{ int ups = epSents.Values.Count(e => e.Sentiment == SentimentLevel.Up); }
                                @{ int favs = epSents.Values.Count(e => e.Sentiment == SentimentLevel.Favorite); }
                                @{ int downs = epSents.Values.Count(e => e.Sentiment == SentimentLevel.Down); }
                                @if (favs > 0) { <span class="text-pink-400">@favs<span class="icon-[heroicons--heart-20-solid] w-3 h-3 inline ml-0.5"></span></span> }
                                @if (ups > 0) { <span class="text-green-400">@ups<span class="icon-[heroicons--hand-thumb-up-20-solid] w-3 h-3 inline ml-0.5"></span></span> }
                                @if (downs > 0) { <span class="text-red-400">@downs<span class="icon-[heroicons--hand-thumb-down-20-solid] w-3 h-3 inline ml-0.5"></span></span> }
                            </div>
                        }
                        <!-- season sentiment buttons -->
                        <div class="flex gap-1" @onclick:stopPropagation="true">
                            <button class="@($"w-7 h-7 rounded flex items-center justify-center transition-colors {(seasonSent?.Sentiment == SentimentLevel.Down ? "bg-red-600/20 text-red-400" : "text-gray-600 hover:text-red-400")}")"
                                    @onclick="() => SetSeasonSentiment(sn, SentimentLevel.Down)">
                                <span class="icon-[heroicons--hand-thumb-down] w-3.5 h-3.5"></span>
                            </button>
                            <button class="@($"w-7 h-7 rounded flex items-center justify-center transition-colors {(seasonSent?.Sentiment == SentimentLevel.Up ? "bg-green-600/20 text-green-400" : "text-gray-600 hover:text-green-400")}")"
                                    @onclick="() => SetSeasonSentiment(sn, SentimentLevel.Up)">
                                <span class="icon-[heroicons--hand-thumb-up] w-3.5 h-3.5"></span>
                            </button>
                            <button class="@($"w-7 h-7 rounded flex items-center justify-center transition-colors {(seasonSent?.Sentiment == SentimentLevel.Favorite ? "bg-pink-600/20 text-pink-400" : "text-gray-600 hover:text-pink-400")}")"
                                    @onclick="() => SetSeasonSentiment(sn, SentimentLevel.Favorite)">
                                <span class="icon-[heroicons--heart] w-3.5 h-3.5"></span>
                            </button>
                        </div>
                    </div>
                </button>

                <!-- expanded episode list -->
                @if (expanded)
                {
                    @if (_loadingEpisodes)
                    {
                        <div class="px-4 py-3 border-t border-surface-200">
                            <div class="w-5 h-5 border-2 border-accent border-t-transparent rounded-full animate-spin"></div>
                        </div>
                    }
                    else if (_seasonDetail != null)
                    {
                        <div class="border-t border-surface-200">
                            @{
                                DateTime today = DateTime.Now.Date;
                                List<EpisodeInfo> aired = [.. _seasonDetail.Episodes.Where(e => HasAired(e.AirDate, today))];
                                EpisodeInfo? nextUp = _seasonDetail.Episodes
                                    .Where(e => IsFuture(e.AirDate, today))
                                    .OrderBy(e => e.EpisodeNumber)
                                    .FirstOrDefault();
                                List<EpisodeInfo> visible = [.. aired];
                                if (nextUp != null) visible.Add(nextUp);
                            }
                            @foreach (EpisodeInfo ep in visible.OrderByDescending(e => e.EpisodeNumber))
                            {
                                int en = ep.EpisodeNumber;
                                bool upcoming = ep == nextUp;
                                EpisodeSentiment? epSent = epSents.GetValueOrDefault(en);

                                <div class="flex items-center justify-between px-4 py-2.5 hover:bg-surface-100 transition-colors border-b border-surface-200 last:border-b-0 @(upcoming ? "opacity-70" : "")">
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-2">
                                            <span class="text-xs text-gray-500 flex-shrink-0">E@(en)</span>
                                            <span class="text-xs text-gray-600">·</span>
                                            <span class="text-sm @(upcoming ? "text-gray-400" : "text-white") truncate">@ep.Name</span>
                                            @if (upcoming)
                                            {
                                                <span class="text-[10px] text-blue-400 bg-blue-600/20 px-1.5 py-0.5 rounded flex-shrink-0">Upcoming</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(ep.AirDate))
                                        {
                                            <div class="text-[10px] text-gray-600 ml-8">@FormatDate(ep.AirDate)</div>
                                        }
                                    </div>
                                    @if (!upcoming)
                                    {
                                    <div class="flex gap-1 flex-shrink-0 ml-2">
                                        @{ bool epWatched = IsWatched(sn, en); }
                                        <button class="@($"w-7 h-7 rounded-full flex items-center justify-center transition-all duration-150 {(epWatched ? "text-green-400 bg-green-600/20" : "text-gray-600 hover:text-green-400 hover:bg-green-600/10")}")"
                                                title="@(epWatched ? "Unmark watched" : "Mark watched")"
                                                @onclick="() => ToggleWatched(sn, en)">
                                            <span class="@(epWatched ? "icon-[heroicons--check-circle-20-solid]" : "icon-[heroicons--check-circle]") w-4 h-4"></span>
                                        </button>
                                        <button class="@($"w-7 h-7 rounded flex items-center justify-center transition-colors {(epSent?.Sentiment == SentimentLevel.Down ? "bg-red-600/20 text-red-400" : "text-gray-600 hover:text-red-400")}")"
                                                @onclick="() => SetEpisodeSentiment(sn, en, SentimentLevel.Down)">
                                            <span class="icon-[heroicons--hand-thumb-down] w-3.5 h-3.5"></span>
                                        </button>
                                        <button class="@($"w-7 h-7 rounded flex items-center justify-center transition-colors {(epSent?.Sentiment == SentimentLevel.Up ? "bg-green-600/20 text-green-400" : "text-gray-600 hover:text-green-400")}")"
                                                @onclick="() => SetEpisodeSentiment(sn, en, SentimentLevel.Up)">
                                            <span class="icon-[heroicons--hand-thumb-up] w-3.5 h-3.5"></span>
                                        </button>
                                        <button class="@($"w-7 h-7 rounded flex items-center justify-center transition-colors {(epSent?.Sentiment == SentimentLevel.Favorite ? "bg-pink-600/20 text-pink-400" : "text-gray-600 hover:text-pink-400")}")"
                                                @onclick="() => SetEpisodeSentiment(sn, en, SentimentLevel.Favorite)">
                                            <span class="icon-[heroicons--heart] w-3.5 h-3.5"></span>
                                        </button>
                                    </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public int TmdbId { get; set; }
    [Parameter, EditorRequired] public List<SeasonInfo> Seasons { get; set; } = [];

    private Dictionary<int, SeasonSentiment> _seasonSentiments = [];
    private Dictionary<int, Dictionary<int, EpisodeSentiment>> _episodeSentiments = [];
    private HashSet<(int Season, int Episode)> _watchedSet = [];
    private int? _expandedSeason;
    private SeasonDetail? _seasonDetail;
    private bool _loadingEpisodes;

    protected override async Task OnInitializedAsync()
    {
        Task<ShowSentiments> sentimentsTask = Api.GetShowSentimentsAsync(TmdbId);
        Task<List<WatchedEpisode>> watchedTask = Api.GetWatchedEpisodesAsync(TmdbId);
        await Task.WhenAll(sentimentsTask, watchedTask);
        ShowSentiments s = sentimentsTask.Result;
        _seasonSentiments = s.Seasons.ToDictionary(x => x.SeasonNumber);
        _episodeSentiments = s.Episodes
            .GroupBy(e => e.SeasonNumber)
            .ToDictionary(g => g.Key, g => g.ToDictionary(e => e.EpisodeNumber));
        _watchedSet = [.. watchedTask.Result.Select(w => (w.Season, w.Episode))];
    }

    private bool IsWatched(int season, int episode) => _watchedSet.Contains((season, episode));

    private async Task ToggleWatched(int season, int episode)
    {
        if (IsWatched(season, episode))
        {
            _watchedSet.Remove((season, episode));
            await Api.UnmarkEpisodeWatchedAsync(TmdbId, season, episode);
        }
        else
        {
            _watchedSet.Add((season, episode));
            await Api.MarkEpisodeWatchedAsync(TmdbId, season, episode);
        }
    }

    private async Task ToggleSeason(int seasonNumber)
    {
        if (_expandedSeason == seasonNumber)
        {
            _expandedSeason = null;
            _seasonDetail = null;
            return;
        }

        _expandedSeason = seasonNumber;
        _loadingEpisodes = true;
        StateHasChanged();

        _seasonDetail = await Api.GetSeasonAsync(TmdbId, seasonNumber);
        _loadingEpisodes = false;
    }

    private async Task SetSeasonSentiment(int seasonNumber, int sentiment)
    {
        int? newSentiment = _seasonSentiments.GetValueOrDefault(seasonNumber)?.Sentiment == sentiment ? null : sentiment;
        await Api.SetSeasonSentimentAsync(TmdbId, seasonNumber, newSentiment);
        if (newSentiment.HasValue)
            _seasonSentiments[seasonNumber] = new SeasonSentiment { TmdbId = TmdbId, SeasonNumber = seasonNumber, Sentiment = newSentiment.Value };
        else
            _seasonSentiments.Remove(seasonNumber);
    }

    private static bool HasAired(string? dateStr, DateTime today)
    {
        // null or unparseable = unknown = not aired (don't show sentiment buttons)
        if (string.IsNullOrEmpty(dateStr) || !DateTime.TryParse(dateStr, out DateTime date)) return false;
        return date.Date <= today;
    }

    private static bool IsFuture(string? dateStr, DateTime today)
    {
        if (string.IsNullOrEmpty(dateStr) || !DateTime.TryParse(dateStr, out DateTime date)) return false;
        return date.Date > today;
    }

    private static string FormatDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr) || dateStr == "0000-00-00") return "";
        if (!DateTime.TryParse(dateStr, out DateTime date)) return "";
        return date.ToString("MMM d, yyyy");
    }

    private async Task SetEpisodeSentiment(int seasonNumber, int episodeNumber, int sentiment)
    {
        int? newSentiment = _episodeSentiments.GetValueOrDefault(seasonNumber)?.GetValueOrDefault(episodeNumber)?.Sentiment == sentiment ? null : sentiment;
        await Api.SetEpisodeSentimentAsync(TmdbId, seasonNumber, episodeNumber, newSentiment);
        if (!_episodeSentiments.ContainsKey(seasonNumber))
            _episodeSentiments[seasonNumber] = [];
        if (newSentiment.HasValue)
            _episodeSentiments[seasonNumber][episodeNumber] = new EpisodeSentiment { TmdbId = TmdbId, SeasonNumber = seasonNumber, EpisodeNumber = episodeNumber, Sentiment = newSentiment.Value };
        else
            _episodeSentiments[seasonNumber].Remove(episodeNumber);
    }
}
