@page "/queue"
@attribute [Authorize]
@implements IAsyncDisposable
@inject ApiClient Api
@inject MediaFilterService MediaFilter
@inject UserServicesCache UserServicesCache
@inject QuickActionService QuickActionSvc
@inject IJSRuntime JS

<PageTitle>My List - Hurrah.tv</PageTitle>

<div class="flex items-center justify-between mb-4 md:mb-6">
    <h1 class="text-xl md:text-2xl font-bold">My List</h1>
</div>

@if (!_loading && _items.Count > 0)
{
    <!-- filter tabs (scrollable on mobile) -->
    <div class="flex gap-2 mb-4 overflow-x-auto pb-1 -mx-1 px-1 scrollbar-none">
        @foreach ((string key, string label) in _tabs)
        {
            int count = key == "all" ? _totalCount : _statusCounts.GetValueOrDefault(key, 0);
            bool active = _activeTab == key;
            <button class="@($"flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm transition-all whitespace-nowrap {(active ? "bg-surface-100 text-white" : "bg-surface-50 text-gray-400 hover:text-white")}")"
                    @onclick="() => { _activeTab = key; _expandedStatusId = null; }">
                <span class="@TabIcon(key) w-3.5 h-3.5 @(active ? "opacity-90" : "opacity-50")"></span>
                @label
                <span class="@(active ? "opacity-60" : "opacity-40") text-xs">@count</span>
            </button>
        }
    </div>
}

@if (_loading)
{
    <!-- shimmer skeleton -->
    <div class="space-y-2 md:space-y-3">
        @for (int i = 0; i < 6; i++)
        {
            <div class="flex items-center gap-3 md:gap-4 bg-surface-50 rounded-lg p-2.5 md:p-3 animate-pulse">
                <div class="w-14 h-20 md:w-16 md:h-24 bg-surface-200 rounded flex-shrink-0"></div>
                <div class="flex-1 space-y-2 min-w-0">
                    <div class="h-4 bg-surface-200 rounded w-3/5"></div>
                    <div class="h-3 bg-surface-200 rounded w-1/4"></div>
                </div>
                <div class="h-7 w-20 bg-surface-200 rounded-full flex-shrink-0"></div>
            </div>
        }
    </div>
}
else if (_items.Count == 0)
{
    <!-- global empty state -->
    <div class="text-center py-16 md:py-24 fade-in">
        <span class="icon-[heroicons--film] w-14 h-14 md:w-16 md:h-16 mx-auto mb-4 text-gray-700 block"></span>
        <p class="text-gray-300 text-lg font-semibold mb-2">Your list is empty</p>
        <p class="text-gray-600 mb-6 text-sm">Add shows and movies you want to watch.</p>
        <a href="/search" class="bg-accent hover:bg-accent-light text-white font-semibold px-6 py-2.5 rounded-lg transition-colors inline-block">
            Browse Content
        </a>
    </div>
}
else
{
    List<QueueItem> visible = FilteredItems.ToList();

    @if (!visible.Any())
    {
        <!-- filtered empty state -->
        <div class="text-center py-12 fade-in">
            <p class="text-gray-500 text-sm">Nothing here yet</p>
            <p class="text-gray-600 text-xs mt-1">Items you mark as "@(_tabs.FirstOrDefault(t => t.key == _activeTab).label ?? _activeTab)" will show up here.</p>
        </div>
    }
    else
    {
        <div @ref="_listEl" class="space-y-2 md:space-y-3 fade-in">
            @foreach (QueueItem item in visible)
            {
                <div @key="item.Id" data-item-id="@item.Id"
                     class="flex items-center gap-3 md:gap-4 bg-surface-50 rounded-lg p-2.5 md:p-3 hover:bg-surface-100 transition-colors group">

                    @if (_activeTab == WantToWatchTab)
                    {
                        bool reordering = _reorderingIds.Contains(item.Id);
                        <button class="@($"drag-handle flex-shrink-0 cursor-grab active:cursor-grabbing touch-none p-1 -ml-1 transition-opacity {(reordering ? "opacity-30 pointer-events-none" : "text-gray-600 hover:text-gray-300")}")"
                                aria-label="Reorder @item.Title" tabindex="-1">
                            <span class="icon-[heroicons--bars-3] w-5 h-5 block"></span>
                        </button>
                    }

                    <a href="/details/@item.MediaType/@item.TmdbId" class="flex-shrink-0 relative">
                        @if (!string.IsNullOrEmpty(item.PosterUrl("w92")))
                        {
                            <img src="@item.PosterUrl("w92")" alt="@item.Title"
                                 class="w-14 h-20 md:w-16 md:h-24 object-cover rounded" />
                        }
                        else
                        {
                            <div class="w-14 h-20 md:w-16 md:h-24 bg-surface-200 rounded flex items-center justify-center">
                                <span class="icon-[heroicons--photo] w-5 h-5 text-gray-600"></span>
                            </div>
                        }
                        @if (item.HasNewEpisode)
                        {
                            <span class="absolute -top-1 -right-1 bg-black/60 backdrop-blur-sm rounded-full w-5 h-5 flex items-center justify-center"
                                  title="New episode available">
                                <span class="icon-[heroicons--sparkles] w-3 h-3 text-amber-300"></span>
                            </span>
                        }
                        else if (item.HasUpcomingEpisode)
                        {
                            <span class="absolute -top-1 -right-1 bg-blue-600 rounded-full w-5 h-5 flex items-center justify-center shadow"
                                  title="New episode coming soon">
                                <span class="icon-[heroicons--clock] w-3 h-3 text-white"></span>
                            </span>
                        }
                    </a>


                    <div class="flex-1 min-w-0">
                        <a href="/details/@item.MediaType/@item.TmdbId"
                           class="font-semibold text-sm md:text-base text-white hover:text-accent transition-colors truncate block leading-tight">
                            @item.Title
                        </a>
                        <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                            <span class="text-[10px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded bg-surface-200 text-gray-500">
                                @(item.MediaType == "tv" ? "TV" : "Movie")
                            </span>
                            @foreach (StreamingService svc in _itemServices.GetValueOrDefault(item.Id, []))
                            {
                                <span class="flex items-center gap-1 text-[10px] font-medium px-1.5 py-0.5 rounded bg-surface-200 text-gray-300">
                                    <img src="@svc.LogoUrl("w45")" alt="" class="w-3.5 h-3.5 rounded" />
                                    @svc.Name
                                </span>
                            }
                            @if (item.Sentiment.HasValue)
                            {
                                <span class="@SentimentHelpers.Color(item.Sentiment.Value) flex items-center">
                                    <span class="@SentimentHelpers.Icon(item.Sentiment.Value) w-3.5 h-3.5"></span>
                                </span>
                            }
                            @if (item.MediaType == "tv" && item.LastSeasonWatched.HasValue && item.LastEpisodeWatched.HasValue)
                            {
                                <span class="text-xs text-gray-500">S@(item.LastSeasonWatched) E@(item.LastEpisodeWatched)</span>
                            }
                        </div>
                    </div>


                    <div class="flex-shrink-0">
                        @if (_expandedStatusId == item.Id)
                        {
                            <div class="flex items-center gap-1">
                                @foreach (QueueStatus s in BadgeHelpers.AllStatuses)
                                {
                                    <button class="@($"w-8 h-8 rounded-full flex items-center justify-center transition-all {(item.Status == s ? BadgeHelpers.StatusColor(s) + " bg-surface-200 scale-110" : "text-gray-500 hover:text-white hover:bg-surface-100")}")"
                                            @onclick="() => SelectStatus(item, s)"
                                            title="@SentimentHelpers.StatusLabel(s)">
                                        <span class="@BadgeHelpers.StatusIcon(s) w-4 h-4"></span>
                                    </button>
                                }
                                <button class="w-8 h-8 rounded-full flex items-center justify-center text-gray-500 hover:text-white hover:bg-surface-100 transition-colors ml-0.5"
                                        @onclick="() => _expandedStatusId = null">
                                    <span class="icon-[heroicons--x-mark] w-4 h-4"></span>
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="@($"flex items-center gap-1.5 text-xs font-medium transition-opacity hover:opacity-70 {BadgeHelpers.StatusColor(item.Status)}")"
                                    @onclick="() => _expandedStatusId = item.Id">
                                <span class="@BadgeHelpers.StatusIcon(item.Status) w-3.5 h-3.5"></span>
                                <span class="hidden sm:inline">@BadgeHelpers.StatusShortLabel(item.Status)</span>
                            </button>
                        }
                    </div>


                    <button class="text-gray-700 hover:text-red-400 transition-colors p-1.5 flex-shrink-0 md:opacity-0 md:group-hover:opacity-100"
                            @onclick="() => Remove(item)" title="Remove from list">
                        <span class="icon-[heroicons--trash] w-4 h-4"></span>
                    </button>
                </div>
            }
        </div>
    }
}

@code {
    private List<QueueItem> _items = [];
    private Dictionary<string, int> _statusCounts = [];
    private Dictionary<int, List<StreamingService>> _itemServices = [];
    private IReadOnlyList<int> _userServices = [];
    private int _totalCount;
    private bool _loading = true;
    private string _activeTab = "all";
    private int? _expandedStatusId;

    // drag-reorder is meaningful only on the WantToWatch tab — Position is the primary
    // sort signal there; other tabs are sorted by recency / status. See Plans/issue-39.
    private const string WantToWatchTab = "wanttowatch";

    private ElementReference _listEl;
    private IJSObjectReference? _sortableHandle;
    private DotNetObjectReference<Queue>? _dotNetRef;
    private string? _attachedTab;
    private readonly HashSet<int> _reorderingIds = [];
    private bool _disposed;

    private static readonly (string key, string label)[] _tabs =
    [
        ("all", "All"),
        ("watching", "Watching"),
        ("wanttowatch", "Want to Watch"),
        ("finished", "Watched"),
        ("notforme", "Not For Me")
    ];

    private static string TabIcon(string key) => key switch
    {
        "watching"    => BadgeHelpers.StatusIcon(QueueStatus.Watching),
        "wanttowatch" => BadgeHelpers.StatusIcon(QueueStatus.WantToWatch),
        "finished"    => BadgeHelpers.StatusIcon(QueueStatus.Finished),
        "notforme"    => BadgeHelpers.StatusIcon(QueueStatus.NotForMe),
        _             => "icon-[heroicons--bars-3]"
    };

    private static string StatusKey(QueueStatus status) => status switch
    {
        QueueStatus.WantToWatch => "wanttowatch",
        QueueStatus.Watching    => "watching",
        QueueStatus.Finished    => "finished",
        QueueStatus.NotForMe    => "notforme",
        _                       => "unknown"
    };

    private IEnumerable<QueueItem> FilteredItems =>
        (_activeTab == "all" ? _items : _items.Where(i => StatusKey(i.Status) == _activeTab))
        .Where(i => MediaFilter.MediaType == "all" || i.MediaType == MediaFilter.MediaType);

    protected override async Task OnInitializedAsync()
    {
        MediaFilter.OnChanged += OnMediaFilterChanged;
        UserServicesCache.Changed += OnServicesChanged;
        _userServices = await UserServicesCache.GetAsync();
        await LoadQueue();
    }

    private void OnMediaFilterChanged() => InvokeAsync(() => { UpdateCounts(); StateHasChanged(); });

    private void OnServicesChanged()
    {
        _userServices = UserServicesCache.TryGetCached();
        UpdateItemServices();
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadQueue()
    {
        _loading = true;
        _items = await Api.GetQueueAsync();
        _loading = false;
        UpdateCounts();
        UpdateItemServices();
    }

    private void UpdateItemServices()
    {
        _itemServices = _items.ToDictionary(i => i.Id, i => i.VisibleServicesFor(_userServices));
    }

    private void UpdateCounts()
    {
        IEnumerable<QueueItem> scoped = MediaFilter.MediaType == "all"
            ? _items
            : _items.Where(i => i.MediaType == MediaFilter.MediaType);
        _totalCount = scoped.Count();
        _statusCounts = scoped
            .GroupBy(i => StatusKey(i.Status))
            .ToDictionary(g => g.Key, g => g.Count());
    }

    private async Task SelectStatus(QueueItem item, QueueStatus status)
    {
        if (item.Status == status) { _expandedStatusId = null; return; }
        _expandedStatusId = null;
        try
        {
            QueueItem? updated = await Api.UpdateStatusAsync(item.Id, status);
            if (updated != null)
            {
                // splice the fresh server state into our list and notify listeners (e.g. Home,
                // if it's still mounted) so they can update in place without a refetch
                int idx = _items.IndexOf(item);
                if (idx >= 0) _items[idx] = updated;
                QuickActionSvc.NotifyItemUpdated(updated);
            }
            else
            {
                item.Status = status; // optimistic fallback
            }
            UpdateCounts();
        }
        catch { }
    }

    private async Task Remove(QueueItem item)
    {
        try
        {
            await Api.RemoveFromQueueAsync(item.Id);
            _items.Remove(item);
            UpdateCounts();
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        bool wantSortable = _activeTab == WantToWatchTab && !_loading && FilteredItems.Any();

        if (wantSortable && _attachedTab != _activeTab)
        {
            await DisposeSortableAsync();
            _dotNetRef ??= DotNetObjectReference.Create(this);
            _sortableHandle = await JS.InvokeAsync<IJSObjectReference>(
                "hurrahSortableInit", _listEl, _dotNetRef, nameof(OnReorder), null);
            _attachedTab = _activeTab;
        }
        else if (!wantSortable && _attachedTab is not null)
        {
            await DisposeSortableAsync();
        }
    }

    private async Task DisposeSortableAsync()
    {
        if (_sortableHandle is not null)
        {
            try { await JS.InvokeVoidAsync("hurrahSortableDispose", _sortableHandle); } catch { }
            try { await _sortableHandle.DisposeAsync(); } catch { }
            _sortableHandle = null;
        }
        _attachedTab = null;
    }

    [JSInvokable]
    public async Task OnReorder(int itemId, int oldIndex, int newIndex)
    {
        // a drag in flight when the user navigates away can deliver onEnd after
        // the component is gone — do not mutate state on a disposed component
        if (_disposed || oldIndex == newIndex) return;

        List<QueueItem> visible = FilteredItems.ToList();
        if (newIndex < 0 || newIndex >= visible.Count) return;

        QueueItem? dragged = visible.FirstOrDefault(i => i.Id == itemId);
        QueueItem target = visible[newIndex];
        if (dragged is null || ReferenceEquals(dragged, target)) return;

        // ReorderAsync sets dragged.Position = target.Position and shifts the displaced
        // item out of the way. Net effect: dragged lands exactly where target used to be.
        int targetPos = target.Position;

        // optimistic local rearrange so the UI doesn't snap back during the API call
        List<QueueItem> snapshot = [.._items];
        _items.Remove(dragged);
        int targetInItems = _items.IndexOf(target);
        if (targetInItems < 0) { _items = snapshot; return; }
        int insertAt = newIndex > oldIndex ? targetInItems + 1 : targetInItems;
        _items.Insert(insertAt, dragged);
        _reorderingIds.Add(itemId);
        await InvokeAsync(StateHasChanged);

        try
        {
            bool ok = await Api.UpdateQueuePositionAsync(itemId, targetPos);
            if (!ok) _items = snapshot;
        }
        catch
        {
            _items = snapshot;
        }
        finally
        {
            _reorderingIds.Remove(itemId);
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        MediaFilter.OnChanged -= OnMediaFilterChanged;
        UserServicesCache.Changed -= OnServicesChanged;
        await DisposeSortableAsync();
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }
}
