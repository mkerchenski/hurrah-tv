@page "/search"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api

<PageTitle>Search - Hurrah.tv</PageTitle>

<div class="max-w-3xl mx-auto mb-6 md:mb-8">
    <div class="relative">
        <span class="icon-[heroicons--magnifying-glass] absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500"></span>
        <input type="text" @bind="_query" @bind:event="oninput" @onkeyup="HandleKeyUp"
               placeholder="Search movies and TV shows..."
               class="w-full bg-surface-50 border border-surface-200 rounded-xl pl-12 pr-12 py-3 md:text-lg
                      text-white placeholder-gray-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent" />
        @if (!string.IsNullOrEmpty(_query))
        {
            <button class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white p-1"
                    @onclick="ClearSearch">
                <span class="icon-[heroicons--x-mark] w-5 h-5"></span>
            </button>
        }
    </div>

    <!-- filter tabs -->
    <div class="flex gap-2 mt-3 md:mt-4">
        @foreach (string tab in new[] { "all", "tv", "movie" })
        {
            string label = tab == "all" ? "All" : tab == "tv" ? "TV Shows" : "Movies";
            <button class="@($"px-3 md:px-4 py-1.5 rounded-full text-sm transition-all {(_activeTab == tab ? "bg-accent text-white" : "bg-surface-50 text-gray-400 hover:text-white")}")"
                    @onclick="() => FilterByTab(tab)">
                @label
            </button>
        }
    </div>
</div>

<PosterGrid Results="_filteredResults" Loading="_loading" EmptyMessage="@_emptyMessage" />

@code {
    private string _query = "";
    private string _activeTab = "all";
    private List<SearchResult> _results = [];
    private bool _loading;
    private CancellationTokenSource? _cts;
    private string _emptyMessage = "Start typing to search";

    private List<SearchResult> _filteredResults => _activeTab == "all"
        ? _results
        : _results.Where(r => r.MediaType == _activeTab).ToList();

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        _cts?.Cancel();
        _cts?.Dispose();

        if (string.IsNullOrWhiteSpace(_query))
        {
            _results = [];
            _emptyMessage = "Start typing to search";
            return;
        }

        _cts = new CancellationTokenSource();
        CancellationToken token = _cts.Token;
        _ = DebounceSearchAsync(token);
    }

    private async Task DebounceSearchAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(400, token);
            await InvokeAsync(async () =>
            {
                if (token.IsCancellationRequested || string.IsNullOrWhiteSpace(_query)) return;

                _loading = true;
                _emptyMessage = "No results found";
                StateHasChanged();

                _results = await Api.SearchAsync(_query);
                _loading = false;
                StateHasChanged();
            });
        }
        catch (TaskCanceledException) { }
    }

    private void FilterByTab(string tab)
    {
        _activeTab = tab;
    }

    private void ClearSearch()
    {
        _cts?.Cancel();
        _query = "";
        _results = [];
        _emptyMessage = "Start typing to search";
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
