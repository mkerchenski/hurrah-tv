@page "/search"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject NavigationManager Nav
@inject MediaFilterService MediaFilter

<PageTitle>Search - Hurrah.tv</PageTitle>

<div class="max-w-3xl mx-auto mb-6 md:mb-8">
    <div class="relative">
        <span class="icon-[heroicons--magnifying-glass] absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500"></span>
        <input type="text" @bind="_query" @bind:event="oninput" @onkeyup="HandleKeyUp"
               placeholder="Search movies and TV shows..."
               class="w-full bg-surface-50 border border-surface-200 rounded-xl pl-12 pr-12 py-3 md:text-lg
                      text-white placeholder-gray-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent" />
        @if (!string.IsNullOrEmpty(_query))
        {
            <button class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white p-1"
                    @onclick="ClearSearch">
                <span class="icon-[heroicons--x-mark] w-5 h-5"></span>
            </button>
        }
    </div>

</div>

<PosterGrid Results="_filteredResults" Loading="_loading" EmptyMessage="@_emptyMessage" />

@code {
    private string _query = "";
    private List<SearchResult> _results = [];
    private bool _loading;
    private CancellationTokenSource? _cts;
    private string _emptyMessage = "Start typing to search";

    private List<SearchResult> _filteredResults => MediaFilter.MediaType == "all"
        ? _results
        : _results.Where(r => r.MediaType == MediaFilter.MediaType).ToList();

    protected override async Task OnInitializedAsync()
    {
        MediaFilter.OnChanged += OnMediaFilterChanged;

        // restore query from URL on back navigation
        Uri uri = new(Nav.Uri);
        string? q = System.Web.HttpUtility.ParseQueryString(uri.Query).Get("q");
        if (!string.IsNullOrWhiteSpace(q))
        {
            _query = q;
            _loading = true;
            SearchResponse response = await Api.SearchAsync(_query);
            _results = response.Results;
            _emptyMessage = _results.Count == 0 ? "No results found" : "";
            _loading = false;
        }
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        _cts?.Cancel();
        _cts?.Dispose();

        if (string.IsNullOrWhiteSpace(_query) || _query.Trim().Length < 2)
        {
            _results = [];
            _emptyMessage = "Start typing to search";
            UpdateUrl("");
            return;
        }

        _cts = new CancellationTokenSource();
        CancellationToken token = _cts.Token;
        _ = DebounceSearchAsync(token);
    }

    private async Task DebounceSearchAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(300, token);
            await InvokeAsync(async () =>
            {
                if (token.IsCancellationRequested || string.IsNullOrWhiteSpace(_query)) return;

                _loading = true;
                StateHasChanged();

                SearchResponse response = await Api.SearchAsync(_query);
                _results = response.Results;

                _emptyMessage = _results.Count == 0
                    ? "No results found — try different spelling or keywords"
                    : "";

                _loading = false;
                UpdateUrl(_query);
                StateHasChanged();
            });
        }
        catch (TaskCanceledException) { }
    }

    private void OnMediaFilterChanged() => InvokeAsync(StateHasChanged);

    private void ClearSearch()
    {
        _cts?.Cancel();
        _query = "";
        _results = [];
        _emptyMessage = "Start typing to search";
        UpdateUrl("");
    }

    private void UpdateUrl(string query)
    {
        string url = string.IsNullOrWhiteSpace(query)
            ? "/search"
            : $"/search?q={Uri.EscapeDataString(query)}";
        Nav.NavigateTo(url, replace: true);
    }

    public void Dispose()
    {
        MediaFilter.OnChanged -= OnMediaFilterChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
