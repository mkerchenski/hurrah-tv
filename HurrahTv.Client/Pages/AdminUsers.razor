@page "/admin/users"
@attribute [Authorize(Policy = "Admin")]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Admin · Users - Hurrah.tv</PageTitle>

<div class="max-w-6xl mx-auto">
    <div class="flex items-center gap-3 mb-4 md:mb-6">
        <a href="/admin" class="text-gray-400 hover:text-white transition-colors">
            <span class="icon-[heroicons--chevron-left] w-5 h-5 inline-block align-text-bottom"></span>
            Admin
        </a>
        <span class="text-gray-600">/</span>
        <h1 class="text-xl md:text-2xl font-bold">Users</h1>
    </div>

    @if (_loading)
    {
        <div class="w-6 h-6 border-2 border-accent border-t-transparent rounded-full animate-spin"></div>
    }
    else if (_response is null)
    {
        <div class="text-red-400">Could not load users.</div>
    }
    else
    {
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-4 md:mb-6">
            <StatCard Label="Total Users" Value="@_response.TotalUsers.ToString()" />
            <StatCard Label="Admins" Value="@_response.Users.Count(u => u.IsAdmin).ToString()" />
            <StatCard Label="With Queue" Value="@_response.Users.Count(u => u.QueueCount > 0).ToString()" />
            <StatCard Label="With Services" Value="@_response.Users.Count(u => u.ActiveServiceCount > 0).ToString()" />
        </div>

        <div class="bg-surface-50 rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-surface-100 text-gray-400 text-xs uppercase">
                        <tr>
                            <th class="px-3 py-2 text-left">Phone</th>
                            <th class="px-3 py-2 text-left">Name</th>
                            <th class="px-3 py-2 text-left">Joined</th>
                            <th class="px-3 py-2 text-right">Queue</th>
                            <th class="px-3 py-2 text-right">Services</th>
                            <th class="px-3 py-2 text-right">AI $</th>
                            <th class="px-3 py-2 text-left">Last Add</th>
                            <th class="px-3 py-2 text-center">Admin</th>
                            <th class="px-3 py-2 text-center w-8"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (AdminUserSummary u in _response.Users)
                        {
                            <tr class="border-t border-surface-200 hover:bg-surface-100 transition-colors">
                                <td class="px-3 py-2">
                                    <a href="@($"/admin/users/{u.Id}")" class="text-accent hover:underline">@PhoneHelpers.Format(u.PhoneNumber)</a>
                                    @if (u.IsAdmin)
                                    {
                                        <span class="ml-2 text-[10px] uppercase bg-accent/20 text-accent px-1.5 py-0.5 rounded">Admin</span>
                                    }
                                </td>
                                <td class="px-3 py-2">
                                    @if (_editingNameId == u.Id)
                                    {
                                        <div class="flex items-center gap-1">
                                            <input type="text" @bind="_nameDraft" @bind:event="oninput"
                                                   maxlength="50"
                                                   placeholder="Name"
                                                   class="bg-surface-100 border border-surface-200 rounded px-2 py-0.5 text-xs w-28 focus:outline-none focus:border-accent" />
                                            <button @onclick="() => SaveName(u)" disabled="@_savingName"
                                                    class="text-accent hover:text-accent-light text-xs px-1" title="Save">
                                                <span class="icon-[heroicons--check] w-4 h-4"></span>
                                            </button>
                                            <button @onclick="CancelEditName" disabled="@_savingName"
                                                    class="text-gray-500 hover:text-white text-xs px-1" title="Cancel">
                                                <span class="icon-[heroicons--x-mark] w-4 h-4"></span>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button @onclick="() => StartEditName(u)" class="text-left hover:text-white transition-colors group flex items-center gap-1.5">
                                            @if (string.IsNullOrWhiteSpace(u.FirstName))
                                            {
                                                <span class="text-gray-600 italic">add name</span>
                                            }
                                            else
                                            {
                                                <span>@u.FirstName</span>
                                            }
                                            <span class="icon-[heroicons--pencil] w-3 h-3 text-gray-600 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                                        </button>
                                    }
                                </td>
                                <td class="px-3 py-2 text-gray-400">@u.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td class="px-3 py-2 text-right">@u.QueueCount</td>
                                <td class="px-3 py-2 text-right">@u.ActiveServiceCount</td>
                                <td class="px-3 py-2 text-right">@($"${u.TotalAiCostUsd:F2}")</td>
                                <td class="px-3 py-2 text-gray-400">@(u.LastQueueAddAt?.ToLocalTime().ToString("yyyy-MM-dd") ?? "—")</td>
                                <td class="px-3 py-2 text-center">
                                    <button @onclick="() => ToggleAdmin(u)"
                                            disabled="@(_busyId == u.Id)"
                                            class="@(u.IsAdmin ? "bg-accent text-white" : "bg-surface-200 text-gray-300 hover:bg-surface-300") px-2 py-1 rounded text-xs transition-colors disabled:opacity-50">
                                        @(u.IsAdmin ? "Revoke" : "Grant")
                                    </button>
                                </td>
                                <td class="px-3 py-2 text-center">
                                    @{
                                        bool canDelete = !u.IsAdmin;
                                        string deleteTitle = u.IsAdmin
                                            ? "Revoke admin before deleting"
                                            : "Delete user (permanent)";
                                    }
                                    <button @onclick="() => DeleteUser(u)"
                                            disabled="@(!canDelete || _busyId == u.Id)"
                                            title="@deleteTitle"
                                            class="text-gray-500 hover:text-red-400 transition-colors disabled:opacity-30 disabled:hover:text-gray-500 p-1">
                                        <span class="icon-[heroicons--trash] w-4 h-4"></span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="mt-3 text-sm text-red-400">@_error</div>
        }
    }
</div>

@code {
    private bool _loading = true;
    private AdminUsersResponse? _response;
    private string? _busyId;
    private string? _error;
    private string? _editingNameId;
    private string _nameDraft = "";
    private bool _savingName;

    protected override async Task OnInitializedAsync()
    {
        _response = await Api.GetAdminUsersAsync();
        _loading = false;
    }

    private async Task ToggleAdmin(AdminUserSummary user)
    {
        _error = null;
        bool target = !user.IsAdmin;
        string verb = target ? "grant" : "revoke";
        string confirmMsg = target
            ? $"Grant admin to {PhoneHelpers.Format(user.PhoneNumber)}?"
            : $"Revoke admin from {PhoneHelpers.Format(user.PhoneNumber)}?";

        // simple confirm — destructive toggle deserves a beat
        bool confirmed = await ConfirmAsync(confirmMsg);
        if (!confirmed) return;

        _busyId = user.Id;
        try
        {
            HttpResponseMessage res = await Api.SetUserAdminAsync(user.Id, target);
            if (!res.IsSuccessStatusCode)
            {
                _error = await ExtractErrorAsync(res) ?? $"Failed to {verb} admin (HTTP {(int)res.StatusCode}).";
                return;
            }
            _response = await Api.GetAdminUsersAsync();
        }
        finally
        {
            _busyId = null;
        }
    }

    private static async Task<string?> ExtractErrorAsync(HttpResponseMessage res)
    {
        try
        {
            ErrorBody? body = await res.Content.ReadFromJsonAsync<ErrorBody>();
            return body?.Error;
        }
        catch { return null; }
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
    private async Task<bool> ConfirmAsync(string msg) => await JS.InvokeAsync<bool>("confirm", msg);

    private void StartEditName(AdminUserSummary u)
    {
        _editingNameId = u.Id;
        _nameDraft = u.FirstName ?? "";
        _error = null;
    }

    private void CancelEditName()
    {
        _editingNameId = null;
        _nameDraft = "";
    }

    private async Task DeleteUser(AdminUserSummary u)
    {
        _error = null;

        // type-to-confirm: user must type the full phone number to enable the destructive action
        string label = string.IsNullOrWhiteSpace(u.FirstName)
            ? PhoneHelpers.Format(u.PhoneNumber)
            : $"{u.FirstName} ({PhoneHelpers.Format(u.PhoneNumber)})";
        string? typed = await JS.InvokeAsync<string?>("prompt",
            $"DELETE {label} and all their data?\n\nThis cannot be undone. Type the phone number to confirm:\n{u.PhoneNumber}");

        if (typed is null) return;
        if (typed.Trim() != u.PhoneNumber)
        {
            _error = "Phone number didn't match — deletion cancelled.";
            return;
        }

        _busyId = u.Id;
        try
        {
            HttpResponseMessage res = await Api.DeleteUserAsync(u.Id);
            if (!res.IsSuccessStatusCode)
            {
                _error = await ExtractErrorAsync(res) ?? $"Failed to delete (HTTP {(int)res.StatusCode}).";
                return;
            }
            _response = await Api.GetAdminUsersAsync();
        }
        finally
        {
            _busyId = null;
        }
    }

    private async Task SaveName(AdminUserSummary u)
    {
        _savingName = true;
        _error = null;
        try
        {
            string? trimmed = string.IsNullOrWhiteSpace(_nameDraft) ? null : _nameDraft.Trim();
            HttpResponseMessage res = await Api.SetUserFirstNameAsync(u.Id, trimmed);
            if (!res.IsSuccessStatusCode)
            {
                _error = await ExtractErrorAsync(res) ?? $"Failed to save name (HTTP {(int)res.StatusCode}).";
                return;
            }
            _editingNameId = null;
            _response = await Api.GetAdminUsersAsync();
        }
        finally
        {
            _savingName = false;
        }
    }

    private record ErrorBody(string Error);
}
