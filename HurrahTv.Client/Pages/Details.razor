@page "/details/{MediaType}/{TmdbId:int}"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject IJSRuntime JS
@inject QuickActionService QuickActionSvc
@inject ShareService Share
@inject ToastService Toast

<PageTitle>@(_details?.Title ?? "Loading...") - Hurrah.tv</PageTitle>

@if (_loading)
{
    <div class="text-center py-20">
        <div class="w-8 h-8 border-2 border-accent border-t-transparent rounded-full animate-spin mx-auto"></div>
    </div>
}
else if (_details != null)
{
    <!-- backdrop -->
    @if (!string.IsNullOrEmpty(_details.BackdropUrl()))
    {
        <div class="relative -mx-4 md:-mx-6 -mt-4 md:-mt-6 mb-4 md:mb-6 h-48 md:h-80 overflow-hidden">
            <img src="@_details.BackdropUrl("w1280")" alt="" class="w-full h-full object-cover opacity-40" />
            <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent"></div>
            <!-- back button overlaid on backdrop -->
            <button class="absolute top-3 left-3 md:top-4 md:left-4 bg-black/50 hover:bg-black/70 text-white
                           rounded-full w-10 h-10 flex items-center justify-center transition-colors backdrop-blur-sm"
                    @onclick="GoBack" title="Go back">
                <span class="icon-[heroicons--arrow-left] w-5 h-5"></span>
            </button>
            <!-- share button mirrors the back button on the right -->
            <button class="absolute top-3 right-3 md:top-4 md:right-4 bg-black/50 hover:bg-black/70 text-white
                           rounded-full w-10 h-10 flex items-center justify-center transition-colors backdrop-blur-sm"
                    @onclick="ShareDetails" title="Share" aria-label="Share">
                <span class="icon-[heroicons--arrow-up-tray] w-5 h-5"></span>
            </button>
        </div>
    }
    else
    {
        <!-- back + share when no backdrop -->
        <div class="flex items-center justify-between mb-3">
            <button class="text-gray-400 hover:text-white flex items-center gap-1.5 text-sm transition-colors"
                    @onclick="GoBack">
                <span class="icon-[heroicons--arrow-left] w-4 h-4"></span>
                Back
            </button>
            <button class="text-gray-400 hover:text-white flex items-center gap-1.5 text-sm transition-colors"
                    @onclick="ShareDetails" aria-label="Share">
                <span class="icon-[heroicons--arrow-up-tray] w-4 h-4"></span>
                Share
            </button>
        </div>
    }

    <div class="@(!string.IsNullOrEmpty(_details.BackdropUrl()) ? "-mt-24 md:-mt-32 relative z-10" : "") fade-in">
        <!-- mobile: centered poster -->
        <div class="md:hidden flex flex-col items-center mb-4">
            @if (!string.IsNullOrEmpty(_details.PosterUrl()))
            {
                <img src="@_details.PosterUrl("w342")" alt="@_details.Title"
                     class="w-32 rounded-lg shadow-2xl" />
            }
            <h1 class="text-2xl font-bold mt-3 text-center">@_details.Title</h1>
            @if (!string.IsNullOrEmpty(_details.Tagline))
            {
                <p class="text-gray-400 italic text-sm text-center mt-1">@_details.Tagline</p>
            }
        </div>

        <!-- desktop: side by side -->
        <div class="hidden md:flex gap-8">
            <div class="flex-shrink-0 w-48">
                @if (!string.IsNullOrEmpty(_details.PosterUrl()))
                {
                    <img src="@_details.PosterUrl("w500")" alt="@_details.Title"
                         class="w-full rounded-lg shadow-2xl" />
                }
            </div>
            <div class="flex-1 min-w-0">
                <h1 class="text-3xl font-bold mb-1">@_details.Title</h1>
                @if (!string.IsNullOrEmpty(_details.Tagline))
                {
                    <p class="text-gray-400 italic mb-3">@_details.Tagline</p>
                }
                @{ RenderMetadata(); }
            </div>
        </div>

        <!-- trailer: rendered ONCE outside RenderMetadata. RenderMetadata is called
             twice (desktop right-column + mobile-below-poster) and CSS hides one,
             but display:none does NOT unload iframes — duplicating would mount two
             YouTube embeds with autoplay=1 and play audio twice. Keep this single. -->
        @if (_details.Trailers.Count > 0)
        {
            int activeIdx = Math.Clamp(_activeTrailerIndex, 0, _details.Trailers.Count - 1);
            TrailerDto active = _details.Trailers[activeIdx];
            string activeLabel = TrailerLabel(active, activeIdx);
            <div class="mb-4 md:mb-6">
                <h3 class="text-sm font-semibold text-gray-400 mb-2 uppercase tracking-wider">Trailer</h3>
                <div class="relative aspect-video bg-black rounded-lg overflow-hidden">
                    @if (_trailerPlaying)
                    {
                        <iframe @key="active.Key" class="w-full h-full"
                                src="@($"https://www.youtube-nocookie.com/embed/{Uri.EscapeDataString(active.Key)}?autoplay=1&rel=0")"
                                title="@activeLabel"
                                referrerpolicy="strict-origin-when-cross-origin"
                                allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen></iframe>
                    }
                    else
                    {
                        <button type="button" class="group block w-full h-full cursor-pointer"
                                @onclick="PlayTrailer" aria-label="@($"Play {activeLabel}")">
                            @* deleted/private YouTube videos fail two ways: a 404 (caught by
                               onerror) or a successfully-loaded gray 120x90 placeholder (caught
                               by onload — a real hqdefault.jpg is 480 wide). either way we hide
                               the img; the bg-black container and play overlay still render and
                               stay clickable. @key remounts a fresh img per trailer so a hidden
                               state doesn't carry display:none to the next chip. pins #111. *@
                            <img @key="active.Key"
                                 src="@($"https://img.youtube.com/vi/{Uri.EscapeDataString(active.Key)}/hqdefault.jpg")"
                                 alt="" loading="lazy" draggable="false"
                                 onerror="this.style.display='none'"
                                 onload="if(this.naturalWidth<=120)this.style.display='none'"
                                 class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity no-callout" />
                            <div class="absolute inset-0 flex items-center justify-center">
                                <div class="bg-black/60 group-hover:bg-accent rounded-full w-16 h-16 md:w-20 md:h-20
                                            flex items-center justify-center transition-colors shadow-2xl">
                                    <span class="icon-[heroicons--play-solid] w-8 h-8 md:w-10 md:h-10 text-white ml-1"></span>
                                </div>
                            </div>
                            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-3">
                                <p class="text-sm md:text-base text-white font-medium truncate">@activeLabel</p>
                            </div>
                        </button>
                    }
                </div>
                @if (_details.Trailers.Count > 1)
                {
                    <div class="flex gap-2 mt-2 overflow-x-auto pb-1">
                        @for (int i = 0; i < _details.Trailers.Count; i++)
                        {
                            int idx = i;
                            TrailerDto t = _details.Trailers[idx];
                            bool isActive = idx == _activeTrailerIndex;
                            string chipLabel = TrailerLabel(t, idx);
                            <button type="button" aria-pressed="@isActive" aria-label="@chipLabel"
                                    class="@($"flex-shrink-0 text-left text-xs px-3 py-1.5 rounded-md transition-colors border {(isActive ? "border-accent bg-accent/20 text-white" : "border-surface-200 bg-surface-50 text-gray-400 hover:text-gray-200 hover:border-gray-500")}")"
                                    @onclick="() => SelectTrailer(idx)">
                                @chipLabel
                            </button>
                        }
                    </div>
                }
            </div>
        }

        <!-- mobile: metadata below poster -->
        <div class="md:hidden">
            @{ RenderMetadata(); }
        </div>
    </div>
}
else
{
    <div class="text-center py-20 text-gray-500">Content not found.</div>
}

@{
    void RenderMetadata()
    {
        <!-- AI match blurb -->
        @if (_showMatch != null)
        {
            string matchColor = _showMatch.Match switch
            {
                "strong" => "accent",
                "good" => "green-500",
                "stretch" => "yellow-500",
                "miss" => "gray-500",
                _ => "gray-500"
            };
            string matchBg = _showMatch.Match switch
            {
                "strong" => "bg-accent/15 border-accent/30",
                "good" => "bg-green-600/15 border-green-600/30",
                "stretch" => "bg-yellow-600/15 border-yellow-600/30",
                "miss" => "bg-gray-600/15 border-gray-600/30",
                _ => "bg-gray-600/15 border-gray-600/30"
            };
            string matchLabel = _showMatch.Match switch
            {
                "strong" => "Great match",
                "good" => "Good match",
                "stretch" => "Worth a try",
                "miss" => "Not your usual",
                _ => ""
            };
            <div class="flex items-start gap-2 @matchBg border rounded-lg px-3 py-2 mb-3 md:mb-4 fade-in">
                <span class="icon-[heroicons--sparkles] w-4 h-4 text-@matchColor mt-0.5 flex-shrink-0"></span>
                <div class="text-sm">
                    <span class="font-medium text-@matchColor">@matchLabel</span>
                    <span class="text-gray-300 ml-1">@_showMatch.Reason</span>
                </div>
            </div>
        }
        else if (_matchLoading)
        {
            <div class="flex items-center gap-2 bg-surface-50 border border-surface-200 rounded-lg px-3 py-2 mb-3 md:mb-4">
                <div class="w-3 h-3 border-2 border-accent border-t-transparent rounded-full animate-spin"></div>
                <span class="text-xs text-gray-500">Analyzing match with your taste...</span>
            </div>
        }

        <!-- new/upcoming episode banner -->
        @if (_details!.MediaType == "tv")
        {
            @if (_details.NextEpisodeAirDate != null)
            {
                <div class="flex items-center gap-2 bg-blue-600/20 border border-blue-600/40 rounded-lg px-3 py-2 mb-3 md:mb-4">
                    <span class="icon-[heroicons--clock] w-5 h-5 text-blue-400"></span>
                    <div class="text-sm">
                        <span class="text-blue-300 font-medium">Next episode</span>
                        <span class="text-gray-300">
                            S@(_details.NextEpisodeSeason)E@(_details.NextEpisodeNumber)
                            @if (!string.IsNullOrEmpty(_details.NextEpisodeName))
                            {
                                <span>&ldquo;@_details.NextEpisodeName&rdquo;</span>
                            }
                            &mdash; @FormatAirDate(_details.NextEpisodeAirDate)
                        </span>
                    </div>
                </div>
            }
            else if (_details.LastEpisodeAirDate != null && IsRecent(_details.LastEpisodeAirDate))
            {
                <div class="flex items-center gap-2 bg-accent/20 border border-accent/40 rounded-lg px-3 py-2 mb-3 md:mb-4">
                    <span class="icon-[heroicons--sparkles] w-5 h-5 text-accent-light"></span>
                    <div class="text-sm">
                        <span class="text-accent-light font-medium">New episode</span>
                        <span class="text-gray-300">
                            S@(_details.LastEpisodeSeason) E@(_details.LastEpisodeNumber)
                            @if (!string.IsNullOrEmpty(_details.LastEpisodeName) && _details.LastEpisodeName != $"Episode {_details.LastEpisodeNumber}")
                            {
                                <span>&ldquo;@_details.LastEpisodeName&rdquo;</span>
                            }
                            &mdash; aired @FormatAirDate(_details.LastEpisodeAirDate)
                        </span>
                    </div>
                </div>
            }
        }

        <div class="flex flex-wrap items-center gap-2 md:gap-3 text-sm text-gray-400 mb-3 md:mb-4">
            @if (!string.IsNullOrEmpty(_details.Year))
            {
                <span>@_details.Year</span>
            }
            @if (_details.MediaType == "tv" && _details.NumberOfSeasons > 0)
            {
                <span>@_details.NumberOfSeasons season@(_details.NumberOfSeasons > 1 ? "s" : "")</span>
            }
            @if (_details.Runtime > 0)
            {
                <span>@(_details.Runtime / 60)h @(_details.Runtime % 60)m</span>
            }
            @if (_details.VoteAverage > 0)
            {
                <span class="flex items-center gap-1">
                    <span class="icon-[heroicons--star-20-solid] w-4 h-4 text-yellow-400"></span>
                    @_details.VoteAverage.ToString("F1")
                </span>
            }
            @if (!string.IsNullOrEmpty(_details.Status))
            {
                <span class="px-2 py-0.5 bg-surface-100 rounded text-xs">@_details.Status</span>
            }
            @if (_details.MediaType == "tv" && _details.LastEpisodeAirDate != null)
            {
                <span>Last aired @FormatAirDate(_details.LastEpisodeAirDate)</span>
            }
            @if (_details.MediaType == "movie" && !string.IsNullOrEmpty(_details.ReleaseDate) && IsRecent(_details.ReleaseDate))
            {
                <span class="text-accent-light font-medium">New release</span>
            }
        </div>

        <!-- genres -->
        @if (_details.Genres.Count > 0)
        {
            <div class="flex flex-wrap gap-2 mb-3 md:mb-4">
                @foreach (string genre in _details.Genres)
                {
                    <span class="px-2.5 py-1 bg-surface-100 rounded-full text-xs text-gray-300">@genre</span>
                }
            </div>
        }

        <!-- available on -->
        <div class="mb-3 md:mb-4">
            <h3 class="text-sm font-semibold text-gray-400 mb-2 uppercase tracking-wider">Streaming on</h3>
            @if (_details.AvailableOn.Count > 0)
            {
                <div class="flex flex-wrap gap-2 md:gap-3">
                    @foreach (AvailableService svc in _details.AvailableOn)
                    {
                        @if (!string.IsNullOrEmpty(svc.Link))
                        {
                            @* svc.Link is the region-level JustWatch page (all providers), not a
                               provider-specific deep link — keep the tooltip destination-neutral *@
                            <a href="@svc.Link" target="_blank" rel="noopener noreferrer"
                               title="Find where to watch @_details.Title"
                               class="group flex items-center gap-2 bg-surface-50 hover:bg-surface-100 transition-colors px-3 py-2 rounded-lg">
                                @if (!string.IsNullOrEmpty(svc.LogoUrl()))
                                {
                                    @* decorative — the provider name is already the link's visible text *@
                                    <img src="@svc.LogoUrl("w45")" alt="" class="w-6 h-6 rounded" />
                                }
                                <span class="text-sm">@svc.ProviderName</span>
                                <svg class="w-3.5 h-3.5 text-gray-500 group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                            </a>
                        }
                        else
                        {
                            <div class="flex items-center gap-2 bg-surface-50 px-3 py-2 rounded-lg">
                                @if (!string.IsNullOrEmpty(svc.LogoUrl()))
                                {
                                    <img src="@svc.LogoUrl("w45")" alt="" class="w-6 h-6 rounded" />
                                }
                                <span class="text-sm">@svc.ProviderName</span>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-gray-600 italic">No streaming info available</p>
            }
        </div>

        <p class="text-gray-300 text-sm md:text-base leading-relaxed mb-4 md:mb-6">@_details.Overview</p>

        <!-- my list (mutually exclusive) -->
        <div class="mb-4">
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-2">My List</div>
            <div class="flex flex-wrap gap-2">
                @foreach ((QueueStatus status, string label, string icon) in _listOptions)
                {
                    bool active = _queueItem?.Status == status;
                    <button class="@($"px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-2 border {(active ? "border-accent bg-accent/20 text-white" : "border-surface-200 bg-surface-50 text-gray-400 hover:border-gray-500 hover:text-gray-300")}")"
                            @onclick="() => SetListStatus(status)">
                        <span class="@($"{icon} w-4 h-4 {(active ? "text-accent-light" : "")}")"></span>
                        <span>@label</span>
                    </button>
                }
            </div>
        </div>

        <!-- sentiment (independent toggle) -->
        <div class="mb-4 md:mb-6">
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-2">My Take</div>
            <div class="flex gap-2">
                <button class="@($"w-10 h-10 rounded-lg flex items-center justify-center transition-colors border {(_queueItem?.Sentiment == SentimentLevel.Down ? "border-red-500 bg-red-600/20 text-red-400" : "border-surface-200 bg-surface-50 text-gray-500 hover:border-red-500 hover:text-red-400")}")"
                        @onclick="() => SetSentiment(SentimentLevel.Down)" title="Thumbs down">
                    <span class="icon-[heroicons--hand-thumb-down] w-5 h-5"></span>
                </button>
                <button class="@($"w-10 h-10 rounded-lg flex items-center justify-center transition-colors border {(_queueItem?.Sentiment == SentimentLevel.Up ? "border-green-500 bg-green-600/20 text-green-400" : "border-surface-200 bg-surface-50 text-gray-500 hover:border-green-500 hover:text-green-400")}")"
                        @onclick="() => SetSentiment(SentimentLevel.Up)" title="Thumbs up">
                    <span class="icon-[heroicons--hand-thumb-up] w-5 h-5"></span>
                </button>
                <button class="@($"w-10 h-10 rounded-lg flex items-center justify-center transition-colors border {(_queueItem?.Sentiment == SentimentLevel.Favorite ? "border-pink-500 bg-pink-600/20 text-pink-400" : "border-surface-200 bg-surface-50 text-gray-500 hover:border-pink-500 hover:text-pink-400")}")"
                        @onclick="() => SetSentiment(SentimentLevel.Favorite)" title="Favorite">
                    <span class="icon-[heroicons--heart] w-5 h-5"></span>
                </button>
            </div>
        </div>

        <!-- seasons & episodes -->
        @if (_details.Seasons.Count > 0)
        {
            <EpisodeBrowser TmdbId="TmdbId" Seasons="_details.Seasons" />
        }
    }
}

@code {
    [Parameter] public string MediaType { get; set; } = "";
    [Parameter] public int TmdbId { get; set; }

    private ShowDetails? _details;
    private bool _loading = true;
    private QueueItem? _queueItem;
    private int _lastTmdbId;
    private string _lastMediaType = "";
    private ShowMatchResult? _showMatch;
    private bool _matchLoading;
    private bool _disposed;
    // single page-scoped CTS — covers the awaited Details/Queue fetches AND the
    // fire-and-forget match load. Rapid navigation cancels in-flight calls so a
    // late response for show A can't overwrite _details / _queueItem while the
    // user is on show B (especially visible with the trailer iframe). pins #112.
    private CancellationTokenSource? _loadCts;
    private int _activeTrailerIndex;
    private bool _trailerPlaying;

    private static readonly (QueueStatus status, string label, string icon)[] _listOptions =
    [
        (QueueStatus.WantToWatch, "Want to Watch", "icon-[heroicons--bookmark]"),
        (QueueStatus.Watching, "Watching", "icon-[heroicons--play]"),
        (QueueStatus.Finished, "Watched", "icon-[heroicons--eye]"),
        (QueueStatus.NotForMe, "Not For Me", "icon-[heroicons--x-mark]"),
    ];

    public void Dispose()
    {
        _disposed = true;
        _loadCts?.Cancel();
        _loadCts?.Dispose();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_lastTmdbId == TmdbId && _lastMediaType == MediaType) return;
        _lastTmdbId = TmdbId;
        _lastMediaType = MediaType;
        _queueItem = null;
        _showMatch = null;
        _matchLoading = false;
        _activeTrailerIndex = 0;
        _trailerPlaying = false;
        _loading = true;
        StateHasChanged();

        // cancel any prior in-flight loads (details/queue/match) so a late response
        // from the previous TmdbId can't clobber state for the current one.
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();
        CancellationToken ct = _loadCts.Token;

        try
        {
            // assign-on-success: if the HTTP call completed a beat before cancel landed,
            // the early return drops the stale response instead of overwriting state
            // for the now-current TmdbId.
            ShowDetails? details = await Api.GetDetailsAsync(TmdbId, MediaType, ct);
            if (ct.IsCancellationRequested) return;
            _details = details;
            _loading = false;

            // check if this item is already in the queue
            List<QueueItem> queue = await Api.GetQueueAsync(ct);
            if (ct.IsCancellationRequested) return;
            _queueItem = queue.FirstOrDefault(i => i.TmdbId == TmdbId && i.MediaType == MediaType);
        }
        catch (OperationCanceledException)
        {
            // a newer OnParametersSetAsync took over — abandon silently.
            return;
        }

        _ = LoadShowMatch(ct);
    }

    private async Task LoadShowMatch(CancellationToken ct)
    {
        _matchLoading = true;
        if (!_disposed) StateHasChanged();
        try
        {
            // pass ct so the AI inference itself aborts on rapid navigation, not just
            // the response on this side. pins #117.
            _showMatch = await Api.GetShowMatchAsync(TmdbId, MediaType, ct);
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
            // newer load took over — abandon silently. unfiltered catch would also
            // swallow HttpClient.Timeout TaskCanceledExceptions and leave _matchLoading
            // stuck true. when our ct isn't the cancel source, fall through so the
            // late-check below clears state normally.
            return;
        }
        if (ct.IsCancellationRequested) return;
        _matchLoading = false;
        if (!_disposed) StateHasChanged();
    }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private void PlayTrailer() => _trailerPlaying = true;

    // preserves user intent — switching tabs without prior play shouldn't autoplay;
    // if play was already on, @key on the iframe remounts and the new src autoplays.
    private void SelectTrailer(int index) => _activeTrailerIndex = index;

    // TMDb occasionally returns empty Name (older / less-curated records).
    // "Trailer N" keeps chips, iframe title, and aria-labels non-blank.
    private static string TrailerLabel(TrailerDto t, int index) =>
        string.IsNullOrWhiteSpace(t.Name) ? $"Trailer {index + 1}" : t.Name;

    private async Task ShareDetails()
    {
        if (_details is null) return;
        string text = !string.IsNullOrEmpty(_details.Tagline) ? _details.Tagline! : "Check this out on Hurrah.tv";
        // ShareService prepends the canonical production origin so the link is correct
        // regardless of whether the user is on localhost, staging.hurrah.tv, or prod
        ShareOutcome outcome = await Share.ShareOrCopyAsync(_details.Title, text, $"/details/{MediaType}/{TmdbId}");
        string? notice = outcome switch
        {
            ShareOutcome.Copied      => "Link copied",
            ShareOutcome.Unsupported => "Couldn't share — copy the URL from the address bar",
            ShareOutcome.Error       => "Couldn't share — try again",
            _                        => null // shared / cancelled: stay silent
        };
        if (notice is not null) _ = Toast.ShowAsync(notice);
    }

    private async Task SetListStatus(QueueStatus status)
    {
        if (_details == null) return;

        // snapshot the navigation identity — OnParametersSetAsync nulls _queueItem on navigation,
        // so after an await we must confirm we're still on the same title before mutating state.
        int startTmdbId = TmdbId;
        string startMediaType = MediaType;
        try
        {
            if (_queueItem != null)
            {
                QueueItem existing = _queueItem;
                if (existing.Status == status)
                    return;
                QueueItem? updated = await Api.UpdateStatusAsync(existing.Id, status);
                if (Navigated(startTmdbId, startMediaType)) return;
                if (updated != null)
                {
                    _queueItem = updated;
                    QuickActionSvc.NotifyItemUpdated(updated);
                }
                else
                {
                    existing.Status = status; // optimistic fallback
                }
            }
            else
            {
                QueueItem item = _details.ToQueueItem();
                item.Status = status;
                // idempotent post-#155: AddToQueueAsync returns the existing row on a duplicate,
                // so null here means a genuine add failure, not a conflict to recover from.
                QueueItem? added = await Api.AddToQueueAsync(item);
                if (Navigated(startTmdbId, startMediaType)) return;
                if (added == null)
                {
                    await Toast.ShowAsync("Couldn't update your list — try again");
                    return;
                }
                _queueItem = added;
                QuickActionSvc.NotifyItemUpdated(added);
            }
        }
        catch
        {
            // a network failure throws out of Update/AddToQueueAsync; without this the click
            // fails silently (Blazor swallows event-handler exceptions). Matches HomeHero.
            await Toast.ShowAsync("Couldn't update your list — try again");
            return;
        }
        if (!_disposed) StateHasChanged();
    }

    private async Task SetSentiment(int sentiment)
    {
        if (_details == null) return;

        int startTmdbId = TmdbId;
        string startMediaType = MediaType;
        try
        {
            if (_queueItem == null)
            {
                // idempotent post-#155 — null means a genuine add failure, so surface it and bail.
                QueueItem? added = await Api.AddToQueueAsync(_details.ToQueueItem());
                if (Navigated(startTmdbId, startMediaType)) return;
                if (added == null)
                {
                    await Toast.ShowAsync("Couldn't update your list — try again");
                    return;
                }
                _queueItem = added;
                // commit the add to the UI before the sentiment call — if that throws, the item
                // is still shown as added (it exists server-side) rather than silently vanishing.
                QuickActionSvc.NotifyItemUpdated(added);
                StateHasChanged();
            }

            QueueItem current = _queueItem;
            int? newSentiment = current.Sentiment == sentiment ? null : sentiment;
            QueueItem? updated = await Api.UpdateSentimentAsync(current.Id, newSentiment);
            if (Navigated(startTmdbId, startMediaType)) return;
            if (updated != null)
            {
                _queueItem = updated;
                QuickActionSvc.NotifyItemUpdated(updated);
            }
            else
            {
                current.Sentiment = newSentiment; // optimistic fallback
            }
        }
        catch
        {
            await Toast.ShowAsync("Couldn't update your list — try again");
            return;
        }
        if (!_disposed) StateHasChanged();
    }

    // true if the component was disposed or navigated to a different title while an await was in
    // flight — OnParametersSetAsync resets _queueItem on navigation, so a continuation that
    // mutates it would NRE or clobber the new title's state. Callers bail silently when true.
    private bool Navigated(int startTmdbId, string startMediaType) =>
        _disposed || TmdbId != startTmdbId || MediaType != startMediaType;

    private static bool IsRecent(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr) || !TmdbDate.TryParse(dateStr, out DateTime date)) return false;
        return (DateTime.UtcNow - date).TotalDays <= 30;
    }

    private static string FormatAirDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr) || !TmdbDate.TryParse(dateStr, out DateTime date)) return "";

        int daysAgo = (int)(DateTime.UtcNow - date).TotalDays;
        if (daysAgo < 0)
        {
            int daysUntil = -daysAgo;
            if (daysUntil == 0) return "today";
            if (daysUntil == 1) return "tomorrow";
            if (daysUntil <= 7) return $"in {daysUntil} days";
            return date.ToString("MMM d, yyyy");
        }
        if (daysAgo == 0) return "today";
        if (daysAgo == 1) return "yesterday";
        if (daysAgo <= 7) return $"{daysAgo} days ago";
        if (daysAgo <= 30) return $"{daysAgo / 7} weeks ago";
        return date.ToString("MMM d, yyyy");
    }
}
