@page "/details/{MediaType}/{TmdbId:int}"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(_details?.Title ?? "Loading...") - Hurrah.tv</PageTitle>

@if (_loading)
{
    <div class="text-center py-20">
        <div class="w-8 h-8 border-2 border-accent border-t-transparent rounded-full animate-spin mx-auto"></div>
    </div>
}
else if (_details != null)
{
    <!-- backdrop -->
    @if (!string.IsNullOrEmpty(_details.BackdropUrl()))
    {
        <div class="relative -mx-4 md:-mx-6 -mt-4 md:-mt-6 mb-4 md:mb-6 h-48 md:h-80 overflow-hidden">
            <img src="@_details.BackdropUrl("w1280")" alt="" class="w-full h-full object-cover opacity-40" />
            <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent"></div>
            <!-- back button overlaid on backdrop -->
            <button class="absolute top-3 left-3 md:top-4 md:left-4 bg-black/50 hover:bg-black/70 text-white
                           rounded-full w-10 h-10 flex items-center justify-center transition-colors backdrop-blur-sm"
                    @onclick="GoBack" title="Go back">
                <span class="icon-[heroicons--arrow-left] w-5 h-5"></span>
            </button>
        </div>
    }
    else
    {
        <!-- back button when no backdrop -->
        <button class="mb-3 text-gray-400 hover:text-white flex items-center gap-1.5 text-sm transition-colors"
                @onclick="GoBack">
            <span class="icon-[heroicons--arrow-left] w-4 h-4"></span>
            Back
        </button>
    }

    <div class="@(!string.IsNullOrEmpty(_details.BackdropUrl()) ? "-mt-24 md:-mt-32 relative z-10" : "") fade-in">
        <!-- mobile: centered poster -->
        <div class="md:hidden flex flex-col items-center mb-4">
            @if (!string.IsNullOrEmpty(_details.PosterUrl()))
            {
                <img src="@_details.PosterUrl("w342")" alt="@_details.Title"
                     class="w-32 rounded-lg shadow-2xl" />
            }
            <h1 class="text-2xl font-bold mt-3 text-center">@_details.Title</h1>
            @if (!string.IsNullOrEmpty(_details.Tagline))
            {
                <p class="text-gray-400 italic text-sm text-center mt-1">@_details.Tagline</p>
            }
        </div>

        <!-- desktop: side by side -->
        <div class="hidden md:flex gap-8">
            <div class="flex-shrink-0 w-48">
                @if (!string.IsNullOrEmpty(_details.PosterUrl()))
                {
                    <img src="@_details.PosterUrl("w500")" alt="@_details.Title"
                         class="w-full rounded-lg shadow-2xl" />
                }
            </div>
            <div class="flex-1 min-w-0">
                <h1 class="text-3xl font-bold mb-1">@_details.Title</h1>
                @if (!string.IsNullOrEmpty(_details.Tagline))
                {
                    <p class="text-gray-400 italic mb-3">@_details.Tagline</p>
                }
                @{ RenderMetadata(); }
            </div>
        </div>

        <!-- mobile: metadata below poster -->
        <div class="md:hidden">
            @{ RenderMetadata(); }
        </div>
    </div>
}
else
{
    <div class="text-center py-20 text-gray-500">Content not found.</div>
}

@{
    void RenderMetadata()
    {
        <!-- new/upcoming episode banner -->
        @if (_details!.MediaType == "tv")
        {
            @if (_details.NextEpisodeAirDate != null)
            {
                <div class="flex items-center gap-2 bg-blue-600/20 border border-blue-600/40 rounded-lg px-3 py-2 mb-3 md:mb-4">
                    <span class="icon-[heroicons--clock] w-5 h-5 text-blue-400"></span>
                    <div class="text-sm">
                        <span class="text-blue-300 font-medium">Next episode</span>
                        <span class="text-gray-300">
                            S@(_details.NextEpisodeSeason)E@(_details.NextEpisodeNumber)
                            @if (!string.IsNullOrEmpty(_details.NextEpisodeName))
                            {
                                <span>&ldquo;@_details.NextEpisodeName&rdquo;</span>
                            }
                            &mdash; @FormatAirDate(_details.NextEpisodeAirDate)
                        </span>
                    </div>
                </div>
            }
            else if (_details.LastEpisodeAirDate != null && IsRecent(_details.LastEpisodeAirDate))
            {
                <div class="flex items-center gap-2 bg-accent/20 border border-accent/40 rounded-lg px-3 py-2 mb-3 md:mb-4">
                    <span class="icon-[heroicons--sparkles] w-5 h-5 text-accent-light"></span>
                    <div class="text-sm">
                        <span class="text-accent-light font-medium">New episode</span>
                        <span class="text-gray-300">
                            S@(_details.LastEpisodeSeason)E@(_details.LastEpisodeNumber)
                            @if (!string.IsNullOrEmpty(_details.LastEpisodeName))
                            {
                                <span>&ldquo;@_details.LastEpisodeName&rdquo;</span>
                            }
                            &mdash; aired @FormatAirDate(_details.LastEpisodeAirDate)
                        </span>
                    </div>
                </div>
            }
        }

        <div class="flex flex-wrap items-center gap-2 md:gap-3 text-sm text-gray-400 mb-3 md:mb-4">
            @if (!string.IsNullOrEmpty(_details.Year))
            {
                <span>@_details.Year</span>
            }
            @if (_details.MediaType == "tv" && _details.NumberOfSeasons > 0)
            {
                <span>@_details.NumberOfSeasons season@(_details.NumberOfSeasons > 1 ? "s" : "")</span>
            }
            @if (_details.Runtime > 0)
            {
                <span>@(_details.Runtime / 60)h @(_details.Runtime % 60)m</span>
            }
            @if (_details.VoteAverage > 0)
            {
                <span class="flex items-center gap-1">
                    <span class="icon-[heroicons--star-20-solid] w-4 h-4 text-yellow-400"></span>
                    @_details.VoteAverage.ToString("F1")
                </span>
            }
            @if (!string.IsNullOrEmpty(_details.Status))
            {
                <span class="px-2 py-0.5 bg-surface-100 rounded text-xs">@_details.Status</span>
            }
            @if (_details.MediaType == "tv" && _details.LastEpisodeAirDate != null && !IsRecent(_details.LastEpisodeAirDate))
            {
                <span>Last aired @FormatAirDate(_details.LastEpisodeAirDate)</span>
            }
            @if (_details.MediaType == "movie" && !string.IsNullOrEmpty(_details.ReleaseDate) && IsRecent(_details.ReleaseDate))
            {
                <span class="text-accent-light font-medium">New release</span>
            }
        </div>

        <!-- genres -->
        @if (_details.Genres.Count > 0)
        {
            <div class="flex flex-wrap gap-2 mb-3 md:mb-4">
                @foreach (string genre in _details.Genres)
                {
                    <span class="px-2.5 py-1 bg-surface-100 rounded-full text-xs text-gray-300">@genre</span>
                }
            </div>
        }

        <!-- available on (user's subscribed services only) -->
        @if (_details.AvailableOn.Count > 0)
        {
            <div class="mb-3 md:mb-4">
                <h3 class="text-sm font-semibold text-gray-400 mb-2 uppercase tracking-wider">Streaming on</h3>
                <div class="flex flex-wrap gap-2 md:gap-3">
                    @foreach (AvailableService svc in _details.AvailableOn)
                    {
                        <div class="flex items-center gap-2 bg-surface-50 px-3 py-2 rounded-lg">
                            @if (!string.IsNullOrEmpty(svc.LogoUrl()))
                            {
                                <img src="@svc.LogoUrl("w45")" alt="@svc.ProviderName" class="w-6 h-6 rounded" />
                            }
                            <span class="text-sm">@svc.ProviderName</span>
                        </div>
                    }
                </div>
            </div>
        }

        <p class="text-gray-300 text-sm md:text-base leading-relaxed mb-4 md:mb-6">@_details.Overview</p>

        <!-- actions -->
        <div class="flex flex-wrap gap-3">
            <button class="bg-accent hover:bg-accent-light text-white font-semibold px-5 md:px-6 py-2.5 rounded-lg transition-colors flex items-center gap-2 flex-1 md:flex-none justify-center"
                    @onclick="AddToWatchlist">
                @if (_addState == "added")
                {
                    <span class="icon-[heroicons--check] w-5 h-5"></span>
                    <span>Added!</span>
                }
                else
                {
                    <span class="icon-[heroicons--plus] w-5 h-5"></span>
                    <span>Want to Watch</span>
                }
            </button>
            <button class="bg-surface-50 hover:bg-blue-600/20 hover:border-blue-600 text-gray-400 hover:text-blue-400 border border-surface-200 px-4 py-2.5 rounded-lg transition-colors flex items-center gap-2"
                    @onclick="MarkAsSeen">
                @if (_addState == "seen")
                {
                    <span class="icon-[heroicons--check] w-5 h-5"></span>
                    <span>Marked!</span>
                }
                else
                {
                    <span class="icon-[heroicons--eye] w-5 h-5"></span>
                    <span>I've Seen This</span>
                }
            </button>
            @if (!_dismissed)
            {
                <button class="bg-surface-50 hover:bg-red-600/20 hover:border-red-600 text-gray-400 hover:text-red-400 border border-surface-200 px-4 py-2.5 rounded-lg transition-colors flex items-center gap-2"
                        @onclick="DismissTitle">
                    <span class="icon-[heroicons--x-mark] w-5 h-5"></span>
                    <span class="hidden md:inline">Not interested</span>
                </button>
            }
            else
            {
                <div class="text-gray-500 text-sm flex items-center gap-2 px-4 py-2.5 fade-in">
                    <span class="icon-[heroicons--check] w-4 h-4"></span>
                    Hidden from home
                </div>
            }
        </div>

        <!-- seasons -->
        @if (_details.Seasons.Count > 0)
        {
            <div class="mt-6 md:mt-8">
                <h3 class="text-lg font-semibold mb-3">Seasons</h3>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 md:gap-3">
                    @foreach (SeasonInfo season in _details.Seasons.Where(s => s.SeasonNumber > 0))
                    {
                        <div class="bg-surface-50 rounded-lg p-3">
                            <div class="font-medium text-sm">@season.Name</div>
                            <div class="text-xs text-gray-500">@season.EpisodeCount episodes</div>
                            @if (!string.IsNullOrEmpty(season.AirDate))
                            {
                                <div class="text-xs text-gray-600">@(season.AirDate!.Length >= 4 ? season.AirDate[..4] : season.AirDate)</div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public string MediaType { get; set; } = "";
    [Parameter] public int TmdbId { get; set; }

    private ShowDetails? _details;
    private bool _loading = true;
    private string _addState = ""; // "", "added", "seen"
    private bool _dismissed;
    private int _lastTmdbId;
    private string _lastMediaType = "";

    protected override async Task OnParametersSetAsync()
    {
        if (_lastTmdbId == TmdbId && _lastMediaType == MediaType) return;
        _lastTmdbId = TmdbId;
        _lastMediaType = MediaType;
        _addState = "";
        _dismissed = false;
        _loading = true;
        _details = await Api.GetDetailsAsync(TmdbId, MediaType);
        _loading = false;
    }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private async Task DismissTitle()
    {
        if (_details == null) return;
        await Api.DismissAsync(_details.TmdbId);
        _dismissed = true;
    }

    private async Task AddToWatchlist()
    {
        if (_details == null || _addState != "") return;

        QueueItem? added = await Api.AddToQueueAsync(_details.ToQueueItem());
        if (added != null)
        {
            _addState = "added";
            StateHasChanged();
        }
    }

    private async Task MarkAsSeen()
    {
        if (_details == null || _addState != "") return;

        QueueItem? item = await Api.MarkAsSeenAsync(_details);
        if (item != null)
        {
            _addState = "seen";
            StateHasChanged();
        }
    }

    private static bool IsRecent(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr) || !DateTime.TryParse(dateStr, out DateTime date)) return false;
        return (DateTime.UtcNow - date).TotalDays <= 30;
    }

    private static string FormatAirDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr) || !DateTime.TryParse(dateStr, out DateTime date)) return "";

        int daysAgo = (int)(DateTime.UtcNow - date).TotalDays;
        if (daysAgo < 0)
        {
            int daysUntil = -daysAgo;
            if (daysUntil == 0) return "today";
            if (daysUntil == 1) return "tomorrow";
            if (daysUntil <= 7) return $"in {daysUntil} days";
            return date.ToString("MMM d, yyyy");
        }
        if (daysAgo == 0) return "today";
        if (daysAgo == 1) return "yesterday";
        if (daysAgo <= 7) return $"{daysAgo} days ago";
        if (daysAgo <= 30) return $"{daysAgo / 7} weeks ago";
        return date.ToString("MMM d, yyyy");
    }
}
