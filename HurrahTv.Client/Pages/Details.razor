@page "/details/{MediaType}/{TmdbId:int}"
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>@(_details?.Title ?? "Loading...") - Hurrah.tv</PageTitle>

@if (_loading)
{
    <div class="text-center py-20">
        <div class="w-8 h-8 border-2 border-accent border-t-transparent rounded-full animate-spin mx-auto"></div>
    </div>
}
else if (_details != null)
{
    <!-- backdrop -->
    @if (!string.IsNullOrEmpty(_details.BackdropUrl()))
    {
        <div class="relative -mx-6 -mt-6 mb-6 h-64 md:h-80 overflow-hidden">
            <img src="@_details.BackdropUrl("w1280")" alt="" class="w-full h-full object-cover opacity-40" />
            <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent"></div>
        </div>
    }

    <div class="flex flex-col md:flex-row gap-8 fade-in @(!string.IsNullOrEmpty(_details.BackdropUrl()) ? "-mt-32 relative z-10" : "")">
        <!-- poster -->
        <div class="flex-shrink-0 w-48 mx-auto md:mx-0">
            @if (!string.IsNullOrEmpty(_details.PosterUrl()))
            {
                <img src="@_details.PosterUrl("w500")" alt="@_details.Title"
                     class="w-full rounded-lg shadow-2xl" />
            }
        </div>

        <!-- info -->
        <div class="flex-1 min-w-0">
            <h1 class="text-3xl font-bold mb-1">@_details.Title</h1>

            @if (!string.IsNullOrEmpty(_details.Tagline))
            {
                <p class="text-gray-400 italic mb-3">@_details.Tagline</p>
            }

            <div class="flex flex-wrap items-center gap-3 text-sm text-gray-400 mb-4">
                @if (!string.IsNullOrEmpty(_details.Year))
                {
                    <span>@_details.Year</span>
                }
                @if (_details.MediaType == "tv" && _details.NumberOfSeasons > 0)
                {
                    <span>@_details.NumberOfSeasons season@(_details.NumberOfSeasons > 1 ? "s" : "")</span>
                }
                @if (_details.Runtime > 0)
                {
                    <span>@(_details.Runtime / 60)h @(_details.Runtime % 60)m</span>
                }
                @if (_details.VoteAverage > 0)
                {
                    <span class="flex items-center gap-1">
                        <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                        @_details.VoteAverage.ToString("F1")
                    </span>
                }
                @if (!string.IsNullOrEmpty(_details.Status))
                {
                    <span class="px-2 py-0.5 bg-surface-100 rounded text-xs">@_details.Status</span>
                }
            </div>

            <!-- genres -->
            @if (_details.Genres.Count > 0)
            {
                <div class="flex flex-wrap gap-2 mb-4">
                    @foreach (string genre in _details.Genres)
                    {
                        <span class="px-3 py-1 bg-surface-100 rounded-full text-xs text-gray-300">@genre</span>
                    }
                </div>
            }

            <!-- available on -->
            @if (_details.AvailableOn.Count > 0)
            {
                <div class="mb-4">
                    <h3 class="text-sm font-semibold text-gray-400 mb-2 uppercase tracking-wider">Available on</h3>
                    <div class="flex flex-wrap gap-3">
                        @foreach (AvailableService svc in _details.AvailableOn.Where(s => s.Type == "flatrate"))
                        {
                            <div class="flex items-center gap-2 bg-surface-50 px-3 py-2 rounded-lg">
                                @if (!string.IsNullOrEmpty(svc.LogoUrl()))
                                {
                                    <img src="@svc.LogoUrl("w45")" alt="@svc.ProviderName" class="w-6 h-6 rounded" />
                                }
                                <span class="text-sm">@svc.ProviderName</span>
                            </div>
                        }
                        @foreach (AvailableService svc in _details.AvailableOn.Where(s => s.Type != "flatrate"))
                        {
                            <div class="flex items-center gap-2 bg-surface-50 px-3 py-2 rounded-lg opacity-60">
                                @if (!string.IsNullOrEmpty(svc.LogoUrl()))
                                {
                                    <img src="@svc.LogoUrl("w45")" alt="@svc.ProviderName" class="w-6 h-6 rounded" />
                                }
                                <span class="text-sm">@svc.ProviderName</span>
                                <span class="text-xs text-gray-500">(@svc.Type)</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <p class="text-gray-300 leading-relaxed mb-6">@_details.Overview</p>

            <!-- actions -->
            <div class="flex gap-3">
                <button class="bg-accent hover:bg-accent-light text-white font-semibold px-6 py-2.5 rounded-lg transition-colors flex items-center gap-2"
                        @onclick="AddToQueue">
                    @if (_addedToQueue)
                    {
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        <span>Added!</span>
                    }
                    else
                    {
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        <span>Add to Queue</span>
                    }
                </button>
                <button class="bg-surface-50 hover:bg-surface-100 text-gray-300 px-4 py-2.5 rounded-lg transition-colors"
                        @onclick="GoBack">
                    Back
                </button>
            </div>

            <!-- seasons -->
            @if (_details.Seasons.Count > 0)
            {
                <div class="mt-8">
                    <h3 class="text-lg font-semibold mb-3">Seasons</h3>
                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
                        @foreach (SeasonInfo season in _details.Seasons.Where(s => s.SeasonNumber > 0))
                        {
                            <div class="bg-surface-50 rounded-lg p-3">
                                <div class="font-medium text-sm">@season.Name</div>
                                <div class="text-xs text-gray-500">@season.EpisodeCount episodes</div>
                                @if (!string.IsNullOrEmpty(season.AirDate))
                                {
                                    <div class="text-xs text-gray-600">@season.AirDate[..4]</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="text-center py-20 text-gray-500">Content not found.</div>
}

@code {
    [Parameter] public string MediaType { get; set; } = "";
    [Parameter] public int TmdbId { get; set; }

    private ShowDetails? _details;
    private bool _loading = true;
    private bool _addedToQueue;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _details = await Api.GetDetailsAsync(TmdbId, MediaType);
        _loading = false;
    }

    private void GoBack() => Nav.NavigateTo("/");

    private async Task AddToQueue()
    {
        if (_details == null || _addedToQueue) return;

        string serviceIds = System.Text.Json.JsonSerializer.Serialize(
            _details.AvailableOn.Select(s => s.ProviderId).ToList());

        QueueItem item = new()
        {
            TmdbId = _details.TmdbId,
            MediaType = _details.MediaType,
            Title = _details.Title,
            PosterPath = _details.PosterPath,
            AvailableOnJson = serviceIds,
        };

        QueueItem? added = await Api.AddToQueueAsync(item);
        if (added != null)
        {
            _addedToQueue = true;
            StateHasChanged();
        }
    }
}
