@page "/"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject QuickActionService QuickActionSvc
@inject MediaFilterService MediaFilter

<PageTitle>Hurrah.tv - Your Streaming, Curated</PageTitle>

@if (!_servicesLoaded)
{
    <div class="text-center py-20">
        <div class="w-8 h-8 border-2 border-accent border-t-transparent rounded-full animate-spin mx-auto"></div>
    </div>
}
else if (!_onboardingComplete)
{
    <div class="max-w-2xl mx-auto py-8 md:py-12 fade-in">
        <h1 class="text-3xl md:text-4xl font-bold mb-2 text-center">Welcome to <span class="text-accent">hurrah.tv</span></h1>

        <!-- step indicator -->
        <div class="flex items-center justify-center gap-2 mb-6 md:mb-8">
            @for (int i = 1; i <= 3; i++)
            {
                int step = i;
                <div class="flex items-center gap-2">
                    <div class="@($"w-7 h-7 rounded-full flex items-center justify-center text-xs font-semibold transition-colors {(step <= _onboardingStep ? "bg-accent text-white" : "bg-surface-200 text-gray-500")}")">
                        @step
                    </div>
                    @if (step < 3)
                    {
                        <div class="w-8 h-0.5 @(step < _onboardingStep ? "bg-accent" : "bg-surface-200")"></div>
                    }
                </div>
            }
        </div>

        @if (_onboardingStep == 1)
        {
            <!-- step 1: streaming services -->
            <div class="text-center">
                <p class="text-gray-400 mb-6 text-base md:text-lg">Which streaming services do you have?</p>
                <ServicePicker @bind-SelectedIds="_pendingServices" />
                <button class="mt-6 bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-lg transition-colors disabled:opacity-40 w-full md:w-auto"
                        disabled="@(_pendingServices.Count == 0)"
                        @onclick="OnboardingNext">
                    Next
                </button>
            </div>
        }
        else if (_onboardingStep == 2)
        {
            <!-- step 2: genres -->
            <div class="text-center">
                <p class="text-gray-400 mb-6 text-base md:text-lg">What genres do you enjoy?</p>
                <GenrePicker @bind-SelectedIds="_pendingGenres" />
                <div class="flex gap-3 justify-center mt-6">
                    <button class="border border-surface-200 text-gray-400 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors"
                            @onclick="OnboardingBack">
                        Back
                    </button>
                    <button class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-lg transition-colors disabled:opacity-40"
                            disabled="@(_pendingGenres.Count == 0)"
                            @onclick="OnboardingNext">
                        Next
                    </button>
                </div>
            </div>
        }
        else if (_onboardingStep == 3)
        {
            <!-- step 3: pick shows -->
            <div>
                <p class="text-gray-400 mb-6 text-base md:text-lg text-center">Pick a few shows you watch or have watched — this powers your recommendations.</p>
                <ShowPicker SelectionsChanged="OnShowSelectionsChanged" />
                <div class="flex gap-3 justify-center mt-6">
                    <button class="border border-surface-200 text-gray-400 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors"
                            @onclick="OnboardingBack">
                        Back
                    </button>
                    <button class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-lg transition-colors disabled:opacity-40"
                            disabled="@(_pendingShows.Count < 3)"
                            @onclick="FinishOnboarding">
                        Get Started
                    </button>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="fade-in">
        <!-- My Watchlist section — header with chips + all three rows grouped together -->
        @{
            // use pre-filter flags so the section (and its chips) stays visible
            // even when the active status filter produces zero results
            bool hasWatchlistContent =
                (MediaFilter.MediaType != "movie" && _hasTvWatchlistContent)
                || (MediaFilter.MediaType != "tv" && _hasMovieWatchlistContent);
        }
        @if (hasWatchlistContent)
        {
            <div class="mb-8">
                <!-- section header — matches Curated for You pattern -->
                <div class="mb-4">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="icon-[heroicons--rectangle-stack] w-5 h-5 text-accent"></span>
                        <h2 class="text-lg md:text-xl font-bold text-white">My Watchlist</h2>
                    </div>
                    <div class="flex items-center justify-between mt-3 gap-2">
                        @if (MediaFilter.MediaType != "movie")
                        {
                            <div class="flex gap-0.5 bg-surface-100 rounded-lg p-0.5">
                                @foreach (QueueStatus status in new[] { QueueStatus.Watching, QueueStatus.WantToWatch, QueueStatus.Finished })
                                {
                                    bool active = IsStatusActive(status);
                                    string chipLabel = BadgeHelpers.StatusShortLabel(status);
                                    string chipIcon = BadgeHelpers.StatusIcon(status);
                                    <button class="@(active ? "bg-surface-200 text-white font-medium" : "text-gray-500 hover:text-white") flex items-center gap-1 px-2 md:px-3 py-1 rounded-md text-xs transition-all"
                                            @onclick="() => ToggleStatusFilter(status)">
                                        <span class="@chipIcon w-3 h-3"></span>
                                        <span class="hidden md:inline">@chipLabel</span>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <div></div>
                        }
                        <!-- sort control — same level as filter, saved to UserSettings -->
                        <div class="flex gap-0.5 bg-surface-100 rounded-lg p-0.5">
                            @foreach (string mode in new[] { "date", "sentiment", "queue" })
                            {
                                string modeLabel = mode switch { "date" => "Date", "sentiment" => "Liked", _ => "List" };
                                @if (_watchlistSort == mode)
                                {
                                    <button class="bg-surface-200 text-white font-semibold text-xs px-3 py-1 rounded-md"
                                            @onclick="() => OnWatchlistSortChanged(mode)">@modeLabel</button>
                                }
                                else
                                {
                                    <button class="text-gray-500 hover:text-white text-xs px-3 py-1 rounded-md transition-colors"
                                            @onclick="() => OnWatchlistSortChanged(mode)">@modeLabel</button>
                                }
                            }
                        </div>
                    </div>
                </div>

                @if (MediaFilter.MediaType != "movie")
                {
                    @if (_watchingItems.Count > 0)
                    {
                        <WatchlistRow Title="Continue Watching" Items="_watchingItems" ShowAirDates="true" RowMode="watching"
                                      ShowMarkWatched="true" OnMarkWatched="HandleMarkWatched" />
                    }
                    @if (_upcomingItems.Count > 0)
                    {
                        <WatchlistRow Title="Upcoming Episodes" Subtitle="Airing soon" Items="_upcomingItems" ShowAirDates="true" RowMode="upcoming"
                                      ShowMarkWatched="false" />
                    }
                }

                @if (MediaFilter.MediaType != "tv" && _wantToWatchMovies.Count > 0
                     && (MediaFilter.MediaType == "movie" || _settings.ShowWantToWatch))
                {
                    <WatchlistRow Title="Movies to Watch" Items="_wantToWatchMovies" ShowAirDates="false"
                                  ShowMarkWatched="false" ShowStatusBadge="false" />
                }
            </div>
        }

        <!-- AI-curated section -->
        @if (_curatedItems.Count > 0 || _aiLoading)
        {
            <CuratedSection Items="_curatedItems" Loading="_aiLoading" MediaType="@MediaFilter.MediaType" />
        }
        @if (!string.IsNullOrEmpty(_aiError))
        {
            <div class="flex items-center justify-between mb-6 px-4 py-3 bg-surface-50 border border-surface-200 rounded-lg">
                <div class="flex items-center gap-2">
                    <span class="icon-[heroicons--sparkles] w-5 h-5 text-accent flex-shrink-0"></span>
                    <span class="text-sm text-gray-400">@_aiError</span>
                </div>
                <button class="text-xs text-accent hover:text-accent-light transition-colors flex-shrink-0 ml-4"
                        @onclick="RefreshCuration">
                    Retry
                </button>
            </div>
        }

        <!-- TV-only rows (hidden in Movies mode) -->
        @if (MediaFilter.MediaType != "movie")
        {
            <ContentRow Title="New This Season" Subtitle="Recently aired" LoadData="LoadNewTv" NewEpisodeTmdbIds="_newEpisodeTmdbIds" HideIfFewer="4" />
            <ContentRow Title="Trending TV Shows" Subtitle="Popular on your services" LoadData="LoadTrendingTv" NewEpisodeTmdbIds="_newEpisodeTmdbIds" HideIfFewer="4" />
        }

        <!-- Movie-only rows (hidden in TV Shows mode) -->
        @if (MediaFilter.MediaType != "tv")
        {
            <ContentRow Title="New Releases" Subtitle="Recently released" LoadData="LoadNewMovies" HideIfFewer="4" />
            <ContentRow Title="Trending Movies" Subtitle="Popular on your services" LoadData="LoadTrendingMovies" HideIfFewer="4" />
        }

        <!-- "because you loved X" rows — seeded from matching media type -->
        @foreach (QueueItem seed in _recSeeds)
        {
            <ContentRow Title="@($"Because You Loved {seed.Title}")"
                        LoadData="@(() => Api.GetRecommendationsAsync(seed.TmdbId, seed.MediaType))"
                        NewEpisodeTmdbIds="_newEpisodeTmdbIds" />
        }
    </div>
}

@code {
    private List<int> _userServices = [];
    private List<int> _pendingServices = [];
    private List<int> _pendingGenres = [];
    private Dictionary<int, (SearchResult Result, QueueStatus Status, int? Sentiment)> _pendingShows = [];
    private int _onboardingStep = 1;
    private bool _servicesLoaded;
    private bool _onboardingComplete;

    // watchlist rows
    private List<QueueItem> _watchingItems = [];
    private List<QueueItem> _upcomingItems = [];
    private List<QueueItem> _wantToWatchMovies = [];
    // pre-filter existence flags — keep section visible even when chips filter everything out
    private bool _hasTvWatchlistContent;
    private bool _hasMovieWatchlistContent;
    private HashSet<int> _newEpisodeTmdbIds = [];
    private List<QueueItem> _recSeeds = [];
    private int[] _queuedTmdbIds = [];
    private HashSet<(int TmdbId, int Season, int Episode)> _watchedSet = [];
    private string _watchlistSort = "date"; // single sort for all My Watchlist rows, synced with UserSettings
    private UserSettings _settings = new();

    // AI curation
    private List<CuratedItem> _curatedItems = [];
    private bool _aiLoading;
    private string? _aiError;

    protected override async Task OnInitializedAsync()
    {
        QuickActionSvc.OnChanged += OnQuickActionChanged;
        MediaFilter.OnChanged += OnMediaFilterChanged;
        _userServices = await Api.GetUserServicesAsync();
        _servicesLoaded = true;
        _onboardingComplete = _userServices.Count > 0;

        if (_onboardingComplete)
        {
            _settings = await Api.GetUserSettingsAsync();
            _watchlistSort = _settings.WatchlistSort;
            await LoadWatchlistData();
        }
    }

    private async Task OnboardingNext()
    {
        if (_onboardingStep == 1)
        {
            // save services immediately so step 3 can use existing discovery endpoints
            await Api.SetUserServicesAsync(_pendingServices);
            _userServices = _pendingServices;
        }
        else if (_onboardingStep == 2)
        {
            // save genres immediately so step 3 show picker gets genre-filtered results
            await Api.SetUserGenresAsync(_pendingGenres);
        }
        _onboardingStep++;
    }

    private void OnboardingBack() => _onboardingStep--;

    private void OnShowSelectionsChanged(Dictionary<int, (SearchResult Result, QueueStatus Status, int? Sentiment)> selections)
    {
        _pendingShows = selections;
    }

    private async Task FinishOnboarding()
    {
        // add all selected shows to queue in parallel
        await Task.WhenAll(_pendingShows.Values.Select(async entry =>
        {
            QueueItem item = entry.Result.ToQueueItem();
            item.Status = entry.Status;
            item.Sentiment = entry.Sentiment;
            await Api.AddToQueueAsync(item);
        }));

        _onboardingComplete = true;
        await LoadWatchlistData();
    }

    private async Task LoadWatchlistData()
    {
        QueueResponse queueResponse = await Api.GetQueueResponseAsync();
        List<QueueItem> allItems = queueResponse.Items;

        // build watched set for O(1) lookups during render
        _watchedSet = [.. queueResponse.WatchedEpisodes.Select(w => (w.TmdbId, w.Season, w.Episode))];
        _queuedTmdbIds = [.. allItems.Select(i => i.TmdbId).Distinct()];

        // stamp IsLatestEpisodeWatched — exact match on season/episode (API forces refresh when these are null)
        foreach (QueueItem item in allItems)
        {
            if (item.LatestEpisodeSeason.HasValue && item.LatestEpisodeNumber.HasValue)
                item.IsLatestEpisodeWatched = _watchedSet.Contains((item.TmdbId, item.LatestEpisodeSeason.Value, item.LatestEpisodeNumber.Value));
        }

        _recSeeds = PickRecSeeds(allItems, 3, MediaFilter.MediaType);

        ApplyWatchlistFilters(allItems);

        _newEpisodeTmdbIds = [.. _watchingItems.Concat(_upcomingItems).Select(i => i.TmdbId)];

        StateHasChanged();

        // load AI curation (awaited so StateHasChanged works properly)
        await LoadAICuration();
    }

    private bool IsStatusActive(QueueStatus status) => status switch
    {
        QueueStatus.Watching    => _settings.ShowWatching,
        QueueStatus.WantToWatch => _settings.ShowWantToWatch,
        QueueStatus.Finished    => _settings.ShowFinished,
        _                       => false
    };

    private async Task ToggleStatusFilter(QueueStatus status)
    {
        // count currently active chips — prevent turning off the last one
        int activeCount = (_settings.ShowWatching ? 1 : 0) + (_settings.ShowWantToWatch ? 1 : 0) + (_settings.ShowFinished ? 1 : 0);
        bool current = IsStatusActive(status);
        if (current && activeCount == 1) return; // last active chip — snap back

        switch (status)
        {
            case QueueStatus.Watching:    _settings.ShowWatching    = !current; break;
            case QueueStatus.WantToWatch: _settings.ShowWantToWatch = !current; break;
            case QueueStatus.Finished:    _settings.ShowFinished    = !current; break;
        }

        await Api.SetUserSettingsAsync(_settings);
        // reload to re-apply filter (uses cached queue data from last load)
        await ReloadWatchlist();
    }

    private void ApplyWatchlistFilters(List<QueueItem> allItems)
    {
        DateTime now = DateTime.Now;
        DateTime sevenDaysAgo = now.AddDays(-7);
        DateTime fourteenDaysAhead = now.AddDays(14);

        // pre-filter existence: does the user have any TV/movie watchlist content at all?
        // used by the section header so it stays visible even when chips filter everything out
        _hasTvWatchlistContent = allItems.Any(i => i.MediaType == "tv" && i.Status != QueueStatus.NotForMe);
        _hasMovieWatchlistContent = allItems.Any(i => i.MediaType == "movie" && i.Status == QueueStatus.WantToWatch);

        // continue watching: Watching always shows; WantToWatch/Finished need date activity
        // Finished: recently aired only (7d window) — upcoming Finished go to Upcoming row
        // WantToWatch: recently aired OR upcoming (same ranges as Upcoming row)
        IEnumerable<QueueItem> watching = allItems
            .Where(i => IsStatusActive(i.Status)
                && i.Status != QueueStatus.NotForMe
                && !i.IsLatestEpisodeWatched
                && (MediaFilter.MediaType == "all" || i.MediaType == MediaFilter.MediaType)
                && (i.Status == QueueStatus.Watching
                    || (i.LatestEpisodeDate.HasValue && i.LatestEpisodeDate.Value >= sevenDaysAgo)
                    || (i.Status != QueueStatus.Finished && i.NextEpisodeDate.HasValue && i.NextEpisodeDate.Value <= fourteenDaysAhead)));

        _watchingItems = SortWatching(watching);

        IEnumerable<QueueItem> upcoming = allItems
            .Where(i => i.MediaType == "tv"
                && i.Status != QueueStatus.NotForMe
                && IsStatusActive(i.Status)
                && ((i.LatestEpisodeDate.HasValue && i.LatestEpisodeDate.Value >= sevenDaysAgo)
                    || (i.NextEpisodeDate.HasValue && i.NextEpisodeDate.Value <= fourteenDaysAhead))
                && (i.Status != QueueStatus.Finished || i.NextEpisodeDate.HasValue));

        _upcomingItems = SortUpcoming(upcoming);

        _wantToWatchMovies = SortMovies(allItems.Where(i => i.MediaType == "movie" && i.Status == QueueStatus.WantToWatch));
    }

    private async Task RefreshCuration()
    {
        _aiError = null;
        _curatedItems = [];
        _aiLoading = true;
        StateHasChanged();

        try
        {
            CurationResponse? fresh = await Api.RefreshCurationAsync();
            _aiLoading = false;
            if (fresh?.AiEnabled == true && fresh.Rows.Count > 0)
            {
                _curatedItems = [.. fresh.Rows
                    .SelectMany(row => row.Results
                        .Select(r => new CuratedItem
                        {
                            Result = r,
                            Reason = row.Reasons.TryGetValue(r.TmdbId, out string? reason) ? reason : ""
                        }))];
            }
            else
            {
                _aiError = fresh == null ? "Failed to reach curation API" : $"Not enough candidates ({fresh.CandidateCount})";
            }
        }
        catch (Exception ex)
        {
            _aiLoading = false;
            _aiError = $"Exception: {ex.Message}";
        }
        StateHasChanged();
    }

    private async Task LoadAICuration()
    {
        try
        {
            _aiLoading = true;
            StateHasChanged();

            CurationResponse? curation = await Api.GetCuratedRowsAsync();
            _aiLoading = false;

            if (curation == null)
            {
                _aiError = "Failed to reach curation API";
                StateHasChanged();
                return;
            }

            if (!curation.AiEnabled)
            {
                _aiError = $"AI not enabled (candidates: {curation.CandidateCount})";
                StateHasChanged();
                return;
            }

            _aiError = curation.Error;

            // flatten into a single ranked list
            _curatedItems = [];
            foreach (CuratedRowResponse row in curation.Rows)
            {
                foreach (SearchResult result in row.Results)
                {
                    string reason = row.Reasons.TryGetValue(result.TmdbId, out string? r) ? r : "";
                    _curatedItems.Add(new CuratedItem { Result = result, Reason = reason });
                }
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {

            _aiLoading = false;
            _aiError = $"Exception: {ex.Message}";
            StateHasChanged();
        }
    }

    // content row data loaders — pass queued IDs so discovered items exclude already-queued shows
    private Task<List<SearchResult>> LoadTrendingTv() => Api.ForYouAsync("tv", _queuedTmdbIds);
    private Task<List<SearchResult>> LoadNewTv() => Api.NewOnServicesAsync("tv", _queuedTmdbIds);
    private Task<List<SearchResult>> LoadTrendingMovies() => Api.ForYouAsync("movie", _queuedTmdbIds);
    private Task<List<SearchResult>> LoadNewMovies() => Api.NewOnServicesAsync("movie", _queuedTmdbIds);

    // Favorite(3)→2, Liked(2)→1, null→0, Disliked(1)→-1 so null sorts between Liked and Disliked
    private static int SentimentSortKey(int? sentiment) => sentiment switch
    {
        SentimentLevel.Favorite => 2,
        SentimentLevel.Up       => 1,
        null                    => 0,
        _                       => -1
    };

    // Watching→0, WantToWatch→1, Finished→2 (status list order)
    private static int StatusSortKey(QueueStatus status) => status switch
    {
        QueueStatus.Watching    => 0,
        QueueStatus.WantToWatch => 1,
        QueueStatus.Finished    => 2,
        _                       => 3
    };

    private static List<QueueItem> PickRecSeeds(List<QueueItem> allItems, int count, string mediaType = "all")
    {
        // prefer items with positive sentiment, fallback to Finished; filter by active media type
        List<QueueItem> candidates = allItems
            .Where(i => (mediaType == "all" || i.MediaType == mediaType)
                && (i.Sentiment >= SentimentLevel.Up || i.Status == QueueStatus.Finished))
            .ToList();

        if (candidates.Count <= count) return candidates;

        DateTime recentCutoff = DateTime.UtcNow.AddDays(-30);
        Random rng = new();
        List<(QueueItem item, double weight)> weighted = candidates
            .Select(i => (i, weight: (i.AddedAt >= recentCutoff ? 3.0 : 1.0) * rng.NextDouble()))
            .OrderByDescending(x => x.weight)
            .ToList();

        return weighted.Take(count).Select(x => x.item).ToList();
    }

    private async Task ReloadWatchlist()
    {
        QueueResponse queueResponse = await Api.GetQueueResponseAsync();
        List<QueueItem> allItems = queueResponse.Items;

        _watchedSet = [.. queueResponse.WatchedEpisodes.Select(w => (w.TmdbId, w.Season, w.Episode))];
        foreach (QueueItem item in allItems)
        {
            if (item.LatestEpisodeSeason.HasValue && item.LatestEpisodeNumber.HasValue)
                item.IsLatestEpisodeWatched = _watchedSet.Contains((item.TmdbId, item.LatestEpisodeSeason.Value, item.LatestEpisodeNumber.Value));
        }

        _recSeeds = PickRecSeeds(allItems, 3, MediaFilter.MediaType);
        ApplyWatchlistFilters(allItems);
        _newEpisodeTmdbIds = [.. _watchingItems.Concat(_upcomingItems).Select(i => i.TmdbId)];
        StateHasChanged();
    }

    private async Task HandleMarkWatched(QueueItem item)
    {
        if (!item.LatestEpisodeSeason.HasValue || !item.LatestEpisodeNumber.HasValue) return;

        if (item.IsLatestEpisodeWatched)
        {
            await Api.UnmarkEpisodeWatchedAsync(item.TmdbId, item.LatestEpisodeSeason.Value, item.LatestEpisodeNumber.Value);
            item.IsLatestEpisodeWatched = false;
        }
        else
        {
            await Api.MarkEpisodeWatchedAsync(item.TmdbId, item.LatestEpisodeSeason.Value, item.LatestEpisodeNumber.Value);
            item.IsLatestEpisodeWatched = true;
            // optimistically remove from Continue Watching
            _watchingItems = [.. _watchingItems.Where(i => i.Id != item.Id)];
        }
        StateHasChanged();
    }

    private async Task OnWatchlistSortChanged(string mode)
    {
        _watchlistSort = mode;
        _settings.WatchlistSort = mode;
        _ = Api.SetUserSettingsAsync(_settings);
        _watchingItems = SortWatching(_watchingItems);
        _upcomingItems = SortUpcoming(_upcomingItems);
        _wantToWatchMovies = SortMovies(_wantToWatchMovies);
        StateHasChanged();
    }

    private List<QueueItem> SortWatching(IEnumerable<QueueItem> items) => _watchlistSort switch
    {
        "sentiment" => [.. items.OrderByDescending(i => SentimentSortKey(i.Sentiment)).ThenByDescending(i => i.LatestEpisodeDate ?? DateTime.MinValue)],
        "queue"     => [.. items.OrderBy(i => StatusSortKey(i.Status)).ThenByDescending(i => i.LatestEpisodeDate ?? DateTime.MinValue)],
        _           => [.. items.OrderByDescending(i => i.HasEpisodeThisMonth ? 1 : 0).ThenByDescending(i => i.LatestEpisodeDate ?? DateTime.MinValue).ThenBy(i => i.Position)]
    };

    private List<QueueItem> SortUpcoming(IEnumerable<QueueItem> items) => _watchlistSort switch
    {
        "sentiment" => [.. items.OrderByDescending(i => SentimentSortKey(i.Sentiment)).ThenBy(i => i.NextEpisodeDate ?? DateTime.MaxValue)],
        "queue"     => [.. items.OrderBy(i => StatusSortKey(i.Status)).ThenBy(i => i.NextEpisodeDate ?? DateTime.MaxValue)],
        _           => [.. items.OrderBy(i => i.NextEpisodeDate ?? DateTime.MaxValue)]
    };

    private List<QueueItem> SortMovies(IEnumerable<QueueItem> items) => _watchlistSort switch
    {
        "sentiment" => [.. items.OrderByDescending(i => SentimentSortKey(i.Sentiment)).ThenByDescending(i => i.AddedAt)],
        _           => [.. items.OrderByDescending(i => i.AddedAt)]
    };

    private void OnQuickActionChanged() => _ = InvokeAsync(ReloadWatchlist);

    private void OnMediaFilterChanged() => _ = InvokeAsync(async () =>
    {
        // re-seed rec rows for correct media type, re-apply watchlist filters, re-render
        await ReloadWatchlist();
    });

    public void Dispose()
    {
        QuickActionSvc.OnChanged -= OnQuickActionChanged;
        MediaFilter.OnChanged -= OnMediaFilterChanged;
    }
}
