@page "/"
@attribute [Authorize]
@inject ApiClient Api

<PageTitle>Hurrah.tv - Your Streaming Queue</PageTitle>

@if (!_servicesLoaded)
{
    <div class="text-center py-20">
        <div class="w-8 h-8 border-2 border-accent border-t-transparent rounded-full animate-spin mx-auto"></div>
    </div>
}
else if (!_onboardingComplete)
{
    <!-- onboarding: pick your services -->
    <div class="max-w-lg mx-auto text-center py-8 md:py-12 fade-in">
        <h1 class="text-3xl md:text-4xl font-bold mb-2">Welcome to <span class="text-accent">hurrah.tv</span></h1>
        <p class="text-gray-400 mb-6 md:mb-8 text-base md:text-lg">One queue for everything you watch. Pick your streaming services to get started.</p>

        <ServicePicker @bind-SelectedIds="_pendingServices" />

        <button class="mt-6 md:mt-8 bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-lg transition-colors disabled:opacity-40 w-full md:w-auto"
                disabled="@(_pendingServices.Count == 0)"
                @onclick="SaveServices">
            Get Started
        </button>
    </div>
}
else
{
    <!-- content -->
    <div class="fade-in">
        <!-- header row: toggle + search link -->
        <div class="flex items-center justify-between mb-6 md:mb-8">
            <div class="flex bg-surface-50 rounded-full p-1">
                <button class="@(_activeTab == "tv" ? "bg-accent text-white" : "text-gray-400 hover:text-white") px-4 md:px-5 py-1.5 rounded-full text-sm font-medium transition-all"
                        @onclick="@(() => _activeTab = "tv")">
                    TV Shows
                </button>
                <button class="@(_activeTab == "movie" ? "bg-accent text-white" : "text-gray-400 hover:text-white") px-4 md:px-5 py-1.5 rounded-full text-sm font-medium transition-all"
                        @onclick="@(() => _activeTab = "movie")">
                    Movies
                </button>
            </div>
            <a href="/search" class="text-accent text-sm hover:text-accent-light">Search all &rarr;</a>
        </div>

        <!-- TV Shows tab -->
        @if (_activeTab == "tv")
        {
            <div class="space-y-6 md:space-y-8 fade-in">
                <section>
                    <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">New This Season</h3>
                    <PosterGrid Results="_newTv" Loading="_loading" EmptyMessage="No new shows found" />
                </section>

                <section>
                    <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Popular Shows</h3>
                    <PosterGrid Results="_trendingTv" Loading="_loading" EmptyMessage="No popular shows" />
                </section>
            </div>
        }

        <!-- Movies tab -->
        @if (_activeTab == "movie")
        {
            <div class="space-y-6 md:space-y-8 fade-in">
                <section>
                    <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">New Releases</h3>
                    <PosterGrid Results="_newMovies" Loading="_loading" EmptyMessage="No new movies found" />
                </section>

                <section>
                    <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Popular Movies</h3>
                    <PosterGrid Results="_trendingMovies" Loading="_loading" EmptyMessage="No popular movies" />
                </section>
            </div>
        }
    </div>
}

@code {
    private List<int> _userServices = [];
    private List<int> _pendingServices = [];
    private bool _servicesLoaded;
    private bool _onboardingComplete;
    private string _activeTab = "tv";

    private List<SearchResult> _newTv = [];
    private List<SearchResult> _trendingTv = [];
    private List<SearchResult> _newMovies = [];
    private List<SearchResult> _trendingMovies = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _userServices = await Api.GetUserServicesAsync();
        _servicesLoaded = true;
        _onboardingComplete = _userServices.Count > 0;

        if (_onboardingComplete)
            await LoadContent();
    }

    private async Task SaveServices()
    {
        _userServices = _pendingServices;
        await Api.SetUserServicesAsync(_userServices);
        _onboardingComplete = true;
        await LoadContent();
    }

    private async Task LoadContent()
    {
        _loading = true;
        StateHasChanged();

        Task<List<SearchResult>> newTvTask = Api.NewOnServicesAsync("tv");
        Task<List<SearchResult>> trendingTvTask = Api.ForYouAsync("tv");
        Task<List<SearchResult>> newMoviesTask = Api.NewOnServicesAsync("movie");
        Task<List<SearchResult>> trendingMoviesTask = Api.ForYouAsync("movie");
        await Task.WhenAll(newTvTask, trendingTvTask, newMoviesTask, trendingMoviesTask);

        _newTv = newTvTask.Result;
        _trendingTv = trendingTvTask.Result;
        _newMovies = newMoviesTask.Result;
        _trendingMovies = trendingMoviesTask.Result;
        _loading = false;
    }
}
