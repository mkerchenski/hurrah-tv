@page "/"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject QuickActionService QuickActionSvc
@inject MediaFilterService MediaFilter
@inject UserServicesCache UserServicesCache
@inject HeroCache HeroCache
@inject TokenService TokenService
@inject HurrahAuthStateProvider AuthState
@using HurrahTv.Shared.Filters

<PageTitle>Hurrah.tv - Your Streaming, Curated</PageTitle>

@if (!_servicesLoaded)
{
    <div class="text-center py-20">
        <div class="w-8 h-8 border-2 border-accent border-t-transparent rounded-full animate-spin mx-auto"></div>
    </div>
}
else if (!_onboardingComplete)
{
    <div class="max-w-2xl mx-auto py-8 md:py-12 fade-in">
        <h1 class="text-3xl md:text-4xl font-bold mb-2 text-center">Welcome to <span class="text-accent">hurrah.tv</span></h1>

        <!-- step indicator -->
        <div class="flex items-center justify-center gap-2 mb-6 md:mb-8">
            @for (int i = 1; i <= 4; i++)
            {
                int step = i;
                <div class="flex items-center gap-2">
                    <div class="@($"w-7 h-7 rounded-full flex items-center justify-center text-xs font-semibold transition-colors {(step <= _onboardingStep ? "bg-accent text-white" : "bg-surface-200 text-gray-500")}")">
                        @step
                    </div>
                    @if (step < 4)
                    {
                        <div class="w-8 h-0.5 @(step < _onboardingStep ? "bg-accent" : "bg-surface-200")"></div>
                    }
                </div>
            }
        </div>

        @if (_onboardingStep == 1)
        {
            <!-- step 1: name (optional) — powers greetings + AI personalization -->
            <div class="text-center max-w-sm mx-auto">
                <p class="text-gray-400 mb-2 text-base md:text-lg">What should we call you?</p>
                <p class="text-gray-500 text-sm mb-6">First name only. Used to personalize your home page and AI recommendations. You can skip and add it later.</p>
                <input type="text" @bind="_pendingFirstName" @bind:event="oninput"
                       placeholder="e.g. Mike"
                       maxlength="50"
                       class="w-full bg-surface-100 border border-surface-200 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent text-center text-lg" />
                <div class="flex gap-3 justify-center mt-6">
                    <button class="border border-surface-200 text-gray-400 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors"
                            @onclick="OnboardingNext">
                        Skip
                    </button>
                    <button class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-lg transition-colors disabled:opacity-40"
                            disabled="@(string.IsNullOrWhiteSpace(_pendingFirstName))"
                            @onclick="OnboardingNext">
                        Next
                    </button>
                </div>
            </div>
        }
        else if (_onboardingStep == 2)
        {
            <!-- step 2: streaming services -->
            <div class="text-center">
                <p class="text-gray-400 mb-6 text-base md:text-lg">Which streaming services do you have?</p>
                <ServicePicker @bind-SelectedIds="_pendingServices" />
                <div class="flex gap-3 justify-center mt-6">
                    <button class="border border-surface-200 text-gray-400 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors"
                            @onclick="OnboardingBack">
                        Back
                    </button>
                    <button class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-lg transition-colors disabled:opacity-40"
                            disabled="@(_pendingServices.Count == 0)"
                            @onclick="OnboardingNext">
                        Next
                    </button>
                </div>
            </div>
        }
        else if (_onboardingStep == 3)
        {
            <!-- step 3: genres -->
            <div class="text-center">
                <p class="text-gray-400 mb-6 text-base md:text-lg">What genres do you enjoy?</p>
                <GenrePicker @bind-SelectedIds="_pendingGenres" />
                <div class="flex gap-3 justify-center mt-6">
                    <button class="border border-surface-200 text-gray-400 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors"
                            @onclick="OnboardingBack">
                        Back
                    </button>
                    <button class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-lg transition-colors disabled:opacity-40"
                            disabled="@(_pendingGenres.Count == 0)"
                            @onclick="OnboardingNext">
                        Next
                    </button>
                </div>
            </div>
        }
        else if (_onboardingStep == 4)
        {
            <!-- step 4: pick shows -->
            <div>
                <p class="text-gray-400 mb-6 text-base md:text-lg text-center">Pick a few shows you watch or have watched — this powers your recommendations.</p>
                <ShowPicker SelectionsChanged="OnShowSelectionsChanged" />
                <div class="flex gap-3 justify-center mt-6">
                    <button class="border border-surface-200 text-gray-400 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors"
                            @onclick="OnboardingBack">
                        Back
                    </button>
                    <button class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-lg transition-colors disabled:opacity-40"
                            disabled="@(_pendingShows.Count < 3)"
                            @onclick="FinishOnboarding">
                        Get Started
                    </button>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="fade-in">
        <!-- hero billboard — the rotating daily AI pick. While it loads we show a skeleton rather
             than a watchlist item, so the hero never flashes a show that's already in the list.
             It only falls back to Continue Watching / New This Week if AI curation is unavailable;
             nothing renders when there's no candidate at all. Shuffle asks for a different pick. -->
        @if (_hero is not null)
        {
            <HomeHero Item="_hero" OnShuffle="@(() => LoadHero(refresh: true))" />
        }
        else if (_heroLoading)
        {
            <section class="relative -mx-4 md:-mx-6 mb-6 md:mb-10 overflow-hidden rounded-b-xl md:rounded-xl">
                <div class="aspect-[3/4] sm:aspect-[16/9] md:aspect-[21/9] loading-shimmer"></div>
            </section>
        }

        <!-- My Watchlist section — header with chips + all three rows grouped together -->
        @{
            // use pre-filter flags so the section (and its chips) stays visible
            // even when the active status filter produces zero results
            bool hasWatchlistContent =
                (MediaFilter.MediaType != "movie" && _hasTvWatchlistContent)
                || (MediaFilter.MediaType != "tv" && _hasMovieWatchlistContent);
        }
        @if (!_queueLoaded)
        {
            <!-- skeleton mirrors the real watchlist section's structure so the swap doesn't grow the
                 page and shove the rows below it down (#175 CLS): title + chip/sort control row, then
                 two WatchlistRow-shaped placeholders (header bar + poster strip + label). Two rows is
                 the common case (Available Now + Available Later); a sparse account collapses by at
                 most one row, far less shift than the prior single bare poster row. matches the real
                 header (Home.razor) and WatchlistRow card structure. -->
            <div class="mb-8">
                <div class="mb-4">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="icon-[heroicons--rectangle-stack] w-5 h-5 text-accent"></span>
                        <h2 class="text-lg md:text-xl font-bold text-white">@WatchlistTitle</h2>
                    </div>
                    <div class="flex items-center justify-between mt-3 gap-2">
                        <div class="h-7 w-28 md:w-44 bg-surface-100 rounded-lg animate-pulse"></div>
                        <div class="h-7 w-36 bg-surface-100 rounded-lg animate-pulse"></div>
                    </div>
                </div>

                @for (int row = 0; row < 2; row++)
                {
                    <section class="mb-6 md:mb-8">
                        <div class="h-5 w-40 bg-surface-100 rounded animate-pulse mb-3"></div>
                        <div class="flex gap-3 overflow-hidden">
                            @for (int i = 0; i < 6; i++)
                            {
                                <div class="flex-shrink-0 w-32 sm:w-32 md:w-36">
                                    <div class="aspect-[2/3] bg-surface-100 rounded-lg animate-pulse"></div>
                                    <div class="h-3 w-20 bg-surface-100 rounded animate-pulse mt-1.5"></div>
                                </div>
                            }
                        </div>
                    </section>
                }
            </div>
        }
        else if (hasWatchlistContent)
        {
            <div class="mb-8">
                <!-- section header — matches Curated for You pattern -->
                <div class="mb-4">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="icon-[heroicons--rectangle-stack] w-5 h-5 text-accent"></span>
                        <h2 class="text-lg md:text-xl font-bold text-white">@WatchlistTitle</h2>
                    </div>
                    <div class="flex items-center justify-between mt-3 gap-2">
                        @if (MediaFilter.MediaType != "movie")
                        {
                            <div class="flex gap-0.5 bg-surface-100 rounded-lg p-0.5">
                                @foreach (QueueStatus status in new[] { QueueStatus.Watching, QueueStatus.WantToWatch, QueueStatus.Finished })
                                {
                                    bool active = IsStatusActive(status);
                                    string chipLabel = BadgeHelpers.StatusShortLabel(status);
                                    string chipIcon = BadgeHelpers.StatusIcon(status);
                                    <button class="@(active ? "bg-surface-200 text-white font-medium" : "text-gray-500 hover:text-white") flex items-center gap-1 px-2 md:px-3 py-1 rounded-md text-xs transition-all"
                                            @onclick="() => ToggleStatusFilter(status)">
                                        <span class="@chipIcon w-3 h-3"></span>
                                        <span class="hidden md:inline">@chipLabel</span>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <div></div>
                        }
                        <!-- sort control — same level as filter, saved to UserSettings -->
                        <div class="flex gap-0.5 bg-surface-100 rounded-lg p-0.5">
                            @foreach (string mode in new[] { "date", "sentiment", "queue" })
                            {
                                string modeLabel = mode switch { "date" => "Date", "sentiment" => "Liked", _ => "List" };
                                @if (_watchlistSort == mode)
                                {
                                    <button class="bg-surface-200 text-white font-semibold text-xs px-3 py-1 rounded-md"
                                            @onclick="() => OnWatchlistSortChanged(mode)">@modeLabel</button>
                                }
                                else
                                {
                                    <button class="text-gray-500 hover:text-white text-xs px-3 py-1 rounded-md transition-colors"
                                            @onclick="() => OnWatchlistSortChanged(mode)">@modeLabel</button>
                                }
                            }
                        </div>
                    </div>
                </div>

                @{
                    bool hasVisibleRows =
                        (MediaFilter.MediaType != "movie" && (_availableNowItems.Count > 0 || _availableLaterItems.Count > 0))
                        || (MediaFilter.MediaType != "tv" && _wantToWatchMovies.Count > 0
                            && (MediaFilter.MediaType == "movie" || _settings.ShowWantToWatch));
                }

                @if (MediaFilter.MediaType != "movie")
                {
                    @if (_availableNowItems.Count > 0)
                    {
                        <WatchlistRow Title="Available Now" Subtitle="Streaming today" Items="_availableNowItems" ShowAirDates="true" RowMode="now" />
                    }
                    @if (_availableLaterItems.Count > 0)
                    {
                        <WatchlistRow Title="Available Later" Subtitle="Coming this week" Items="_availableLaterItems" ShowAirDates="true" RowMode="later" />
                    }
                }

                @if (MediaFilter.MediaType != "tv" && _wantToWatchMovies.Count > 0
                     && (MediaFilter.MediaType == "movie" || _settings.ShowWantToWatch))
                {
                    <WatchlistRow Title="Movies to Watch" Items="_wantToWatchMovies" ShowAirDates="false" ShowStatusBadge="false" />
                }

                @if (!hasVisibleRows)
                {
                    <p class="text-gray-600 text-sm py-2">No shows match your current filters.</p>
                }
            </div>
        }

        <!-- TV-only rows (hidden in Movies mode) -->
        @if (MediaFilter.MediaType != "movie")
        {
            <ContentRow Title="New This Season" Subtitle="Recently aired" LoadData="LoadNewTv" NewEpisodeTmdbIds="_newEpisodeTmdbIds" HideIfFewer="4" />
            <ContentRow Title="Trending TV Shows" Subtitle="Popular on your services" LoadData="LoadTrendingTv" NewEpisodeTmdbIds="_newEpisodeTmdbIds" HideIfFewer="4" />
        }

        <!-- Movie-only rows (hidden in TV Shows mode) -->
        @if (MediaFilter.MediaType != "tv")
        {
            <ContentRow Title="New Releases" Subtitle="Recently released" LoadData="LoadNewMovies" HideIfFewer="4" />
            <ContentRow Title="Trending Movies" Subtitle="Popular on your services" LoadData="LoadTrendingMovies" HideIfFewer="4" />
        }

        <!-- "because you loved X" rows — seeded from matching media type -->
        @foreach (QueueItem seed in _recSeeds)
        {
            <ContentRow Title="@($"Because You Loved {seed.Title}")"
                        LoadData="@(() => Api.GetRecommendationsAsync(seed.TmdbId, seed.MediaType))"
                        NewEpisodeTmdbIds="_newEpisodeTmdbIds"
                        HideIfFewer="4" />
        }
    </div>
}

@code {
    private IReadOnlyList<int> _userServices = [];
    private List<int> _pendingServices = [];
    private List<int> _pendingGenres = [];
    private string _pendingFirstName = "";
    private string? _firstName;
    private Dictionary<int, (SearchResult Result, QueueStatus Status, int? Sentiment)> _pendingShows = [];
    private int _onboardingStep = 1;
    private bool _servicesLoaded;
    private bool _onboardingComplete;
    private bool _queueLoaded;

    // full queue cache — source for splicing in-place updates from QuickActions without a refetch.
    // ApplyWatchlistFilters reads from this and produces the filtered _availableNowItems / _availableLaterItems / etc.
    private List<QueueItem> _allItems = [];

    // watchlist rows
    private List<QueueItem> _availableNowItems = [];
    private List<QueueItem> _availableLaterItems = [];
    private List<QueueItem> _wantToWatchMovies = [];
    // pre-filter existence flags — keep section visible even when chips filter everything out
    private bool _hasTvWatchlistContent;
    private bool _hasMovieWatchlistContent;
    private HashSet<int> _newEpisodeTmdbIds = [];
    private List<QueueItem> _recSeeds = [];
    private int[] _queuedTmdbIds = [];
    private HashSet<(int TmdbId, int Season, int Episode)> _watchedSet = [];
    private string _watchlistSort = "date"; // single sort for all My Watchlist rows, synced with UserSettings
    private UserSettings _settings = new();

    // AI curation — a single rotating hero pick (the only AI surface on Home). null until
    // the background fetch returns. While _heroLoading we show a skeleton rather than a
    // watchlist fallback, so the hero never flashes an already-in-list item.
    private CuratedHero? _heroPick;
    // default true so the hero skeleton reserves its full aspect-ratio height from the very first
    // render of the watchlist view — otherwise the hero area renders at zero height until
    // OnInitializedAsync sets the flag, then pops to full height and shoves the watchlist down (CLS, #175).
    private bool _heroLoading = true;
    private int _heroRequestSeq; // latest-wins guard so overlapping fetches don't both apply
    private bool _disposed;      // LoadHero is fire-and-forget + slow; don't render after disposal
    // page-scoped CTS, cancelled in Dispose(), so navigating away mid-fetch aborts the
    // server-side paid AI inference (the /hero endpoint forwards the token to Claude), not
    // just the client-side render. Mirrors Details.razor's _loadCts pattern. pins #131.
    private readonly CancellationTokenSource _cts = new();

    // hero billboard — cached so it doesn't recompute on every render. recomputed in
    // ReapplyDerivedState after queue mutations and after the AI pick arrives.
    private HomeHero.HeroItem? _hero;

    protected override async Task OnInitializedAsync()
    {
        QuickActionSvc.OnChanged += OnQuickActionChanged;
        QuickActionSvc.OnItemUpdated += OnItemUpdated;
        QuickActionSvc.OnItemRemoved += OnItemRemoved;
        QuickActionSvc.OnEpisodeWatchedChanged += OnEpisodeWatchedChanged;
        MediaFilter.OnChanged += OnMediaFilterChanged;
        UserServicesCache.Changed += OnUserServicesChanged;

        // services-count is the onboarding gate — resolve it before firing settings/queue,
        // so a non-onboarded user doesn't waste two authenticated round-trips on results
        // that get discarded
        Task<IReadOnlyList<int>> servicesTask = UserServicesCache.GetAsync();

        // first name is read from JWT claim — set during sign-in or after profile updates
        Microsoft.AspNetCore.Components.Authorization.AuthenticationState state = await AuthState.GetAuthenticationStateAsync();
        _firstName = state.User.FindFirst("firstname")?.Value;

        _userServices = await servicesTask;
        _servicesLoaded = true;
        _onboardingComplete = _userServices.Count > 0;

        if (!_onboardingComplete) return;

        // onboarded — settings + queue run in parallel; AI is fire-and-forget below
        Task<UserSettings> settingsTask = Api.GetUserSettingsAsync();
        Task<QueueResponse> queueTask = Api.GetQueueResponseAsync();

        _settings = await settingsTask;
        _watchlistSort = _settings.WatchlistSort;

        // ProcessQueueResponse computes _hero via SelectHero; _heroLoading stays true so the hero
        // slot shows its skeleton (never flashing an in-list fallback) until the cache seed below
        // or the /hero fetch resolves.
        ProcessQueueResponse(await queueTask);

        // seed the hero from the last-known localStorage cache so the backdrop — already being
        // preloaded pre-boot by index.html's inline script — paints on first render instead of
        // waiting for the /hero round-trip; LoadHero below swaps in the fresh pick (#229). Gate the
        // seed exactly like SelectHero's AI branch AND the server's daily-hero safety-net: only when
        // it has a backdrop, matches the active media filter, and isn't already on the watchlist —
        // otherwise leave the skeleton up rather than flash a wrong-filter or already-queued hero.
        CuratedHero? cachedHero = await HeroCache.GetAsync();
        if (cachedHero is { Result: { } seed } && !string.IsNullOrEmpty(seed.BackdropPath)
            && (MediaFilter.MediaType == "all" || seed.MediaType == MediaFilter.MediaType)
            && !_allItems.Any(i => i.TmdbId == seed.TmdbId && i.MediaType == seed.MediaType))
        {
            _heroPick = cachedHero;
            _heroLoading = false;
            _hero = SelectHero();
        }

        // AI is the slowest call (Claude API) and not needed for first paint — let it finish in
        // the background and swap the hero to the AI pick when it returns
        _ = LoadHero();
    }

    private async Task OnboardingNext()
    {
        if (_onboardingStep == 1)
        {
            // save name (or skip if blank) and refresh JWT so the new firstname claim is live
            string? trimmed = string.IsNullOrWhiteSpace(_pendingFirstName) ? null : _pendingFirstName.Trim();
            if (trimmed is not null)
            {
                AuthResponse? auth = await Api.UpdateProfileAsync(trimmed);
                if (auth is not null)
                {
                    await TokenService.SetTokenAsync(auth.Token);
                    AuthState.NotifyAuthChanged();
                    _firstName = trimmed;
                }
            }
        }
        else if (_onboardingStep == 2)
        {
            // save services immediately so step 4 can use existing discovery endpoints
            await Api.SetUserServicesAsync(_pendingServices);
            UserServicesCache.Set(_pendingServices);
            _userServices = _pendingServices;
        }
        else if (_onboardingStep == 3)
        {
            // save genres immediately so step 4 show picker gets genre-filtered results
            await Api.SetUserGenresAsync(_pendingGenres);
        }
        _onboardingStep++;
    }

    private void OnboardingBack() => _onboardingStep--;

    private void OnShowSelectionsChanged(Dictionary<int, (SearchResult Result, QueueStatus Status, int? Sentiment)> selections)
    {
        _pendingShows = selections;
    }

    private async Task FinishOnboarding()
    {
        // add all selected shows to queue in parallel
        await Task.WhenAll(_pendingShows.Values.Select(async entry =>
        {
            QueueItem item = entry.Result.ToQueueItem();
            item.Status = entry.Status;
            item.Sentiment = entry.Sentiment;
            await Api.AddToQueueAsync(item);
        }));

        _onboardingComplete = true;
        await LoadWatchlistData();
    }

    private void ProcessQueueResponse(QueueResponse queueResponse)
    {
        _allItems = queueResponse.Items;
        _watchedSet = [.. queueResponse.WatchedEpisodes.Select(w => (w.TmdbId, w.Season, w.Episode))];
        StampWatchedFlags();
        ReapplyDerivedState();
        _queueLoaded = true;
        StateHasChanged();
    }

    // recomputes filtered rows + helper sets from _allItems. Called after any in-place mutation
    // so we don't need a full /api/queue refetch to reflect single-item changes.
    private void ReapplyDerivedState()
    {
        _queuedTmdbIds = [.. _allItems.Select(i => i.TmdbId).Distinct()];
        _recSeeds = PickRecSeeds(_allItems, 3, MediaFilter.MediaType);
        ApplyWatchlistFilters(_allItems);
        _newEpisodeTmdbIds = [.. _availableNowItems.Concat(_availableLaterItems).Select(i => i.TmdbId)];
        _hero = SelectHero();
    }

    private void StampWatchedFlags()
    {
        // high-water mark per show: the newest (season, episode) the user has watched.
        // pre-computed once (not per-item) so the caught-up check below is O(1) per item.
        // we compare against this rather than exact-matching the stored latest S/E, because
        // for daily shows the stored latest lags the truly-newest aired episode — watching
        // the newer one must still count as caught up (#189).
        Dictionary<int, (int Season, int Episode)> highWater = _watchedSet
            .GroupBy(w => w.TmdbId)
            .ToDictionary(g => g.Key, g => g.Max(w => (w.Season, w.Episode)));

        foreach (QueueItem item in _allItems)
        {
            item.IsLatestEpisodeWatched = QueueItemExtensions.IsLatestEpisodeWatched(
                item.LatestEpisodeSeason,
                item.LatestEpisodeNumber,
                highWater.TryGetValue(item.TmdbId, out (int Season, int Episode) hw) ? hw : null);
        }
    }

    private void OnItemUpdated(QueueItem updated) => InvokeAsync(() =>
    {
        // splice the updated item into _allItems by Id, recompute derived state, render
        int idx = _allItems.FindIndex(i => i.Id == updated.Id);
        if (idx >= 0)
        {
            // preserve IsLatestEpisodeWatched (server doesn't include the watched-set), restamp below
            _allItems[idx] = updated;
        }
        else
        {
            _allItems.Add(updated);
        }
        StampWatchedFlags();
        ReapplyDerivedState();
        StateHasChanged();
    });

    // a queued item was removed from another surface (e.g. Details toggling its active status
    // off). Splice it out of _allItems by Id, recompute derived rows, render — no /api/queue
    // refetch needed. Mirrors OnItemUpdated. No-op if we never had the item locally.
    private void OnItemRemoved(int queueItemId) => InvokeAsync(() =>
    {
        int idx = _allItems.FindIndex(i => i.Id == queueItemId);
        if (idx < 0) return;
        _allItems.RemoveAt(idx);
        StampWatchedFlags();
        ReapplyDerivedState();
        StateHasChanged();
    });

    private void OnEpisodeWatchedChanged(int tmdbId, int season, int episode, bool watched) => InvokeAsync(() =>
    {
        (int TmdbId, int Season, int Episode) key = (tmdbId, season, episode);
        if (watched) _watchedSet.Add(key);
        else _watchedSet.Remove(key);
        StampWatchedFlags();
        ReapplyDerivedState();
        StateHasChanged();
    });

    private async Task LoadWatchlistData()
    {
        // set BEFORE ProcessQueueResponse so SelectHero renders the skeleton, not a watchlist
        // fallback, until the AI pick lands (see OnInitializedAsync for the full rationale)
        _heroLoading = true;
        QueueResponse queueResponse = await Api.GetQueueResponseAsync();
        ProcessQueueResponse(queueResponse);

        // AI hero is fire-and-forget — slow Claude call shouldn't block first paint
        _ = LoadHero();
    }

    private bool IsStatusActive(QueueStatus status) => status switch
    {
        QueueStatus.Watching    => _settings.ShowWatching,
        QueueStatus.WantToWatch => _settings.ShowWantToWatch,
        QueueStatus.Finished    => _settings.ShowFinished,
        _                       => false
    };

    private async Task ToggleStatusFilter(QueueStatus status)
    {
        // count currently active chips — prevent turning off the last one
        int activeCount = (_settings.ShowWatching ? 1 : 0) + (_settings.ShowWantToWatch ? 1 : 0) + (_settings.ShowFinished ? 1 : 0);
        bool current = IsStatusActive(status);
        if (current && activeCount == 1) return; // last active chip — snap back

        switch (status)
        {
            case QueueStatus.Watching:    _settings.ShowWatching    = !current; break;
            case QueueStatus.WantToWatch: _settings.ShowWantToWatch = !current; break;
            case QueueStatus.Finished:    _settings.ShowFinished    = !current; break;
        }

        // re-apply the filter from the in-memory queue for an instant response — the chip flags are
        // read by ApplyWatchlistFilters inside ReapplyDerivedState, so no /api/queue refetch is needed
        // (this used to call ReloadWatchlist, which round-tripped). Persist the setting afterward.
        ReapplyDerivedState();
        StateHasChanged();
        await Api.SetUserSettingsAsync(_settings);
    }

    private void ApplyWatchlistFilters(List<QueueItem> allItems)
    {
        // Available Now (streamable today) and Available Later (any upcoming episode in the
        // window, any service — #214) are derived by a pure partition in HurrahTv.Shared — see
        // WatchlistFilters.
        WatchlistFilters.Partition partition = WatchlistFilters.Apply(
            allItems,
            DateTime.UtcNow,
            MediaFilter.MediaType,
            IsStatusActive,
            _userServices);

        _hasTvWatchlistContent = partition.HasTvContent;
        _hasMovieWatchlistContent = partition.HasMovieContent;

        _availableNowItems = SortWatching(partition.AvailableNow);
        _availableLaterItems = SortUpcoming(partition.AvailableLater);
        _wantToWatchMovies = SortMovies(partition.Movies);
    }

    // fetch the rotating AI hero pick and swap it into the hero slot. Best-effort: on any
    // failure the fallback hero (Continue Watching / New This Week) already shows, so there
    // is no error UI. refresh=true asks the server for a different pick (manual escape hatch).
    private async Task LoadHero(bool refresh = false)
    {
        // latest-wins: a slower in-flight fetch (e.g. the initial load) must not clobber a
        // newer one (e.g. a shuffle). Only the most recent request applies its result.
        int seq = ++_heroRequestSeq;
        try
        {
            CuratedHeroResponse? response = await Api.GetCuratedHeroAsync(refresh, MediaFilter.MediaType, _cts.Token);
            if (seq == _heroRequestSeq && response?.Hero is not null)
            {
                _heroPick = response.Hero;
                // persist for the next load's pre-boot preload + seed. Fire-and-forget: caching is
                // best-effort and must not delay the hero swap or throw into the render path.
                _ = HeroCache.SetAsync(response.Hero);
            }
        }
        catch
        {
            // hero is non-critical — leave any existing pick / fallback in place. Also the
            // catch-all swallows the OperationCanceledException raised when _cts is cancelled
            // on disposal, so navigating away never surfaces as an error.
        }
        finally
        {
            // the hero fetch is the slowest call in the app; the user may navigate away before
            // it returns. Don't touch state / render on a disposed component.
            if (!_disposed && seq == _heroRequestSeq)
            {
                _heroLoading = false;
                _hero = SelectHero();
                StateHasChanged();
            }
        }
    }

    // content row data loaders — pass queued IDs so discovered items exclude already-queued shows
    private Task<List<SearchResult>> LoadTrendingTv() => Api.ForYouAsync("tv", _queuedTmdbIds);
    private Task<List<SearchResult>> LoadNewTv() => Api.NewOnServicesAsync("tv", _queuedTmdbIds);
    private Task<List<SearchResult>> LoadTrendingMovies() => Api.ForYouAsync("movie", _queuedTmdbIds);
    private Task<List<SearchResult>> LoadNewMovies() => Api.NewOnServicesAsync("movie", _queuedTmdbIds);

    // Favorite(3)→2, Liked(2)→1, null→0, Disliked(1)→-1 so null sorts between Liked and Disliked
    private static int SentimentSortKey(int? sentiment) => sentiment switch
    {
        SentimentLevel.Favorite => 2,
        SentimentLevel.Up       => 1,
        null                    => 0,
        _                       => -1
    };

    private static List<QueueItem> PickRecSeeds(List<QueueItem> allItems, int count, string mediaType = "all")
    {
        // prefer items with positive sentiment, fallback to Finished; filter by active media type
        List<QueueItem> candidates = allItems
            .Where(i => (mediaType == "all" || i.MediaType == mediaType)
                && (i.Sentiment >= SentimentLevel.Up || i.Status == QueueStatus.Finished))
            .ToList();

        if (candidates.Count <= count) return candidates;

        DateTime recentCutoff = DateTime.UtcNow.AddDays(-30);
        Random rng = new();
        List<(QueueItem item, double weight)> weighted = candidates
            .Select(i => (i, weight: (i.AddedAt >= recentCutoff ? 3.0 : 1.0) * rng.NextDouble()))
            .OrderByDescending(x => x.weight)
            .ToList();

        return weighted.Take(count).Select(x => x.item).ToList();
    }

    private async Task ReloadWatchlist() =>
        ProcessQueueResponse(await Api.GetQueueResponseAsync());

    private async Task OnWatchlistSortChanged(string mode)
    {
        _watchlistSort = mode;
        _settings.WatchlistSort = mode;
        _ = Api.SetUserSettingsAsync(_settings);
        _availableNowItems = SortWatching(_availableNowItems);
        _availableLaterItems = SortUpcoming(_availableLaterItems);
        _wantToWatchMovies = SortMovies(_wantToWatchMovies);
        StateHasChanged();
    }

    private List<QueueItem> SortWatching(IEnumerable<QueueItem> items) => _watchlistSort switch
    {
        "sentiment" => [.. items.OrderByDescending(i => SentimentSortKey(i.Sentiment)).ThenByDescending(i => i.LatestEpisodeDate ?? DateTime.MinValue)],
        "queue"     => [.. items.OrderBy(i => QueueStatusOrdering.SortPriority(i.Status)).ThenByDescending(i => i.LatestEpisodeDate ?? DateTime.MinValue)],
        _           => [.. items.OrderByDescending(i => i.HasEpisodeThisMonth ? 1 : 0).ThenByDescending(i => i.LatestEpisodeDate ?? DateTime.MinValue).ThenBy(i => i.Position)]
    };

    private List<QueueItem> SortUpcoming(IEnumerable<QueueItem> items)
    {
        DateTime today = DateTime.UtcNow.Date;
        // a latest episode dated today is routed into Upcoming as a "drops today" item (see
        // WatchlistFilters, #196). Sort it ahead of strictly-future episodes by keying it on today
        // rather than its NextEpisodeDate, which may be null (→ MaxValue, sorts last) or far off.
        DateTime UpcomingKey(QueueItem i) =>
            i.IsDroppingToday(today) ? today : (i.NextEpisodeDate?.Date ?? DateTime.MaxValue);

        return _watchlistSort switch
        {
            "sentiment" => [.. items.OrderByDescending(i => SentimentSortKey(i.Sentiment)).ThenBy(UpcomingKey)],
            "queue"     => [.. items.OrderBy(i => QueueStatusOrdering.SortPriority(i.Status)).ThenBy(UpcomingKey)],
            _           => [.. items.OrderBy(UpcomingKey)]
        };
    }

    private List<QueueItem> SortMovies(IEnumerable<QueueItem> items) => _watchlistSort switch
    {
        "sentiment" => [.. items.OrderByDescending(i => SentimentSortKey(i.Sentiment)).ThenByDescending(i => i.AddedAt)],
        _           => [.. items.OrderByDescending(i => i.AddedAt)]
    };

    private void OnQuickActionChanged() => _ = InvokeAsync(async () =>
    {
        try { await ReloadWatchlist(); }
        catch { /* leave stale data in place on network failure */ }
    });

    private void OnMediaFilterChanged() => _ = InvokeAsync(() =>
    {
        // MediaFilter is a global service whose InitializeAsync can fire OnChanged during startup,
        // racing Home's own load. Skip until the queue is loaded — OnInitializedAsync owns first
        // render and already reads the initialized media filter, so a pre-load run would only derive
        // empty rows and kick a redundant LoadHero. Mirrors OnUserServicesChanged's _queueLoaded guard.
        if (!_queueLoaded) return;

        // re-fetch a media-appropriate AI hero for the new filter (#147). The single client-held pick
        // may be the other media type; the server re-selects from the SAME cached reservoir (no paid
        // regen). Set _heroLoading BEFORE re-deriving so SelectHero (inside ReapplyDerivedState) keeps
        // the current pick only if it still matches the new filter, else renders the skeleton — the
        // flag gates the derived _hero value, so it must be set before that value is recomputed (#135).
        _heroLoading = true;
        // the hero fetch is independent (the server reads its own watchlist for the hero, not the
        // client's), so kick it off — the new media-appropriate pick lands when it returns.
        _ = LoadHero();
        // the media partition is a pure function of the in-memory queue + the new media filter
        // (cf. OnUserServicesChanged), so re-derive locally instead of refetching /api/queue.
        ReapplyDerivedState();
        StateHasChanged();
    });

    // user changed services in Settings — refresh the cached list and re-run the partition
    // (no /api/queue refetch needed; the filter is a pure function of services + items).
    private void OnUserServicesChanged() => InvokeAsync(() =>
    {
        _userServices = UserServicesCache.TryGetCached();
        if (_queueLoaded)
        {
            ReapplyDerivedState();
            StateHasChanged();
        }
    });

    // possessive form when we have a first name; "My" otherwise. used in section header
    // (replaces the standalone "Good morning, X" greeting we used to render above).
    private string WatchlistTitle => string.IsNullOrWhiteSpace(_firstName)
        ? "My Watchlist"
        : $"{_firstName}'s Watchlist";

    // hero source priority. Rotating AI pick > Continue Watching > Latest aired this week.
    // the AI pick is the primary surface but arrives async, so until it loads (or when it's
    // unavailable / filtered out) the hero falls back to the watchlist-derived options.
    // returns null when nothing has a usable backdrop yet (fresh users before backfill).
    private HomeHero.HeroItem? SelectHero()
    {
        // 1. the rotating AI pick (the only AI surface), if it matches the active media filter
        if (_heroPick is { Result: { } pick } && !string.IsNullOrEmpty(pick.BackdropPath)
            && (MediaFilter.MediaType == "all" || pick.MediaType == MediaFilter.MediaType))
        {
            return new HomeHero.HeroItem(
                Eyebrow: "Recommended for You",
                Title: pick.Title,
                BackdropUrl: pick.BackdropUrl("w1280"),
                BackdropPathRaw: pick.BackdropPath,
                PosterPath: pick.PosterPath,
                Overview: _heroPick.Reason,
                TmdbId: pick.TmdbId,
                MediaType: pick.MediaType,
                PrimaryLabel: "Add to list",
                PrimaryAction: HomeHero.HeroAction.Add);
        }

        // while the AI pick is still loading, render nothing here — Home shows a skeleton in the
        // hero slot. This stops an in-list Continue Watching item from flashing as the "hero"
        // during the load window; the fallbacks below only apply once curation has resolved.
        if (_heroLoading) return null;

        // 2. an item the user is actively watching, with a backdrop available, matching the active media filter
        QueueItem? watching = _availableNowItems.FirstOrDefault(i =>
            i.Status == QueueStatus.Watching && !string.IsNullOrEmpty(i.BackdropPath)
            && (MediaFilter.MediaType == "all" || i.MediaType == MediaFilter.MediaType));
        if (watching is not null)
        {
            return new HomeHero.HeroItem(
                Eyebrow: "Continue Watching",
                Title: watching.Title,
                BackdropUrl: watching.BackdropUrl(),
                BackdropPathRaw: watching.BackdropPath,
                PosterPath: watching.PosterPath,
                Overview: null,
                TmdbId: watching.TmdbId,
                MediaType: watching.MediaType,
                PrimaryLabel: watching.MediaType == MediaTypes.Tv ? "Go to show" : "Go to movie",
                PrimaryAction: HomeHero.HeroAction.Resume);
        }

        // 3. a TV show whose latest episode aired in the last 7 days (regardless of status).
        // inherently TV-only ("new episode this week" has no movie analogue), so it's suppressed
        // under the Movies filter — otherwise the hero would leak a TV show under Movies (#167).
        QueueItem? recent = MediaFilter.MediaType == "movie" ? null : _allItems
            .Where(i => i.MediaType == MediaTypes.Tv
                && i.HasNewEpisode
                && i.Status != QueueStatus.NotForMe
                && !string.IsNullOrEmpty(i.BackdropPath))
            .OrderByDescending(i => i.LatestEpisodeDate)
            .FirstOrDefault();
        if (recent is not null)
        {
            return new HomeHero.HeroItem(
                Eyebrow: "New This Week",
                Title: recent.Title,
                BackdropUrl: recent.BackdropUrl(),
                BackdropPathRaw: recent.BackdropPath,
                PosterPath: recent.PosterPath,
                Overview: null,
                TmdbId: recent.TmdbId,
                MediaType: recent.MediaType,
                PrimaryLabel: "Watch latest",
                PrimaryAction: HomeHero.HeroAction.Resume);
        }

        return null;
    }

    public void Dispose()
    {
        _disposed = true;
        _cts.Cancel();
        _cts.Dispose();
        QuickActionSvc.OnChanged -= OnQuickActionChanged;
        QuickActionSvc.OnItemUpdated -= OnItemUpdated;
        QuickActionSvc.OnItemRemoved -= OnItemRemoved;
        QuickActionSvc.OnEpisodeWatchedChanged -= OnEpisodeWatchedChanged;
        MediaFilter.OnChanged -= OnMediaFilterChanged;
        UserServicesCache.Changed -= OnUserServicesChanged;
    }
}
