{
    "folders": [
        {
            "name": "HurrahTv.Api",
            "path": "HurrahTv.Api"
        },
        {
            "name": "HurrahTv.Client",
            "path": "HurrahTv.Client"
        },
        {
            "name": "HurrahTv.Shared",
            "path": "HurrahTv.Shared"
        },
        {
            "name": "Root (docs, plans, config)",
            "path": "."
        }
    ],
    "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "files.eol": "\n",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "[csharp]": {
            "editor.defaultFormatter": "ms-dotnettools.csharp",
            "editor.tabSize": 4
        },
        "[razor]": {
            "editor.defaultFormatter": "ms-dotnettools.csdevkit",
            "editor.tabSize": 4
        },
        "[aspnetcorerazor]": {
            "editor.defaultFormatter": "ms-dotnettools.csdevkit",
            "editor.tabSize": 4
        },
        "[json]": {
            "editor.defaultFormatter": "vscode.json-language-features",
            "editor.tabSize": 2
        },
        "[jsonc]": {
            "editor.defaultFormatter": "vscode.json-language-features",
            "editor.tabSize": 2
        },
        "[css]": {
            "editor.defaultFormatter": "vscode.css-language-features",
            "editor.tabSize": 2
        },
        "[yaml]": {
            "editor.tabSize": 2
        },
        "[markdown]": {
            "editor.tabSize": 2
        },
        "tailwindCSS.includeLanguages": {
            "razor": "html",
            "aspnetcorerazor": "html"
        },
        "tailwindCSS.experimental.classRegex": [
            [
                "class=\"([^\"]*)\"",
                "([^\"]*)"
            ]
        ],
        "files.associations": {
            "*.razor": "aspnetcorerazor"
        },
        "dotnet.defaultSolution": "HurrahTv.slnx",
        "search.exclude": {
            "**/bin": true,
            "**/obj": true,
            "**/node_modules": true,
            "**/wwwroot/app.css": true
        }
    },
    "extensions": {
        "recommendations": [
            "ms-dotnettools.csdevkit",
            "ms-dotnettools.csharp",
            "bradlc.vscode-tailwindcss",
            "GitHub.copilot",
            "GitHub.copilot-chat",
            "eamodio.gitlens",
            "anthropic.claude-code",
            "EditorConfig.EditorConfig"
        ]
    },
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Watch API",
                "type": "shell",
                "command": "dotnet",
                "args": [
                    "watch",
                    "--launch-profile",
                    "https"
                ],
                "options": {
                    "cwd": "${workspaceFolder:HurrahTv.Api}"
                },
                "isBackground": true,
                "problemMatcher": [],
                "presentation": {
                    "reveal": "always",
                    "panel": "dedicated",
                    "group": "hurrah"
                },
                "detail": "Runs the .NET API with hot reload on https://localhost:7201"
            },
            {
                "label": "Watch Client",
                "type": "shell",
                "command": "dotnet",
                "args": [
                    "watch",
                    "--launch-profile",
                    "https"
                ],
                "options": {
                    "cwd": "${workspaceFolder:HurrahTv.Client}"
                },
                "isBackground": true,
                "problemMatcher": [],
                "presentation": {
                    "reveal": "always",
                    "panel": "dedicated",
                    "group": "hurrah"
                },
                "detail": "Runs the Blazor WASM client with hot reload on https://localhost:7267"
            },
            {
                "label": "Watch All (API + Client)",
                "dependsOn": [
                    "Watch API",
                    "Watch Client"
                ],
                "dependsOrder": "parallel",
                "problemMatcher": [],
                "group": {
                    "kind": "build",
                    "isDefault": true
                },
                "detail": "Starts both the API and the Client in parallel. Use this as your F5 / default build task."
            },
            {
                "label": "Build CSS (rebuild + icons)",
                "type": "shell",
                "command": "npm",
                "args": [
                    "run",
                    "build:css"
                ],
                "options": {
                    "cwd": "${workspaceFolder:HurrahTv.Client}"
                },
                "problemMatcher": [],
                "presentation": {
                    "reveal": "always",
                    "panel": "dedicated",
                    "group": "hurrah"
                },
                "detail": "One-shot Tailwind rebuild + icon regeneration. Run this after any .razor class change OR any icon change. This is the canonical 'rebuild CSS' command."
            },
            {
                "label": "Build CSS (watch, Tailwind only — no icons)",
                "type": "shell",
                "command": "npm",
                "args": [
                    "run",
                    "dev:css"
                ],
                "options": {
                    "cwd": "${workspaceFolder:HurrahTv.Client}"
                },
                "isBackground": true,
                "problemMatcher": [],
                "presentation": {
                    "reveal": "silent",
                    "panel": "dedicated",
                    "group": "hurrah"
                },
                "detail": "Watch-mode rebuild for rapid class iteration. Does NOT regenerate icons — if you add a new icon, run 'Build CSS (rebuild + icons)' manually."
            },
            {
                "label": "Install Client dependencies (npm install)",
                "type": "shell",
                "command": "npm",
                "args": [
                    "install"
                ],
                "options": {
                    "cwd": "${workspaceFolder:HurrahTv.Client}"
                },
                "problemMatcher": [],
                "detail": "Run after a fresh clone or when package.json changes."
            },
            {
                "label": "Build Solution",
                "type": "shell",
                "command": "dotnet",
                "args": [
                    "build",
                    "HurrahTv.slnx"
                ],
                "options": {
                    "cwd": "${workspaceFolder:Root (docs, plans, config)}"
                },
                "problemMatcher": [
                    "$msCompile"
                ],
                "group": "build",
                "detail": "Builds the full solution without running."
            }
        ]
    },
    "launch": {
        "version": "0.2.0",
        "configurations": []
    }
}
